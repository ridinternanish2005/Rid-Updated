  <style>
    /* ===== RID TEAM PAGE PROFESSIONAL CSS ===== */

    :root {
      --primary: #0f4c81;
      --secondary: #1e88e5;
      --light: #f8fbff;
      --dark: #1f2937;
      --border: #e5edf7;
      --shadow: 0 10px 30px rgba(15, 76, 129, .12);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    @media (max-width: 768px) {
      .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      }
    }

    body {
      background: #f4f8fc;
      color: var(--dark);
    }

    /* MAIN WRAPPER */

    .content-wrap {
      max-width: 1400px;
      margin: 40px auto;
      padding: 0 20px;
    }

    /* SECTION TITLES */

    .section-heading,
    .section-sub {
      text-align: center;
      margin: 50px 0 25px;
      font-size: 2rem;
      font-weight: 700;
      color: var(--primary);
      position: relative;
    }

    .section-heading::after,
    .section-sub::after {
      content: '';
      width: 80px;
      height: 4px;
      background: var(--secondary);
      display: block;
      margin: 10px auto 0;
      border-radius: 20px;
    }

    /* GRID */

    .profile-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 28px;
    }

    /* CARD */

    .profile-card {
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      padding: 28px 20px;
      text-align: center;
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      transition: .35s ease;
      position: relative;
    }

    .profile-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 20px 40px rgba(15, 76, 129, .18);
    }

    .profile-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 6px;
      background: linear-gradient(90deg,
          var(--primary),
          var(--secondary));
    }

    /* IMAGE */

    .profile-pic {
      display: flex;
      justify-content: center;
      margin-bottom: 18px;
    }

    .pic-frame {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      overflow: hidden;
      border: 4px solid #fff;
      box-shadow: 0 5px 20px rgba(0, 0, 0, .15);
    }

    .pic-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* NAME */

    .profile-name h2 {
      font-size: 1.2rem;
      color: var(--dark);
      margin-bottom: 6px;
    }

    .role {
      display: inline-block;
      background: #e8f2ff;
      color: var(--primary);
      padding: 6px 14px;
      border-radius: 30px;
      font-size: .85rem;
      font-weight: 600;
    }

    /* DESCRIPTION */

    .profile-description {
      margin-top: 16px;
    }

    .profile-description p {
      color: #64748b;
      font-size: .92rem;
      line-height: 1.6;
    }

    /* BUTTON */

    .explore-btn {
      margin-top: 20px;
      border: none;
      background: linear-gradient(135deg,
          var(--primary),
          var(--secondary));
      color: #fff;
      padding: 12px 24px;
      border-radius: 50px;
      cursor: pointer;
      font-weight: 600;
      transition: .3s;
    }

    .explore-btn:hover {
      transform: translateY(-2px);
    }

    .explore-btn i {
      margin-left: 6px;
    }

    /* DETAIL PAGE */

    .detail-page {
      max-width: 1000px;
      margin: 40px auto;
      background: #fff;
      border-radius: 20px;
      padding: 40px;
      box-shadow: var(--shadow);
    }

    .detail-page-header {
      display: flex;
      align-items: center;
      gap: 25px;
      flex-wrap: wrap;
    }

    .detail-page-pic img {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      object-fit: cover;
      border: 5px solid #fff;
      box-shadow: 0 8px 25px rgba(0, 0, 0, .15);
    }

    .detail-page-text h1 {
      color: var(--primary);
      margin-bottom: 8px;
    }

    .detail-page-role {
      color: var(--secondary);
      font-weight: 600;
    }

    .detail-page-bio {
      margin-top: 30px;
    }

    .detail-page-bio p {
      line-height: 1.8;
      color: #4b5563;
    }

    .detail-page-bio ul {
      margin-top: 20px;
      padding-left: 20px;
    }

    .detail-page-bio li {
      margin-bottom: 10px;
    }

    .back-btn {
      display: inline-block;
      margin-top: 30px;
      text-decoration: none;
      color: #fff;
      background: var(--primary);
      padding: 12px 22px;
      border-radius: 50px;
      transition: .3s;
    }

    .back-btn:hover {
      background: var(--secondary);
    }

    /* MOBILE */

    @media(max-width:768px) {

      .section-heading,
      .section-sub {
        font-size: 1.5rem;
      }

      .detail-page {
        padding: 25px;
      }

      .detail-page-header {
        justify-content: center;
        text-align: center;
      }

      .pic-frame {
        width: 100px;
        height: 100px;
      }
    }
  </style>
</head>

