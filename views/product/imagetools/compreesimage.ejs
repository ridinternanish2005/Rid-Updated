<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Smart Image Compressor - Reduce Image Size Instantly</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        /* ========== PAGE STYLES (buttons reverted to previous colors) ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        @media (max-width: 768px) {
            .menu {
                position: fixed;
                top: 77px;
                left: 0;
                width: 100%;
                height: calc(100vh - 90px);
                background: rgba(255, 255, 255, 0.98);
                backdrop-filter: blur(15px);
                flex-direction: column;
                align-items: flex-start;
                justify-content: flex-start;
                display: none;
                padding: 30px 20px 20px;
                overflow-y: auto;
                z-index: 999;
                transform: translateX(-100%);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            }
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #0f172a;
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding-top: 130px;
        }

        .main-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0.5rem 1rem;
        }

        .container {
            max-width: 1400px;
            width: 95%;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .header {
            text-align: center;
            flex-shrink: 0;
        }

        .header h1 {
            font-size: 28px;
            font-weight: 800;
            background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            -webkit-text-fill-color: transparent;
        }

        .header p {
            color: #94a3b8;
            font-size: 12px;
        }

        /* Stats Bar */
        .stats-bar {
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(12px);
            border-radius: 12px;
            padding: 6px 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 15px;
            flex-shrink: 0;
            border: 1px solid rgba(71, 85, 105, 0.6);
        }

        .stats-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .stats-icon {
            width: 28px;
            height: 28px;
            background: rgba(129, 140, 248, 0.15);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .stats-icon svg {
            width: 14px;
            height: 14px;
        }

        .stats-info h4 {
            font-size: 9px;
            color: #94a3b8;
        }

        .stats-info p {
            font-size: 14px;
            font-weight: 700;
            color: #a5b4fc;
            line-height: 1.2;
        }

        /* Two columns – fixed height (compact) */
        .two-columns {
            display: flex;
            gap: 16px;
            flex: 1;
            height: 460px;
        }

        /* Left Column */
        .left-column {
            flex: 1;
            background: rgba(0, 0, 0, 0.25);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            padding: 12px;
            border: 1px solid rgba(71, 85, 105, 0.5);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Right Column */
        .right-column {
            flex: 1;
            background: rgba(0, 0, 0, 0.25);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            padding: 12px;
            border: 1px solid rgba(71, 85, 105, 0.5);
            display: flex;
            flex-direction: column;
            gap: 12px;
            overflow-y: auto;
        }

        /* Headers */
        .left-header,
        .right-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            padding-bottom: 6px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .left-header h3,
        .right-header h3 {
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            color: #e2e8f0;
        }

        .preview-badge {
            background: rgba(129, 140, 248, 0.2);
            padding: 2px 10px;
            border-radius: 40px;
            font-size: 10px;
            color: #a5b4fc;
        }

        /* Preview Grid */
        .preview-grid {
            flex: 1;
            overflow-y: auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 10px;
            padding-right: 4px;
        }

        .image-card {
            background: rgba(0, 0, 0, 0.4);
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid rgba(71, 85, 105, 0.5);
            transition: all 0.2s;
            position: relative;
        }

        .image-preview {
            width: 100%;
            height: 90px;
            object-fit: cover;
        }

        .remove-img-btn {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 22px;
            height: 22px;
            background: rgba(239, 68, 68, 0.9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            opacity: 0;
        }

        .image-card:hover .remove-img-btn {
            opacity: 1;
        }

        .image-info {
            padding: 6px;
        }

        .image-name {
            font-size: 9px;
            font-weight: 500;
            color: #e2e8f0;
            margin-bottom: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .size-info {
            display: flex;
            justify-content: space-between;
            font-size: 8px;
            margin-bottom: 3px;
        }

        .reduction-badge {
            display: inline-block;
            background: rgba(16, 185, 129, 0.2);
            color: #10b981;
            padding: 1px 5px;
            border-radius: 6px;
            font-size: 8px;
            font-weight: 600;
            margin-top: 2px;
        }

        /* Upload Area */
        .upload-area {
            background: rgba(129, 140, 248, 0.05);
            border: 2px dashed rgba(129, 140, 248, 0.3);
            border-radius: 18px;
            padding: 12px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }

        .upload-icon {
            width: 45px;
            height: 45px;
            margin: 0 auto 6px;
            background: rgba(129, 140, 248, 0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .upload-icon svg {
            width: 25px;
            height: 25px;
        }

        .upload-area h3 {
            font-size: 15px;
            margin-bottom: 3px;
            color: #f1f5f9;
        }

        .upload-area p {
            color: #94a3b8;
            font-size: 10px;
        }

        /* Add More Button (previous style) */
        .add-more-btn {
            width: 100%;
            padding: 8px;
            background: rgba(129, 140, 248, 0.1);
            border: 1px solid rgba(129, 140, 248, 0.3);
            border-radius: 40px;
            color: #a5b4fc;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.2s;
        }

        .add-more-btn:hover {
            background: rgba(129, 140, 248, 0.2);
            transform: translateY(-1px);
            border-color: #818cf8;
        }

        /* Quality Section */
        .quality-section {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 18px;
            padding: 10px;
        }

        .quality-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 6px;
        }

        .quality-header label {
            font-size: 12px;
            font-weight: 500;
            color: #cbd5e1;
        }

        .quality-value {
            background: rgba(129, 140, 248, 0.2);
            padding: 2px 10px;
            border-radius: 40px;
            font-size: 11px;
            font-weight: 600;
            color: #a5b4fc;
        }

        input[type="range"] {
            width: 100%;
            height: 4px;
            -webkit-appearance: none;
            appearance: none;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 10px;
        }

        input[type="range"]::-webkit-slider-thumb {
            width: 14px;
            height: 14px;
            background: #818cf8;
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 0 8px #818cf8;
            border: 2px solid white;
        }

        /* Mode Toggle Buttons (previous colors) */
        .mode-toggle {
            display: flex;
            gap: 8px;
        }

        .mode-btn {
            flex: 1;
            padding: 7px;
            border-radius: 40px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            text-align: center;
            transition: all 0.2s;
            background: rgba(51, 65, 85, 0.6);
            border: 1px solid rgba(71, 85, 105, 0.5);
            color: #94a3b8;
        }

        .mode-btn.manual.active {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            color: white;
            border-color: #818cf8;
        }

        .mode-btn.smart.active {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            border-color: #10b981;
        }

        /* Action Buttons – previous gradients */
        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn {
            flex: 1;
            padding: 8px 10px;
            border-radius: 40px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            border: none;
            color: white;
            transition: all 0.2s;
        }

        .btn svg {
            width: 12px;
            height: 12px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
        }

        .btn-success {
            background: linear-gradient(135deg, #10b981, #059669);
            box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
        }

        .btn-success:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
        }

        .btn-danger {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            box-shadow: 0 2px 8px rgba(239, 68, 68, 0.3);
        }

        .btn-danger:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
        }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 30px 15px;
            color: #64748b;
        }

        .empty-state svg {
            width: 40px;
            height: 40px;
            opacity: 0.5;
            margin-bottom: 10px;
        }

        .empty-state p {
            font-size: 11px;
        }

        /* Toast */
        .toast {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%) translateY(80px);
            background: rgba(16, 185, 129, 0.95);
            backdrop-filter: blur(10px);
            color: white;
            padding: 8px 20px;
            border-radius: 40px;
            font-size: 12px;
            font-weight: 500;
            z-index: 1000;
            transition: transform 0.3s;
            pointer-events: none;
        }

        .toast.show {
            transform: translateX(-50%) translateY(0);
        }

        /* Responsive */
        @media (max-width: 900px) {
            .two-columns {
                flex-direction: column;
                height: auto;
            }

            .left-column,
            .right-column {
                min-height: 350px;
            }

            body {
                padding-top: 90px;
            }
        }

        @media (max-width: 700px) {
            .action-buttons {
                flex-wrap: wrap;
            }

            .btn {
                width: 100%;
            }

            .stats-bar {
                flex-direction: column;
                align-items: stretch;
                gap: 8px;
            }
        }
    </style>
</head>

<body>

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

        <div class="main-content">
            <div class="container">

                <!-- Tool Header -->
                <div class="header">
                    <h1>🖼️ Smart Image Compressor</h1>
                    <p>Reduce image size without losing quality</p>
                </div>

                <!-- Stats Bar -->
                <div class="stats-bar">
                    <div class="stats-item">
                        <div class="stats-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2">
                                <rect x="2" y="2" width="20" height="20" rx="2.18" />
                                <circle cx="8.5" cy="8.5" r="2.5" />
                                <path d="M21 15l-5-5-4 4-3-3-5 5" />
                            </svg>
                        </div>
                        <div class="stats-info">
                            <h4>Images</h4>
                            <p id="totalCount">0</p>
                        </div>
                    </div>
                    <div class="stats-item">
                        <div class="stats-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2">
                                <path d="M3 6h18M9 12h6M12 18v-6" />
                            </svg>
                        </div>
                        <div class="stats-info">
                            <h4>Total Size</h4>
                            <p id="totalSize">0 KB</p>
                        </div>
                    </div>
                    <div class="stats-item">
                        <div class="stats-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2">
                                <path
                                    d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.66 0 3-4 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4-3-9s1.34-9 3-9" />
                            </svg>
                        </div>
                        <div class="stats-info">
                            <h4>Saved</h4>
                            <p id="savedSpace">0 KB</p>
                        </div>
                    </div>
                </div>

                <!-- Two Columns -->
                <div class="two-columns">
                    <!-- LEFT COLUMN -->
                    <div class="left-column">
                        <div class="left-header">
                            <h3><span>🖼️</span> Image Preview</h3>
                            <div class="preview-badge">Live Preview</div>
                        </div>
                        <div id="previewGrid" class="preview-grid">
                            <div class="empty-state">
                                <svg viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="1.5">
                                    <rect x="2" y="2" width="20" height="20" rx="2.18" />
                                    <circle cx="8.5" cy="8.5" r="2.5" />
                                    <path d="M21 15l-5-5-4 4-3-3-5 5" />
                                </svg>
                                <p>No images uploaded</p>
                                <p style="font-size:10px; margin-top:3px;">Upload images to see preview</p>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN (buttons with previous colors) -->
                    <div class="right-column">
                        <div class="right-header">
                            <h3><span>⚙️</span> Controls</h3>
                            <div class="preview-badge">Settings</div>
                        </div>

                        <!-- Upload Area -->
                        <div class="upload-area" id="dropArea">
                            <div class="upload-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="1.5">
                                    <path d="M12 16V4M8 8l4-4 4 4" />
                                    <path d="M20 16.5A4.5 4.5 0 0015.5 12H15A7 7 0 105 16.5" />
                                </svg>
                            </div>
                            <h3>Upload Images</h3>
                            <p>Click or drag & drop</p>
                            <p style="font-size:9px; margin-top:3px;">PNG, JPG, WEBP (max 10MB)</p>
                            <input type="file" id="fileInput" accept="image/*" multiple style="display:none;">
                        </div>

                        <!-- Add More Button -->
                        <div class="add-more-btn" id="addMoreBtn">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M12 5v14M5 12h14" />
                            </svg>
                            Add More Images
                        </div>

                        <!-- Quality Section -->
                        <div class="quality-section">
                            <div class="quality-header">
                                <label>Compression Quality</label>
                                <span class="quality-value" id="qPercent">50%</span>
                            </div>
                            <input type="range" id="quality" min="0.1" max="1" step="0.05" value="0.5">
                        </div>

                        <!-- Mode Toggle (colors reverted) -->
                        <div class="mode-toggle">
                            <div class="mode-btn manual active" id="manualModeBtn">🎛️ Manual</div>
                            <div class="mode-btn smart" id="smartModeBtn">🤖 Smart</div>
                        </div>

                        <!-- Action Buttons (previous gradients) -->
                        <div class="action-buttons">
                            <button class="btn btn-primary" id="compressBtn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M6 3v12M18 9v12M6 21h12M3 6h12" />
                                </svg>
                                Compress
                            </button>
                            <button class="btn btn-success" id="downloadBtn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" />
                                </svg>
                                Download
                            </button>
                            <button class="btn btn-danger" id="clearBtn">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path
                                        d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                </svg>
                                Clear
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- FOOTER (EJS include) – unchanged -->
        <%- include("common/footer.ejs") %>

            <!-- JavaScript (unchanged) -->
            <script>
                const fileInput = document.getElementById("fileInput");
                const dropArea = document.getElementById("dropArea");
                const addMoreBtn = document.getElementById("addMoreBtn");
                const previewGrid = document.getElementById("previewGrid");
                const qualitySlider = document.getElementById("quality");
                const qPercent = document.getElementById("qPercent");

                let images = [];
                let imageFiles = [];
                let compressedImages = [];
                let currentMode = "manual";
                let totalOriginalSize = 0;
                let totalCompressedSize = 0;

                qualitySlider.addEventListener("input", function () {
                    const percent = Math.round(qualitySlider.value * 100);
                    qPercent.innerText = percent + "%";
                });

                function setMode(mode) {
                    currentMode = mode;
                    const manualBtn = document.getElementById("manualModeBtn");
                    const smartBtn = document.getElementById("smartModeBtn");
                    manualBtn.classList.remove("active");
                    smartBtn.classList.remove("active");
                    if (mode === "manual") {
                        manualBtn.classList.add("active");
                        qualitySlider.disabled = false;
                    } else {
                        smartBtn.classList.add("active");
                        qualitySlider.disabled = true;
                        qualitySlider.value = 0.5;
                        qPercent.innerText = "50%";
                    }
                }

                document.getElementById("manualModeBtn").onclick = () => setMode("manual");
                document.getElementById("smartModeBtn").onclick = () => setMode("smart");

                function removeImage(index) {
                    images.splice(index, 1);
                    imageFiles.splice(index, 1);
                    compressedImages.splice(index, 1);
                    renderImages();
                    updateStats();
                    showToast("Image removed", "info");
                }

                function handleFiles(files) {
                    const newFiles = Array.from(files).filter(f => f.type.startsWith("image/"));
                    if (newFiles.length === 0) {
                        showToast("Please select valid image files!", "error");
                        return;
                    }
                    let processed = 0;
                    newFiles.forEach(file => {
                        const reader = new FileReader();
                        reader.onload = (e) => {
                            imageFiles.push(file);
                            images.push(e.target.result);
                            processed++;
                            if (processed === newFiles.length) {
                                renderImages();
                                updateStats();
                                showToast(newFiles.length + " image(s) added!", "success");
                            }
                        };
                        reader.readAsDataURL(file);
                    });
                }

                function getSmartQuality(file) {
                    const sizeMB = file.size / (1024 * 1024);
                    if (sizeMB > 5) return 0.35;
                    if (sizeMB > 3) return 0.5;
                    if (sizeMB > 1) return 0.7;
                    return 0.85;
                }

                function renderImages() {
                    if (images.length === 0) {
                        previewGrid.innerHTML = `<div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="1.5">
                        <rect x="2" y="2" width="20" height="20" rx="2.18"/>
                        <circle cx="8.5" cy="8.5" r="2.5"/>
                        <path d="M21 15l-5-5-4 4-3-3-5 5"/>
                    </svg>
                    <p>No images uploaded</p>
                    <p style="font-size:10px; margin-top:3px;">Upload images to see preview</p>
                </div>`;
                        document.getElementById("totalCount").innerText = "0";
                        document.getElementById("totalSize").innerText = "0 KB";
                        return;
                    }
                    previewGrid.innerHTML = "";
                    totalOriginalSize = 0;
                    for (let i = 0; i < images.length; i++) {
                        const src = images[i];
                        const file = imageFiles[i];
                        const sizeKB = (file.size / 1024).toFixed(2);
                        totalOriginalSize += parseFloat(sizeKB);
                        let fileName = file.name;
                        if (fileName.length > 18) fileName = fileName.substring(0, 15) + "...";
                        const card = document.createElement("div");
                        card.className = "image-card";
                        card.innerHTML = `
                    <img src="${src}" class="image-preview">
                    <div class="remove-img-btn" onclick="removeImage(${i})">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    </div>
                    <div class="image-info">
                        <div class="image-name">${fileName}</div>
                        <div class="size-info">
                            <span class="size-label">Original</span>
                            <span class="size-value">${sizeKB} KB</span>
                        </div>
                        <div class="size-info" id="comp-size-${i}" style="display:none;">
                            <span class="size-label">Compressed</span>
                            <span class="size-value" id="comp-val-${i}">-</span>
                        </div>
                        <div id="reduction-${i}"></div>
                    </div>
                `;
                        previewGrid.appendChild(card);
                    }
                    document.getElementById("totalCount").innerText = images.length;
                    document.getElementById("totalSize").innerText = totalOriginalSize.toFixed(2) + " KB";
                }

                function updateStats() {
                    let saved = totalOriginalSize - totalCompressedSize;
                    if (saved < 0) saved = 0;
                    document.getElementById("savedSpace").innerText = saved.toFixed(2) + " KB";
                }

                async function compressAll() {
                    if (images.length === 0) {
                        showToast("No images to compress!", "error");
                        return;
                    }
                    compressedImages = [];
                    totalCompressedSize = 0;
                    let completed = 0;
                    for (let i = 0; i < images.length; i++) {
                        const img = new Image();
                        img.src = images[i];
                        await new Promise(resolve => {
                            img.onload = () => {
                                const canvas = document.createElement("canvas");
                                const ctx = canvas.getContext("2d");
                                canvas.width = img.width;
                                canvas.height = img.height;
                                ctx.drawImage(img, 0, 0);
                                let q = parseFloat(qualitySlider.value);
                                if (currentMode === "smart") q = getSmartQuality(imageFiles[i]);
                                const compressed = canvas.toDataURL("image/jpeg", q);
                                compressedImages[i] = compressed;
                                const originalKB = imageFiles[i].size / 1024;
                                const compressedKB = (compressed.length * 0.75) / 1024;
                                totalCompressedSize += compressedKB;
                                const reduction = ((originalKB - compressedKB) / originalKB * 100).toFixed(1);
                                const compSizeDiv = document.getElementById(`comp-size-${i}`);
                                const compVal = document.getElementById(`comp-val-${i}`);
                                const reductionDiv = document.getElementById(`reduction-${i}`);
                                if (compSizeDiv) compSizeDiv.style.display = "flex";
                                if (compVal) compVal.innerText = compressedKB.toFixed(2) + " KB";
                                if (reductionDiv) reductionDiv.innerHTML = `<span class="reduction-badge">📉 ${reduction}%</span>`;
                                completed++;
                                if (completed === images.length) {
                                    updateStats();
                                    showToast(`Compressed ${images.length} image(s)!`, "success");
                                }
                                resolve();
                            };
                        });
                    }
                }

                function downloadAll() {
                    let hasCompressed = compressedImages.some(img => img);
                    if (!hasCompressed) {
                        showToast("Please compress images first!", "error");
                        return;
                    }
                    compressedImages.forEach((img, idx) => {
                        if (img) {
                            const a = document.createElement("a");
                            a.href = img;
                            a.download = `compressed-${idx + 1}.jpg`;
                            a.click();
                        }
                    });
                    showToast("Download started!", "success");
                }

                function clearAll() {
                    images = [];
                    imageFiles = [];
                    compressedImages = [];
                    totalOriginalSize = 0;
                    totalCompressedSize = 0;
                    renderImages();
                    showToast("All images cleared", "info");
                }

                function showToast(message, type) {
                    let toast = document.querySelector(".toast");
                    if (!toast) {
                        toast = document.createElement("div");
                        toast.className = "toast";
                        document.body.appendChild(toast);
                    }
                    let color = "rgba(56,189,248,0.95)";
                    if (type === "success") color = "rgba(16,185,129,0.95)";
                    if (type === "error") color = "rgba(239,68,68,0.95)";
                    if (type === "info") color = "rgba(56,189,248,0.95)";
                    toast.style.backgroundColor = color;
                    toast.textContent = message;
                    toast.classList.add("show");
                    setTimeout(() => toast.classList.remove("show"), 2000);
                }

                dropArea.onclick = () => fileInput.click();
                fileInput.onchange = (e) => handleFiles(e.target.files);
                addMoreBtn.onclick = () => fileInput.click();
                dropArea.ondragover = (e) => { e.preventDefault(); dropArea.style.background = "rgba(129,140,248,0.15)"; };
                dropArea.ondragleave = () => { dropArea.style.background = ""; };
                dropArea.ondrop = (e) => { e.preventDefault(); dropArea.style.background = ""; handleFiles(e.dataTransfer.files); };
                document.getElementById("compressBtn").onclick = compressAll;
                document.getElementById("downloadBtn").onclick = downloadAll;
                document.getElementById("clearBtn").onclick = clearAll;
                window.removeImage = removeImage;
                renderImages();
            </script>

</body>

</html>