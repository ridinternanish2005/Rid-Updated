    ];
    let testiIndex = 0;
    function buildServices() { const grid = document.getElementById('servicesGrid'); if(grid) grid.innerHTML = servicesData.map(s => `<div class="service-card"><div class="service-icon">${s.icon}</div><h3>${s.title}</h3><p>${s.desc}</p><span class="service-tag">${s.tag}</span></div>`).join(''); }
