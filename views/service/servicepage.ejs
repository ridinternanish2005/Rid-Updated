<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
  <title> Services </title>
  <!-- Google Fonts + system fallback -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Poppins:wght@300;400;500;600;700;800&family=Rajdhani:wght@500;600;700&family=Exo+2:wght@300;400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" type="image/png" href="/assets/signup.png">
  <link rel="stylesheet" href="/css/common/header.css">
  <link rel="stylesheet" href="/css/common/footer.css">
  <style>
    /* ===== RESET & GLOBAL - RID BHARAT PREMIUM THEME (unchanged) ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary-dark: #051e2f;
      --blue-deep-2: #0a2e44;
      --blue-deep-3: #0e4160;
      --blue-mid-1: #135e82;
      --blue-mid-2: #1a7ca3;
      --blue-light-1: #2a9bc9;
      --blue-glow: #3eb3e0;
      --accent: #ff6b35;
      --accent-glow: #ff8c5a;
      --white: #ffffff;
      --shadow-dark: 0 20px 35px -12px rgba(0, 0, 0, 0.5);
      --shadow-glow: 0 10px 25px -5px rgba(62, 179, 224, 0.3);
      --transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
      --bg-dark: rgba(7, 30, 44, 0.7);
      --bg-medium: rgba(10, 46, 68, 0.55);
      --light-gray: #b8d4e8;
      --gray: #8ba9c2;
    }

    body {
      font-family: 'Inter', 'Poppins', sans-serif;
      background: #f2f2f2;
      color: var(--white);
      overflow-x: hidden;
      line-height: 1.5;
      padding-top: 130px;
    }

    a { text-decoration: none; color: inherit; transition: var(--transition); }
    ul { list-style: none; }
    button { cursor: pointer; border: none; outline: none; transition: var(--transition); }
    img { max-width: 100%; height: auto; display: block; }

    .container {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
      position: relative;
      z-index: 2;
    }

    @media (max-width: 640px) {
      .container { padding: 0 20px; }
    }

    .section-divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--blue-glow), var(--accent), var(--blue-glow), transparent);
      margin: 0 auto 30px;
      border-radius: 2px;
    }

    .section-title {
      text-align: center;
      margin-bottom: 24px;
    }
    .section-title h2 {
      font-size: 36px;
      background: linear-gradient(135deg, #c0e4ff, var(--blue-light-1), var(--blue-glow));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin-bottom: 8px;
      letter-spacing: -0.3px;
    }
    .section-title h2::after {
      content: '';
      display: block;
      width: 60px;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--blue-glow));
      margin: 8px auto 0;
      border-radius: 4px;
    }
    .section-title p {
      max-width: 700px;
      margin: 6px auto 0;
      color: var(--light-gray);
      font-size: 0.95rem;
    }

    @media (max-width: 768px) {
      .section-title h2 { font-size: 28px; }
      .section-title p { font-size: 0.85rem; }
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 26px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      z-index: 1;
    }
    .btn-primary {
      background: linear-gradient(105deg, var(--blue-mid-1), var(--blue-deep-3));
      color: var(--white);
      box-shadow: 0 6px 14px rgba(0,0,0,0.4);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      background: linear-gradient(105deg, var(--blue-mid-2), var(--blue-deep-2));
      box-shadow: 0 10px 18px rgba(0,0,0,0.5), 0 0 0 1px var(--blue-glow);
    }
    .btn-accent {
      background: linear-gradient(105deg, var(--accent), #e05a2a);
      color: var(--white);
      box-shadow: 0 6px 14px rgba(0,0,0,0.4);
    }
    .btn-accent:hover {
      transform: translateY(-2px);
      background: linear-gradient(105deg, #ff8c5a, var(--accent));
      box-shadow: 0 10px 18px rgba(0,0,0,0.5), 0 0 0 1px var(--accent-glow);
    }

    /* Premium Background */
    .premium-bg {
      position: relative;
      overflow: hidden;
      background: radial-gradient(ellipse at 20% 30%, rgba(10, 46, 68, 0.95), rgba(5, 30, 47, 0.98), #020c14);
    }
    .premium-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: 
        linear-gradient(rgba(62, 179, 224, 0.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(62, 179, 224, 0.045) 1px, transparent 1px);
      background-size: 55px 55px;
      animation: rhGridDrift 18s linear infinite;
      z-index: 1;
    }
    .premium-bg::after {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      top: 0;
      left: 0;
      background: 
        radial-gradient(circle at 15% 25%, rgba(62, 179, 224, 0.08) 0%, transparent 55%),
        radial-gradient(circle at 85% 70%, rgba(255, 107, 53, 0.06) 0%, transparent 60%);
      pointer-events: none;
      z-index: 1;
    }
    @keyframes rhGridDrift {
      0% { background-position: 0 0, 0 0; }
      100% { background-position: 55px 55px, -55px 55px; }
    }
    .premium-bg .container { position: relative; z-index: 5; }

    /* Community Background */
    .community-bg {
      width: 100%;
      background-color: var(--primary-dark);
      background-image:
        repeating-linear-gradient(45deg, rgba(62, 179, 224, 0.04) 0, rgba(62, 179, 224, 0.04) 1px, transparent 1px, transparent 40px),
        repeating-linear-gradient(-45deg, rgba(255, 107, 53, 0.03) 0, rgba(255, 107, 53, 0.03) 1px, transparent 1px, transparent 40px);
      background-position: 0 0;
      animation: communityGridDrift 15s linear infinite;
      position: relative;
      overflow: hidden;
    }
    .community-bg::before {
      content: '';
      position: absolute;
      inset: -20%;
      background-image: radial-gradient(rgba(240, 246, 255, 0.1) 1px, transparent 1px);
      background-size: 50px 50px;
      pointer-events: none;
      animation: communityParticleDrift 20s linear infinite;
      z-index: 1;
    }
    .community-bg::after {
      content: '';
      position: absolute;
      width: 150%;
      height: 150%;
      top: -25%;
      left: -25%;
      background:
        radial-gradient(circle at 10% 20%, rgba(62, 179, 224, 0.1) 0%, transparent 45%),
        radial-gradient(circle at 90% 80%, rgba(255, 107, 53, 0.08) 0%, transparent 45%);
      pointer-events: none;
      animation: communityAmbientGlow 8s ease-in-out infinite alternate;
      z-index: 1;
    }
    @keyframes communityGridDrift {
      0% { background-position: 0 0, 0 0; }
      100% { background-position: 40px 40px, -40px 40px; }
    }
    @keyframes communityParticleDrift {
      0% { transform: translateY(0); }
      100% { transform: translateY(-100px); }
    }
    @keyframes communityAmbientGlow {
      0% { transform: scale(1); opacity: 0.6; }
      100% { transform: scale(1.1); opacity: 1; }
    }
    .community-bg .container { position: relative; z-index: 5; }

    /* ===== HERO SECTION (unchanged) ===== */
    .services-hero {
      background: radial-gradient(circle at 30% 20%, #0a2e44, var(--primary-dark), #010e17);
      padding: 50px 0 60px;
      position: relative;
      overflow: hidden;
      margin-top: -49px;
    }
        @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
    .services-hero::before {
      content: '';
      position: absolute;
      inset: -20%;
      background-image: radial-gradient(rgba(240, 246, 255, 0.08) 1px, transparent 1px);
      background-size: 50px 50px;
      pointer-events: none;
      animation: particleDrift 20s linear infinite;
    }
    @keyframes particleDrift { 0% { transform: translateY(0); } 100% { transform: translateY(-100px); } }
    
    .services-hero::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 100%;
      height: 18px;
      background: linear-gradient(105deg, transparent 48%, rgba(62,179,224,0.5) 48.5%, rgba(255,107,53,0.6) 50%, rgba(62,179,224,0.5) 51.5%, transparent 52%);
      transform: skewY(-1.5deg);
      pointer-events: none;
      z-index: 5;
    }
    
    .hero-inner { text-align: center; position: relative; z-index: 2; }
    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,107,53,0.2);
      backdrop-filter: blur(8px);
      padding: 4px 14px;
      border-radius: 40px;
      font-size: 0.75rem;
      font-weight: 500;
      margin-bottom: 16px;
    }
    .hero-tag span { width: 8px; height: 8px; background: var(--accent); border-radius: 50%; animation: pulseDot 1.4s infinite; }
    @keyframes pulseDot { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(0.5);opacity:0.5} }
    
    .services-hero h1 {
      font-size: 2.8rem;
      margin-bottom: 12px;
      background: linear-gradient(125deg, #ffffff, #b8e2ff, #5fc3f0);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      line-height: 1.2;
    }
    .services-hero h1 em { font-style: normal; color: var(--accent); background: none; -webkit-background-clip: unset; background-clip: unset; }
    .services-hero .hero-p { color: #cfe9ff; font-size: 0.95rem; max-width: 580px; margin: 0 auto 20px; opacity: 0.9; }
    .hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 30px; }
    
    .hero-stats {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      background: rgba(5, 30, 47, 0.65);
      backdrop-filter: blur(16px);
      border-radius: 36px;
      padding: 18px 28px;
      border: 1px solid rgba(62,179,224,0.4);
      max-width: 700px;
      margin: 0 auto;
    }
    .hstat { text-align: center; padding: 0 15px; }
    .hstat-num { font-size: 1.5rem; font-weight: 800; background: linear-gradient(135deg, #ffb347, var(--accent)); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .hstat-label { font-size: 0.7rem; color: #eaf4ff; font-weight: 600; margin-top: 4px; letter-spacing: 0.3px; }
    
    @media (max-width: 768px) {
      .services-hero h1 { font-size: 1.8rem; }
      .hero-stats { gap: 10px; padding: 12px 20px; }
      .hstat { padding: 0 8px; }
      .hstat-num { font-size: 1.2rem; }
    }

    /* ===== SECTION NAVIGATION BUTTONS ===== */
    .section-nav {
      background: var(--primary-dark);
      backdrop-filter: blur(10px);
      padding: 12px 10px;
      border-bottom: 1px solid rgba(62,179,224,0.3);
      position: sticky;
      top: 76px;
      z-index: 99;
    }
    .nav-buttons {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px 14px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .nav-btn {
      background: rgba(10, 46, 68, 0.7);
      border: 1.5px solid rgba(62,179,224,0.4);
      color: var(--light-gray);
      font-size: 0.75rem;
      font-weight: 600;
      padding: 8px 16px;
      border-radius: 40px;
      transition: var(--transition);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }
    .nav-btn i { font-size: 0.7rem; color: var(--blue-glow); }
    .nav-btn:hover {
      background: var(--blue-mid-1);
      border-color: var(--blue-glow);
      color: white;
      transform: translateY(-2px);
    }

    /* ===== MAIN SERVICES CARDS (unchanged) ===== */
    .services-main { padding: 60px 0; }
    .service-cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
      margin-top: 20px;
    }
    .service-card {
      background: rgba(10, 46, 68, 0.75);
      backdrop-filter: blur(12px);
      border-radius: 28px;
      padding: 32px 24px;
      border: 1px solid rgba(62,179,224,0.35);
      transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.2);
      text-align: center;
    }
    .service-card:hover {
      transform: translateY(-8px);
      border-color: var(--blue-glow);
      background: rgba(19, 94, 130, 0.92);
      box-shadow: 0 30px 45px -12px rgba(0,0,0,0.6);
    }
    .service-icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(145deg, var(--accent), #e05a2a);
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      margin: 0 auto 20px;
      transition: all 0.35s;
    }
    .service-card:hover .service-icon {
      transform: rotateY(12deg) scale(1.1);
      background: linear-gradient(145deg, var(--blue-glow), var(--blue-mid-2));
    }
    .service-card h3 { font-size: 1.5rem; margin-bottom: 12px; color: #fff; }
    .service-card p { color: #cde3f0; font-size: 0.9rem; line-height: 1.6; margin-bottom: 20px; }
    .service-tag {
      display: inline-block;
      background: rgba(255,107,53,0.25);
      padding: 5px 16px;
      border-radius: 40px;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--accent);
    }
    @media (max-width: 992px) {
      .service-cards-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .service-cards-grid { grid-template-columns: 1fr; }
      .service-card { padding: 24px 20px; }
      .service-card h3 { font-size: 1.3rem; }
    }

    /* ===== WHY CHOOSE US (unchanged) ===== */
    .why-section { padding: 60px 0;  background: var(--primary-dark); backdrop-filter: blur(6px); }
    .why-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 25px;
      margin-top: 20px;
    }
    .why-item {
      text-align: center;
      padding: 28px 20px;
      background: rgba(5, 30, 47, 0.7);
      border-radius: 24px;
      border: 1px solid rgba(62,179,224,0.2);
      transition: all 0.3s;
    }
    .why-item:hover { transform: translateY(-5px); border-color: var(--blue-glow); background: rgba(19,94,130,0.8); }
    .why-icon { font-size: 2.2rem; margin-bottom: 15px; }
    .why-item h4 { font-size: 1.1rem; margin-bottom: 8px; }
    .why-item p { font-size: 0.8rem; color: #cde3f0; line-height: 1.6; }
    @media (max-width: 992px) { .why-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .why-grid { grid-template-columns: 1fr; } }

    /* ===== DOMAINS SECTION (unchanged) ===== */
    .domains-section { padding: 60px 0; }
    .domains-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-top: 20px;
    }
    .domain-card {
      background: rgba(10, 46, 68, 0.85);
      backdrop-filter: blur(8px);
      border-radius: 24px;
      padding: 28px 20px;
      text-align: center;
      border: 1px solid rgba(62,179,224,0.3);
      transition: all 0.3s;
      cursor: pointer;
    }
    .domain-card:hover { transform: translateY(-5px); border-color: var(--blue-glow); background: #0a3b55; }
    .domain-icon { font-size: 2.5rem; margin-bottom: 15px; }
    .domain-card h3 { font-size: 1.1rem; margin-bottom: 8px; }
    .domain-card p { font-size: 0.75rem; color: #cde3f0; line-height: 1.6; }
    .domain-count {
      display: inline-block;
      margin-top: 12px;
      background: rgba(255,107,53,0.25);
      color: var(--accent);
      font-size: 0.7rem;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 40px;
    }
    @media (max-width: 992px) { .domains-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .domains-grid { grid-template-columns: 1fr; } }

    /* ===== TESTIMONIALS (unchanged) ===== */
    .testimonials-section { padding: 60px 0;  background: var(--primary-dark); backdrop-filter: blur(6px); }
    .testi-card {
      background: rgba(10, 46, 68, 0.8);
      backdrop-filter: blur(8px);
      border-radius: 28px;
      padding: 40px;
      border: 1px solid rgba(62,179,224,0.3);
      max-width: 800px;
      margin: 0 auto;
      text-align: center;
    }
    .testi-stars { color: #f5b042; margin-bottom: 15px; font-size: 1rem; }
    .testi-text { font-size: 0.95rem; line-height: 1.7; color: #cde3f0; margin-bottom: 20px; font-style: italic; }
    .testi-author { display: flex; align-items: center; justify-content: center; gap: 12px; }
    .testi-avatar {
      width: 50px;
      height: 50px;
      background: linear-gradient(135deg, var(--blue-mid-2), var(--blue-deep-2));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.1rem;
    }
    .testi-name { font-weight: 700; }
    .testi-role { font-size: 0.7rem; color: var(--accent); }

    /* ===== PORTFOLIO / CASES (unchanged) ===== */
    .cases-section { padding: 60px 0; }
    .cases-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
      margin-top: 20px;
    }
    .case-card {
      background: rgba(10, 46, 68, 0.75);
      backdrop-filter: blur(8px);
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid rgba(62,179,224,0.3);
      transition: all 0.3s;
    }
    .case-card:hover { transform: translateY(-5px); border-color: var(--blue-glow); }
    .case-thumb {
      height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      background: linear-gradient(135deg, #0a2e44, #051e2f);
    }
    .case-body { padding: 20px; }
    .case-type {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--accent);
      margin-bottom: 8px;
    }
    .case-title { font-size: 1rem; font-weight: 700; margin-bottom: 8px; }
    .case-desc { font-size: 0.75rem; color: #cde3f0; line-height: 1.6; margin-bottom: 12px; }
    .case-metrics { display: flex; gap: 8px; flex-wrap: wrap; }
    .cmetric {
      font-size: 0.65rem;
      background: rgba(62,179,224,0.2);
      padding: 3px 10px;
      border-radius: 40px;
    }
    @media (max-width: 992px) { .cases-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .cases-grid { grid-template-columns: 1fr; } }

    /* ===== CTA SECTION (unchanged) ===== */
    .cta-section {
      padding: 60px 0;
      background: linear-gradient(135deg, #0a2e44, var(--primary-dark));
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-section::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 50%, rgba(62,179,224,0.1), transparent 70%);
      pointer-events: none;
    }
    .cta-section h2 { font-size: 2rem; margin-bottom: 15px; }
    .cta-section p { color: #cde3f0; margin-bottom: 25px; max-width: 600px; margin-left: auto; margin-right: auto; }
    .cta-buttons { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }

    /* ===== GROW SECTION (unchanged) ===== */
    .grow-section { padding: 60px 0;  background: var(--primary-dark); backdrop-filter: blur(6px); }
    .grow-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 50px;
      align-items: center;
    }
    .grow-text p { color: #cde3f0; line-height: 1.7; margin-bottom: 15px; }
    .grow-nums {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
      margin-top: 25px;
    }
    .gnum {
      background: rgba(5, 30, 47, 0.7);
      border-radius: 16px;
      padding: 18px;
      border-left: 3px solid var(--accent);
    }
    .gnum-val { font-size: 1.6rem; font-weight: 800; color: var(--accent); }
    .gnum-label { font-size: 0.7rem; color: #cde3f0; margin-top: 4px; }
    .grow-visual {
      background: linear-gradient(135deg, #0a2e44, #051e2f);
      border-radius: 24px;
      padding: 30px;
      border: 1px solid rgba(62,179,224,0.3);
    }
    .gv-chips { display: flex; flex-direction: column; gap: 12px; }
    .gv-chip {
      background: rgba(62,179,224,0.1);
