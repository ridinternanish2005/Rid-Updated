    buildServices(); buildWhy(); buildDomains(); buildTestimonials(); buildCases(); setInterval(rotateTestimonial, 5000);
    
    // ========== FOUNDER CAROUSEL (AUTO-SCROLL) ==========
  const founders = [
  {
    name: "Er. Sunil Kumar",
    company: "CEO, RRID Tech Pvt. Ltd.",
    quote: "At RRID Tech Pvt. Ltd., we are committed to delivering high-quality, scalable, and innovative digital solutions that empower businesses to grow and succeed in a competitive market.",
    avatar: "SK",
    stars: 5
  },
  {
    name: "Er.Rahul Patle",
    company: "CTO, AgroTech India",
    quote: "The mobile application exceeded our expectations with features like offline functionality, multilingual support, and real-time weather updates. RID Tech is truly a team of experts.",
    avatar: "RP",
    stars: 5
  }
];
    let currentFounderIdx = 0;
    let carouselInterval;

    function renderCarousel(index) {
      const f = founders[index];
      document.getElementById('carouselQuote').innerText = `“${f.quote}”`;
      document.getElementById('founderName').innerText = f.name;
      document.getElementById('founderCompany').innerText = f.company;
      document.getElementById('founderAvatar').innerText = f.avatar;
      const starHtml = '★'.repeat(f.stars) + '☆'.repeat(5-f.stars);
      document.getElementById('carouselStars').innerHTML = starHtml;
      const dots = document.querySelectorAll('.dot');
      dots.forEach((dot, i) => { if(i === index) dot.classList.add('active'); else dot.classList.remove('active'); });
    }

    function buildDots() {
      const dotsContainer = document.getElementById('carouselDots');
      dotsContainer.innerHTML = '';
      founders.forEach((_, idx) => {
        const dot = document.createElement('div');
        dot.classList.add('dot');
        if(idx === currentFounderIdx) dot.classList.add('active');
        dot.addEventListener('click', () => { stopCarousel(); currentFounderIdx = idx; renderCarousel(currentFounderIdx); startCarousel(); });
        dotsContainer.appendChild(dot);
      });
    }

    function nextFounder() { currentFounderIdx = (currentFounderIdx + 1) % founders.length; renderCarousel(currentFounderIdx); }
    function prevFounder() { currentFounderIdx = (currentFounderIdx - 1 + founders.length) % founders.length; renderCarousel(currentFounderIdx); }
    function startCarousel() { if(carouselInterval) clearInterval(carouselInterval); carouselInterval = setInterval(() => { nextFounder(); }, 4500); }
    function stopCarousel() { if(carouselInterval) clearInterval(carouselInterval); }

    document.getElementById('prevBtn').addEventListener('click', () => { stopCarousel(); prevFounder(); startCarousel(); });
    document.getElementById('nextBtn').addEventListener('click', () => { stopCarousel(); nextFounder(); startCarousel(); });
    const carouselEl = document.getElementById('founderCarousel');
    carouselEl.addEventListener('mouseenter', stopCarousel);
    carouselEl.addEventListener('mouseleave', startCarousel);

    // Modal functions
    function openPhotoModal() {
      const modal = document.getElementById('photoMatchModal');
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
      renderCarousel(currentFounderIdx);
      buildDots();
      startCarousel();
    }
    function closePhotoModal() {
      const modal = document.getElementById('photoMatchModal');
      modal.classList.remove('open');
      document.body.style.overflow = '';
      stopCarousel();
    }
    function submitPhotoModalForm() {
      const firstName = document.getElementById('modalFirstName').value.trim();
      const lastName = document.getElementById('modalLastName').value.trim();
      const email = document.getElementById('modalEmail').value.trim();
      const company = document.getElementById('modalCompany').value.trim();
      if(!firstName || !lastName || !email || !company) { alert("Please fill all required fields (*)"); return; }
      document.getElementById('modalFormContainer').style.display = 'none';
      document.getElementById('modalFormSuccess').style.display = 'block';
      setTimeout(() => { closePhotoModal(); setTimeout(() => location.reload(), 400); }, 2000);
    }
    
    const backBtn = document.getElementById('backToTop');
    window.addEventListener('scroll', () => { if(window.scrollY>300) backBtn.classList.add('show'); else backBtn.classList.remove('show'); });
    backBtn.addEventListener('click', () => window.scrollTo({top:0, behavior:'smooth'}));
    
    setTimeout(() => { openPhotoModal(); }, 30000);
    
   
    const loginBtn = document.getElementById("logInButton"); const registerBtn = document.getElementById("signUpBtn"); const swapBtn = document.getElementById("swap-btn");
    if (loginBtn && registerBtn && swapBtn) { loginBtn.addEventListener("click", () => { swapBtn.style.left = "0%"; loginBtn.style.color = "white"; registerBtn.style.color = "#000"; }); registerBtn.addEventListener("click", () => { swapBtn.style.left = "50%"; registerBtn.style.color = "white"; loginBtn.style.color = "#000"; }); }

