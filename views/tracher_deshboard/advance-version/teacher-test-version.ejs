    <style>
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, .5);
            z-index: 99999;

            overflow-y: auto;
            /* scroll yahan hoga */
        }

        .modal-box {
            background: #fff;
            width: 90%;
            max-width: 500px;

            margin: 30px auto;
            /* center */
            padding: 20px;
            border-radius: 10px;
        }

        /* Optional: Better scrollbar */
        .modal-box::-webkit-scrollbar {
            width: 6px;
        }

        .modal-box::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 10px;
        }
    </style>
</head>

<body>
