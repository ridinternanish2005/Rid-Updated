/* qr code css */
/* === QR Modal Styles - Beautiful & Fully Responsive === */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

#qrModal {
  /* flex centering – to be activated by JS (set display: flex) */
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px); /* smooth glass effect */
  z-index: 9999;
  align-items: center;
  justify-content: center;
  padding: 16px;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* Modal card */
#qrModal > div {
  background: white;
  padding: 28px 24px;
  border-radius: 28px;
  width: 360px;
  max-width: 100%;
  text-align: center;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  animation: modalPop 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.3);
  transition: transform 0.2s;
}

@keyframes modalPop {
  0% { opacity: 0.8; transform: scale(0.96); }
  100% { opacity: 1; transform: scale(1); }
}

/* Heading */
#qrModal h3 {
  font-size: 1.6rem;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12px;
  letter-spacing: -0.5px;
  background: linear-gradient(145deg, #0f172a, #334155);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* QR Canvas */
#qrCanvas {
  display: block;
  margin: 8px auto 12px;
  max-width: 100%;
  height: auto;
  border-radius: 16px;
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
  background: #fafafa;
  padding: 8px;
}

/* Read-only test link input */
#testLink {
  width: 100%;
  margin-top: 12px;
  padding: 12px 16px;
  border: 1.5px solid #e2e8f0;
  border-radius: 40px;
  font-size: 0.95rem;
  color: #1e293b;
  background: #f8fafc;
  box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
  transition: border 0.2s, box-shadow 0.2s;
  outline: none;
  font-weight: 500;
  letter-spacing: 0.3px;
}

#testLink:hover,
#testLink:focus {
  border-color: #94a3b8;
  box-shadow: inset 0 2px 6px rgba(0,0,0,0.04);
}

/* Button container */
#qrModal div div {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  margin-top: 24px;
}

/* General button style */
#qrModal button {
  flex: 1 1 110px;  /* allows wrap on small screens */
  padding: 10px 16px;
  border: none;
  border-radius: 40px;
  font-size: 0.95rem;
  font-weight: 600;
  color: white;
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  border: 1px solid rgba(255,255,255,0.2);
  letter-spacing: 0.3px;
}

/* Individual button colors */
#copyBtn {
  background: linear-gradient(145deg, #3b82f6, #1d4ed8);
}
#downloadBtn {
  background: linear-gradient(145deg, #10b981, #059669);
}
#whatsappBtn {
  background: linear-gradient(145deg, #25D366, #1da85c);
}
#closeQrBtn {
  background: linear-gradient(145deg, #64748b, #475569);
}

/* Hover effects */
#qrModal button:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  filter: brightness(1.05);
}
#qrModal button:active {
  transform: translateY(0);
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}

/* Focus for accessibility */
#qrModal button:focus-visible {
  outline: 3px solid rgba(59, 130, 246, 0.5);
  outline-offset: 2px;
}

/* === Responsive fine-tuning === */
@media (max-width: 480px) {
  #qrModal > div {
    padding: 24px 18px;
    border-radius: 24px;
  }
  
  #qrModal h3 {
    font-size: 1.4rem;
  }
  
  #qrModal button {
    flex: 1 1 100%; /* stack buttons on very small screens */
    padding: 12px 16px;
  }
  
  #testLink {
    font-size: 0.85rem;
    padding: 10px 14px;
  }
}

/* Optional: small screen landscape */
@media (max-width: 380px) {
  #qrModal > div {
    padding: 20px 14px;
  }
}
