            <div style="margin-top:15px; display:flex; gap:8px; flex-wrap:wrap; justify-content:center;">
                <button id="copyBtn">Copy</button>
                <button id="downloadBtn">Download</button>
                <button id="whatsappBtn">Send</button>
                <button id="closeQrBtn">Close</button>
            </div>

        </div>
    </div>
    <!-- AI Ask Floating Button -->
    <div id="aiAskBtn">
        <i class="fas fa-robot"></i>
    </div>

    <!-- AI Ask Chat Box -->
    <div id="aiAskBox">
        <div class="ai-header">
            <span>AI Ask</span>
            <button id="closeAiAsk">×</button>
        </div>
        <div class="ai-messages" id="aiMessages">
            <div class="ai-msg">Hello! Test se related kuch bhi pucho.</div>
        </div>
        <div class="ai-input">
            <input type="text" id="aiInput" placeholder="Apna sawal likho...">
            <button id="aiSend">Send</button>
        </div>
    </div>

    <!-- MODAL -->
    <div id="requestModal" class="modal-overlay" style="display:none;">
        <div class="modal-box">
            <span class="close-btn" onclick="closeRequestModal()">&times;</span>
            <h3>Send Request For Create Test</h3>

            <label>Test Name</label>
            <input type="text" id="testName" placeholder="Test name">

            <label>Subject</label>
            <input type="text" id="subject" placeholder="Math, Science, English...">

            <label>Upload Banner (Optional)</label>
            <input type="file" id="banner" accept=".jpg,.jpeg,.png,.webp"><br><br>

            <label>Upload Notes (PDF)</label>
            <input type="file" id="notes" accept=".pdf,.doc,.docx"><br><br>

            <textarea id="description" placeholder="Description"></textarea><br><br>

            <button onclick="submitRequest()">Send</button>
        </div>
    </div>

    <div id="viewStudentModal" class="student-modal">

        <div class="student-modal-box">

            <div class="modal-header">
                <h3><i class="fas fa-user"></i> Student Details</h3>
                <span class="close-icon" onclick="closeViewStudent()">&times;</span>
            </div>

            <div id="studentDetails" class="modal-body"></div>

            <div class="modal-footer">
                <button onclick="closeViewStudent()" class="close-btn">Close</button>
            </div>

        </div>

    </div>

    <!-- Invite Student Modal -->
    <div id="inviteModal" class="invite-modal" style="display:none;">
        <div class="invite-modal-content">
            <div class="invite-modal-header">
                <div>
                    <h2>Invite Students</h2>
                    <p>Share this registration link with your students</p>
                </div>

                <button type="button" class="invite-close-btn" onclick="closeInviteModal()">
                    &times;
                </button>
            </div>

            <div class="invite-modal-body">
                <label for="inviteLink">Invite Link</label>
                <div class="invite-link-box">
                    <input type="text" id="inviteLink" readonly class="invite-link-input">
                    <button type="button" class="invite-copy-btn" onclick="copyInviteLink()">
                        Copy
                    </button>
                </div>

                <div class="invite-actions">
                    <button type="button" class="btn btn-primary invite-action-btn" onclick="copyInviteLink()">
                        Copy Link
                    </button>

                    <button type="button" class="btn btn-success invite-action-btn" onclick="shareInviteLink()">
                        Share
                    </button>
                </div>

                <div class="invite-note">
                    Students can open this link and submit their details directly.
                </div>
            </div>
        </div>
    </div>
    <script src="js/teacher-advance-version/desbord.js"> </script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode/1.5.3/qrcode.min.js"></script>
</body>

</html>