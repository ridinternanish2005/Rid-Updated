<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
  <title>About Us</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Poppins:wght@300;400;500;600;700;800&family=Rajdhani:wght@500;600;700&family=Exo+2:wght@300;400;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/common/header.css">
  <link rel="stylesheet" href="/css/common/footer.css">
  <style>
    /* ===== RESET & GLOBAL - NO CSS ON BODY TAG ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary-dark: #051e2f;
      --blue-deep-2: #0a2e44;
      --blue-deep-3: #0e4160;
      --blue-mid-1: #135e82;
      --blue-mid-2: #1a7ca3;
      --blue-light-1: #2a9bc9;
      --blue-glow: #3eb3e0;
      --accent: #ff6b35;
      --accent-glow: #ff8c5a;
      --white: #ffffff;
      --shadow-dark: 0 20px 35px -12px rgba(0, 0, 0, 0.5);
      --shadow-glow: 0 10px 25px -5px rgba(62, 179, 224, 0.3);
      --transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);

      --frontend: #6c5ce7;
      --backend: #00b894;
      --api: #e17055;
      --ai: #0984e3;

      --bg-dark: rgba(7, 30, 44, 0.7);
      --bg-medium: rgba(10, 46, 68, 0.55);
      --bg-light: rgba(12, 54, 78, 0.45);
      --bg-lighter: rgba(14, 62, 88, 0.4);
      --bg-soft: rgba(16, 70, 98, 0.35);
    }

    /* Body styling removed - no CSS on body element */
@media (max-width: 768px) {
            .menu {
                position: fixed;
                top: 77px;
                left: 0;
                width: 100%;
                height: calc(100vh - 90px);
                background: rgba(255, 255, 255, 0.98);
                backdrop-filter: blur(15px);
                flex-direction: column;
                align-items: flex-start;
                justify-content: flex-start;
                display: none;
                padding: 30px 20px 20px;
                overflow-y: auto;
                z-index: 999;
                transform: translateX(-100%);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            }
        }
    a {
      text-decoration: none;
      color: inherit;
      transition: var(--transition);
    }

    ul {
      list-style: none;
    }

    button {
      cursor: pointer;
      border: none;
      outline: none;
      transition: var(--transition);
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    /* Main wrapper to apply background without touching body */
    .page-wrapper {
      font-family: 'Inter', 'Poppins', sans-serif;
      background: var(--primary-dark);
      color: var(--white);
      overflow-x: hidden;
      line-height: 1.5;
    }

    .container {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
      position: relative;
      z-index: 2;
    }

    @media (max-width: 640px) {
      .container {
        padding: 0 20px;
      }
    }

    .section-divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--blue-glow), var(--accent), var(--blue-glow), transparent);
      margin: 0 auto 30px;
      border-radius: 2px;
    }

    .section-title {
      text-align: center;
      margin-bottom: 24px;
    }

    .section-title h2 {
      font-size: 36px;
      background: linear-gradient(135deg, #c0e4ff, var(--blue-light-1), var(--blue-glow));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin-bottom: 8px;
      letter-spacing: -0.3px;
      position: relative;
    }

    .section-title h2::after {
      content: '';
      display: block;
      width: 60px;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--blue-glow));
      margin: 8px auto 0;
      border-radius: 4px;
    }

    .section-title p {
      max-width: 700px;
      margin: 6px auto 0;
      color: #b8d4e8;
      font-size: 0.95rem;
    }

    @media (max-width: 768px) {
      .section-title h2 {
        font-size: 28px;
      }

      .section-title p {
        font-size: 0.85rem;
      }
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 26px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      z-index: 1;
    }

    .btn-primary {
      background: linear-gradient(105deg, var(--blue-mid-1), var(--blue-deep-3));
      color: var(--white);
      box-shadow: 0 6px 14px rgba(0, 0, 0, 0.4);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      background: linear-gradient(105deg, var(--blue-mid-2), var(--blue-deep-2));
      box-shadow: 0 10px 18px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--blue-glow);
    }

    /* Hero Section */
    .about-hero {
      background: radial-gradient(circle at 30% 20%, #0a2e44, var(--primary-dark), #010e17);
      padding: 40px 0 50px;
      position: relative;
      overflow: hidden;
      min-height: auto;

    }

    .about-hero::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 100%;
      height: 18px;
      background: linear-gradient(105deg,
          transparent 48%,
          rgba(62, 179, 224, 0.5) 48.5%,
          rgba(255, 107, 53, 0.6) 50%,
          rgba(62, 179, 224, 0.5) 51.5%,
          transparent 52%);
      transform: skewY(-1.5deg);
      pointer-events: none;
      z-index: 5;
    }

    .about-hero .tilted-border-glow {
      position: absolute;
      bottom: -1px;
      left: -10%;
      width: 120%;
      height: 25px;
      background: linear-gradient(90deg,
          transparent,
          rgba(62, 179, 224, 0.3),
          rgba(255, 107, 53, 0.4),
          rgba(62, 179, 224, 0.3),
          transparent);
      transform: skewY(-2deg) rotate(0.5deg);
      filter: blur(3px);
      pointer-events: none;
      z-index: 4;
    }

    .about-hero::before {
      content: '';
      position: absolute;
      inset: -20%;
      background-image: radial-gradient(rgba(240, 246, 255, 0.08) 1px, transparent 1px);
      background-size: 50px 50px;
      pointer-events: none;
      animation: particleDrift 20s linear infinite;
    }

    @keyframes particleDrift {
      0% {
        transform: translateY(0);
      }

      100% {
        transform: translateY(-100px);
      }
    }

    .hero-flex-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      flex-wrap: wrap;
      position: relative;
      z-index: 2;
    }

    .hero-left {
      flex: 1.2;
      animation: fadeSlideUp 0.6s ease both;
    }

    .hero-badge {
      display: inline-block;
      background: rgba(255, 107, 53, 0.2);
      backdrop-filter: blur(8px);
      padding: 4px 14px;
      border-radius: 40px;
      font-size: 0.75rem;
      font-weight: 500;
      margin-bottom: 16px;
    }

    .hero-left h1 {
      font-size: 2.5rem;
      margin-bottom: 12px;
      background: linear-gradient(125deg, #ffffff, #b8e2ff, #5fc3f0);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      line-height: 1.2;
    }

    .hero-left p {
      max-width: 580px;
      font-size: 0.95rem;
      opacity: 0.9;
      color: #cfe9ff;
      margin-bottom: 20px;
    }

    .hero-stats-two-lines {
      flex: 0.8;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px 25px;
      background: rgba(5, 30, 47, 0.65);
      backdrop-filter: blur(16px);
      border-radius: 36px;
      padding: 22px 28px;
      border: 1px solid rgba(62, 179, 224, 0.4);
      box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.4);
      transition: transform 0.3s, border-color 0.3s;
      animation: fadeSlideUp 0.6s 0.1s ease both;
    }

    .hero-stats-two-lines:hover {
      transform: translateY(-5px);
      border-color: var(--blue-glow);
      background: rgba(10, 46, 68, 0.85);
    }

    .hero-stat-item {
      text-align: center;
      padding: 6px 10px;
      border-radius: 24px;
      transition: all 0.3s;
    }

    .hero-stat-number {
      font-size: 2.2rem;
      font-weight: 800;
      background: linear-gradient(135deg, #ffb347, var(--accent));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      line-height: 1.2;
      margin-bottom: 4px;
      letter-spacing: -0.5px;
    }

    .hero-stat-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: #eaf4ff;
      letter-spacing: 0.3px;
    }

    @keyframes fadeSlideUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 992px) {
      .hero-flex-container {
        flex-direction: column;
        text-align: center;
      }

      .hero-left {
        text-align: center;
      }

      .hero-left h1 {
        font-size: 2rem;
      }

      .hero-stats-two-lines {
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
      }
    }

    @media (max-width: 600px) {
      .hero-left h1 {
        font-size: 1.6rem;
      }

      .hero-stats-two-lines {
        gap: 12px;
        padding: 18px;
      }

      .hero-stat-number {
        font-size: 1.5rem;
      }

      .hero-stat-label {
        font-size: 0.65rem;
      }
    }

    /* Canvas Section */
    .canvas-effect-section {
      position: relative;
      background: linear-gradient(135deg, #051e2f, #0a2e44);
      overflow: hidden;
      padding: 50px 0;
    }

    #canvas-bg-effect {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      display: block;
    }

    .canvas-section-content {
      position: relative;
      z-index: 2;
    }

    .obj-card-3d {
      flex: 0 0 340px;
      background: rgba(10, 46, 68, 0.75);
      backdrop-filter: blur(12px);
      border-radius: 32px;
      padding: 28px 24px;
      border: 1px solid rgba(62, 179, 224, 0.35);
      transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.2);
      box-shadow: 0 15px 25px -10px rgba(0, 0, 0, 0.4);
      position: relative;
      cursor: pointer;
    }

    .obj-card-3d::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(62, 179, 224, 0.15), rgba(255, 107, 53, 0.08));
      border-radius: 32px;
      opacity: 0;
      transition: opacity 0.5s ease;
      pointer-events: none;
    }

    .obj-card-3d:hover {
      transform: translateY(-12px) scale(1.02);
      border-color: var(--blue-glow);
      background: rgba(19, 94, 130, 0.92);
      box-shadow: 0 30px 45px -12px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(62, 179, 224, 0.4);
    }

    .obj-card-3d:hover::before {
      opacity: 1;
    }

    .obj-icon-3d {
      width: 60px;
      height: 60px;
      background: linear-gradient(145deg, var(--accent), #e05a2a);
      border-radius: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 30px;
      margin-bottom: 22px;
      transition: all 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.2);
    }

    .obj-card-3d:hover .obj-icon-3d {
      transform: rotateY(12deg) scale(1.1);
      background: linear-gradient(145deg, var(--blue-glow), var(--blue-mid-2));
      box-shadow: 0 12px 25px rgba(62, 179, 224, 0.5);
    }

    .obj-card-3d h3 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 14px;
      color: #ffffff;
    }

    .obj-card-3d p {
      color: #cde3f0;
      font-size: 0.9rem;
      line-height: 1.55;
      margin-bottom: 18px;
    }

    .obj-tag-3d {
      display: inline-block;
      background: rgba(255, 107, 53, 0.25);
      padding: 5px 16px;
      border-radius: 40px;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.5px;
      transition: all 0.3s;
    }

    .cards-3d-scroll {
      display: flex;
      flex-wrap: nowrap;
      gap: 28px;
      overflow-x: auto;
      padding: 20px 6px 30px 6px;
      scrollbar-width: thin;
      scrollbar-color: var(--blue-glow) #0a2e44;
      -webkit-overflow-scrolling: touch;
    }

    .cards-3d-scroll::-webkit-scrollbar {
      height: 6px;
    }

    .cards-3d-scroll::-webkit-scrollbar-track {
      background: #0a2e44;
      border-radius: 10px;
    }

    .cards-3d-scroll::-webkit-scrollbar-thumb {
      background: var(--blue-glow);
      border-radius: 10px;
    }

    .obj-header-3d {
      text-align: center;
      margin-bottom: 35px;
    }

    .obj-header-3d h2 {
      font-size: 2.2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #fff, #2a9bc9, #3eb3e0);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.3px;
    }

    @media (max-width: 768px) {
      .obj-card-3d {
        flex: 0 0 300px;
        padding: 22px 18px;
      }

      .obj-card-3d h3 {
        font-size: 1.3rem;
      }

      .obj-header-3d h2 {
        font-size: 1.6rem;
      }
    }

    @media (max-width: 480px) {
      .obj-card-3d {
        flex: 0 0 270px;
        padding: 18px 16px;
      }

      .obj-card-3d h3 {
        font-size: 1.2rem;
      }
    }

    /* Premium Background */
    .premium-bg-only {
      position: relative;
      overflow: hidden;
      background: radial-gradient(ellipse at 20% 30%, rgba(10, 46, 68, 0.95), rgba(5, 30, 47, 0.98), #020c14);
    }

    .premium-bg-only::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(62, 179, 224, 0.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(62, 179, 224, 0.045) 1px, transparent 1px);
      background-size: 55px 55px;
      animation: rhGridDrift 18s linear infinite;
      z-index: 1;
    }

    .premium-bg-only::after {
      content: '';
      position: absolute;
      width: 100%;
      height: 100%;
      top: 0;
      left: 0;
      background:
        radial-gradient(circle at 15% 25%, rgba(62, 179, 224, 0.08) 0%, transparent 55%),
        radial-gradient(circle at 85% 70%, rgba(255, 107, 53, 0.06) 0%, transparent 60%);
      pointer-events: none;
      z-index: 1;
    }

    @keyframes rhGridDrift {
      0% {
        background-position: 0 0, 0 0;
      }

      100% {
        background-position: 55px 55px, -55px 55px;
      }
    }

    .premium-bg-only .container {
      position: relative;
      z-index: 5;
    }

    /* Community Background */
    .community-bg-style {
      width: 100%;
      background-color: var(--primary-dark);
      background-image:
        repeating-linear-gradient(45deg, rgba(62, 179, 224, 0.04) 0, rgba(62, 179, 224, 0.04) 1px, transparent 1px, transparent 40px),
        repeating-linear-gradient(-45deg, rgba(255, 107, 53, 0.03) 0, rgba(255, 107, 53, 0.03) 1px, transparent 1px, transparent 40px);
      background-position: 0 0;
      animation: communityGridDrift 15s linear infinite;
      position: relative;
      overflow: hidden;
    }

    .community-bg-style::before {
      content: '';
      position: absolute;
      inset: -20%;
      background-image: radial-gradient(rgba(240, 246, 255, 0.1) 1px, transparent 1px);
      background-size: 50px 50px;
      pointer-events: none;
      animation: communityParticleDrift 20s linear infinite;
      z-index: 1;
    }

    .community-bg-style::after {
      content: '';
      position: absolute;
      width: 150%;
      height: 150%;
      top: -25%;
      left: -25%;
      background:
        radial-gradient(circle at 10% 20%, rgba(62, 179, 224, 0.1) 0%, transparent 45%),
        radial-gradient(circle at 90% 80%, rgba(255, 107, 53, 0.08) 0%, transparent 45%);
      pointer-events: none;
      animation: communityAmbientGlow 8s ease-in-out infinite alternate;
      z-index: 1;
    }

    .community-bg-style .container {
      position: relative;
      z-index: 5;
    }

    @keyframes communityGridDrift {
      0% {
        background-position: 0 0, 0 0;
      }

      100% {
        background-position: 40px 40px, -40px 40px;
      }
    }

    @keyframes communityParticleDrift {
      0% {
        transform: translateY(0);
      }

      100% {
        transform: translateY(-100px);
      }
    }

    @keyframes communityAmbientGlow {
      0% {
        transform: scale(1);
        opacity: 0.6;
      }

      100% {
        transform: scale(1.1);
        opacity: 1;
      }
    }

    /* Story Section */
    .story-section {
      padding: 45px 0;
      background: var(--bg-dark);
      backdrop-filter: blur(6px);
    }

    .story-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }

    .story-text h3 {
      font-size: 1.8rem;
      margin-bottom: 14px;
      background: linear-gradient(135deg, #fff, var(--blue-light-1));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .story-text p {
      margin-bottom: 14px;
      color: #cde3f0;
      font-size: 0.95rem;
    }

    .story-stats {
      display: flex;
      gap: 28px;
      margin-top: 20px;
      flex-wrap: wrap;
    }

    .story-stat-number {
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--accent);
    }

    .story-image img {
      border-radius: 28px;
      box-shadow: 0 20px 30px -12px black;
      border: 1px solid rgba(62, 179, 224, 0.4);
      width: 100%;
      transition: transform 0.5s ease;
    }

    @media (max-width: 992px) {
      .story-grid {
        grid-template-columns: 1fr;
        gap: 30px;
        text-align: center;
      }

      .story-stats {
        justify-content: center;
      }

      .story-text h3 {
        font-size: 1.5rem;
      }
    }

    /* Values */
    .values-section {
      padding: 45px 0;
      background: var(--bg-medium);
      backdrop-filter: blur(6px);
    }

    .values-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }

    .value-card {
      background: rgba(10, 46, 68, 0.75);
      backdrop-filter: blur(8px);
      padding: 26px 18px;
      border-radius: 28px;
      text-align: center;
      transition: all 0.3s;
      border: 1px solid rgba(62, 179, 224, 0.3);
    }

    .value-icon {
      width: 55px;
      height: 55px;
      background: linear-gradient(145deg, var(--blue-mid-2), var(--blue-deep-2));
      border-radius: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      font-size: 26px;
    }

    @media (max-width: 768px) {
      .values-grid {
        grid-template-columns: 1fr;
        gap: 20px;
      }
    }

    /* Services */
    .services-modern {
      padding: 45px 0;
    }

    .services-modern .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }

    .service-card-modern {
      background: rgba(5, 30, 47, 0.85);
      backdrop-filter: blur(8px);
      padding: 28px 20px;
      border-radius: 28px;
      text-align: center;
      transition: all 0.3s;
      border: 1px solid rgba(62, 179, 224, 0.25);
    }

    .service-icon-modern {
      width: 65px;
      height: 65px;
      margin: 0 auto 16px;
      background: linear-gradient(135deg, var(--blue-mid-2), #0f5c7c);
      border-radius: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 30px;
    }

    .btn-service {
      display: inline-block;
      margin-top: 12px;
      background: rgba(0, 0, 0, 0.4);
      padding: 6px 18px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.8rem;
      color: var(--blue-light-1);
      border: 1px solid var(--blue-light-1);
    }

    @media (max-width: 992px) {
      .services-modern .services-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .services-modern .services-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Domains Carousel */
    .domains-carousel-section {
      padding: 45px 0;
    }

    .carousel-wrapper {
      position: relative;
      padding: 10px 0;
      overflow: hidden;
    }

    .carousel-container {
      overflow: hidden;
      width: 100%;
    }

    .carousel-track {
      display: flex;
      gap: 24px;
      animation: domainScroll 32s linear infinite;
      width: max-content;
      padding: 8px 0;
