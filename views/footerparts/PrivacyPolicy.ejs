
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
  <title>Privacy Policy – RID Bharat</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="icon" type="image/png" href="/assets/signup.png">
<link rel="stylesheet" href="/css/common/header.css">
  <link rel="stylesheet" href="/css/common/footer.css">
  <style>
   *{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

:root{
    --primary:#083d5d;
    --secondary:#1e88e5;
    --accent:#4da8da;
    --light:#f8fbff;
    --dark:#1f2937;
    --text:#555;
    --white:#fff;
    --shadow:0 10px 30px rgba(0,0,0,.08);
}

body{
    font-family:'Poppins',sans-serif;
    background:#f4f8fc;
    color:var(--dark);
    overflow-x:hidden;
}

/* ===== PRIVACY PAGE ===== */

.pp-page{
    min-height:100vh;
    background:linear-gradient(180deg,#f8fbff 0%,#eef5fc 100%);
}

/* ===== HERO ===== */

.pp-banner{
    background:linear-gradient(135deg,#083d5d,#1e88e5);
    text-align:center;
    padding:90px 20px;
    position:relative;
    overflow:hidden;
}

.pp-banner::before{
    content:"";
    position:absolute;
    width:350px;
    height:350px;
    background:rgba(255,255,255,.08);
    border-radius:50%;
    top:-120px;
    right:-100px;
}

.pp-banner::after{
    content:"";
    position:absolute;
    width:250px;
    height:250px;
    background:rgba(255,255,255,.05);
    border-radius:50%;
    bottom:-100px;
    left:-80px;
}

.pp-banner h1{
    color:#fff;
    font-size:3rem;
    font-weight:700;
    margin-bottom:12px;
    position:relative;
    z-index:2;
}

.pp-banner p{
    color:rgba(255,255,255,.9);
    font-size:1rem;
    position:relative;
    z-index:2;
}

/* ===== CONTENT ===== */

.pp-body{
    max-width:1100px;
    margin:auto;
    padding:50px 20px 80px;
}

/* ===== DATE BAR ===== */

.pp-date-bar{
    background:#fff;
    border-radius:16px;
    padding:18px 22px;
    box-shadow:var(--shadow);
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:30px;
}

.pp-date-bar strong{
    color:var(--primary);
}

/* ===== INTRO ===== */

.pp-intro{
    background:#fff;
    border-radius:20px;
    padding:30px;
    line-height:1.9;
    box-shadow:var(--shadow);
    margin-bottom:30px;
    color:var(--text);
}

/* ===== SECTION CARD ===== */

.pp-section{
    background:#fff;
    border-radius:18px;
    margin-bottom:18px;
    box-shadow:0 5px 20px rgba(0,0,0,.06);
    overflow:hidden;
    transition:.3s;
}

.pp-section:hover{
    transform:translateY(-3px);
}

.pp-section-title{
    display:flex;
    align-items:center;
    gap:14px;
    padding:22px 25px;
    cursor:pointer;
}

.pp-num{
    width:40px;
    height:40px;
    border-radius:50%;
    background:linear-gradient(135deg,#083d5d,#1e88e5);
    color:#fff;
    display:flex;
    justify-content:center;
    align-items:center;
    font-weight:700;
    flex-shrink:0;
}

.pp-section-title h2{
    flex:1;
    font-size:1.05rem;
    color:var(--primary);
    font-weight:600;
}

.pp-arrow{
    color:var(--secondary);
    transition:.3s;
}

.pp-section.open .pp-arrow{
    transform:rotate(180deg);
}

.pp-section-body{
    padding:0 25px 25px;
    display:none;
}

.pp-section.open .pp-section-body{
    display:block;
}

.pp-section-body p{
    color:var(--text);
    line-height:1.9;
    margin-bottom:12px;
}

.pp-section-body h4{
    color:var(--primary);
    margin:18px 0 10px;
    font-size:1rem;
}

.pp-section-body ul{
    margin-top:10px;
}

.pp-section-body li{
    list-style:none;
    padding:8px 0 8px 24px;
    position:relative;
    color:var(--text);
}

.pp-section-body li::before{
    content:"✓";
    position:absolute;
    left:0;
    color:var(--secondary);
    font-weight:700;
}

/* ===== INFO BOX ===== */

.info-box{
    background:#eef7ff;
    border-left:4px solid var(--secondary);
    padding:18px;
    border-radius:12px;
    margin-top:15px;
    color:#1f4d7a;
}

.info-box.green{
    background:#effcf4;
    border-left-color:#16a34a;
}

.info-box.orange{
    background:#fff7ed;
    border-left-color:#ea580c;
}

/* ===== CONTACT ===== */

.contact-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:16px;
    margin-top:20px;
}

.contact-item{
    background:#f8fbff;
    border:1px solid #dbeafe;
    border-radius:14px;
    padding:18px;
    transition:.3s;
}

.contact-item:hover{
    transform:translateY(-4px);
    box-shadow:0 10px 20px rgba(30,136,229,.15);
}

.c-label{
    font-size:.75rem;
    color:#888;
    text-transform:uppercase;
    letter-spacing:1px;
    margin-bottom:6px;
}

.contact-item a{
    color:var(--primary);
    font-weight:600;
}

.contact-item a:hover{
    color:var(--secondary);
}

/* ===== FOOT NOTE ===== */

.pp-footer-note{
    margin-top:25px;
    background:linear-gradient(135deg,#083d5d,#1e88e5);
    color:#fff;
    text-align:center;
    padding:20px;
    border-radius:16px;
    font-weight:500;
}

/* ===== MOBILE ===== */

@media(max-width:768px){

    .pp-banner{
        padding:70px 15px;
    }

    .pp-banner h1{
        font-size:2rem;
    }

    .pp-banner p{
        font-size:.95rem;
    }

    .pp-body{
        padding:25px 15px 50px;
    }

    .pp-intro{
        padding:20px;
    }

    .pp-section-title{
        padding:16px;
    }

    .pp-section-body{
        padding:0 16px 16px;
    }

    .pp-section-title h2{
        font-size:.95rem;
    }

    .pp-date-bar{
        flex-direction:column;
        align-items:flex-start;
    }
}
  </style>
</head>
<body>
 <%- include("common/header.ejs") %>
  <!-- ══════════════ PRIVACY POLICY CONTENT ══════════════ -->
  <div class="pp-page">

    <div class="pp-banner">
      <h1>
        <i class="fa-solid fa-shield-halved" style="color:var(--secondary);margin-right:10px;"></i>
        Privacy Policy
      </h1>
      <p>RIDTECH · Last Updated: March 2026</p>
    </div>

    <div class="pp-body">

      <div class="pp-date-bar">
        <i class="fa-regular fa-calendar" style="color:var(--primary);"></i>
        <span>
          Effective Date: <strong>March 2026</strong> · Last Updated: <strong>March 2026</strong>
        </span>
      </div>

      <div class="pp-intro">
        RIDTECH (“Company”, “we”, “our”, “us”) is committed to protecting your privacy and ensuring transparency in how your personal data is collected, used, and protected. This Privacy Policy applies to all users, clients, and visitors of our website and services.
      </div>

      <!-- 1 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">1</div>
          <h2>Scope of Policy</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <ul>
            <li>Website visitors</li>
            <li>Registered users</li>
            <li>Clients and business partners</li>
            <li>Mobile and web application users</li>
          </ul>
        </div>
      </div>

      <!-- 2 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">2</div>
          <h2>Information We Collect</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">

          <h4>2.1 Personal Information</h4>
          <ul>
            <li>Full Name</li>
            <li>Email Address</li>
            <li>Phone Number</li>
            <li>Company/Organization Name</li>
            <li>Billing and payment details</li>
          </ul>

          <h4>2.2 Technical Information</h4>
          <ul>
            <li>IP Address</li>
            <li>Browser type and version</li>
            <li>Device type and operating system</li>
            <li>Time zone and location data</li>
          </ul>

          <h4>2.3 Usage Data</h4>
          <ul>
            <li>Pages visited</li>
            <li>Time spent on pages</li>
            <li>Clickstream data</li>
            <li>Interaction behavior</li>
          </ul>

          <h4>2.4 Project & Communication Data</h4>
          <ul>
            <li>Messages, emails, and support queries</li>
            <li>Files and content shared with us</li>
            <li>Project-related documents</li>
          </ul>

        </div>
      </div>

      <!-- 3 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">3</div>
          <h2>Legal Basis for Processing</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <ul>
            <li>Consent (when you provide information)</li>
            <li>Contractual obligations (for services/projects)</li>
            <li>Legal compliance</li>
            <li>Legitimate business interests</li>
          </ul>
        </div>
      </div>

      <!-- 4 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">4</div>
          <h2>How We Use Your Data</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <ul>
            <li>Deliver and manage services</li>
            <li>Communicate project updates</li>
            <li>Improve platform performance</li>
            <li>Customize user experience</li>
            <li>Process transactions and invoices</li>
            <li>Prevent fraud and unauthorized activities</li>
            <li>Comply with legal obligations</li>
          </ul>
        </div>
      </div>

      <!-- 5 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">5</div>
          <h2>Data Sharing & Disclosure</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">

          <h4>5.1 Service Providers</h4>
          <ul>
            <li>Hosting providers</li>
            <li>Payment gateways</li>
            <li>Analytics tools</li>
          </ul>

          <h4>5.2 Legal Authorities</h4>
          <p>If required by law, regulation, or legal request</p>

          <h4>5.3 Business Transfers</h4>
          <p>In case of merger, acquisition, or restructuring</p>

          <div class="info-box">
            <strong>We never sell your personal data.</strong>
          </div>

        </div>
      </div>

      <!-- 6 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">6</div>
          <h2>International Data Transfer</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <p>Your data may be processed or stored outside India. We ensure adequate protection through standard security practices.</p>
        </div>
      </div>

      <!-- 7 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">7</div>
          <h2>Data Security</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <ul>
            <li>SSL encryption</li>
            <li>Secure servers</li>
            <li>Access control systems</li>
            <li>Regular security audits</li>
          </ul>
          <p>However, no system is completely secure.</p>
        </div>
      </div>

      <!-- 8 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">8</div>
          <h2>Data Retention</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <ul>
            <li>As long as required for service delivery</li>
            <li>As required by legal obligations</li>
            <li>Until user requests deletion</li>
          </ul>
        </div>
      </div>

      <!-- 9 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">9</div>
          <h2>Your Rights</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <ul>
            <li>Access your data</li>
            <li>Correct inaccurate data</li>
            <li>Request deletion</li>
            <li>Restrict processing</li>
            <li>Withdraw consent</li>
            <li>Request data portability</li>
          </ul>
        </div>
      </div>

      <!-- 10 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">10</div>
          <h2>Cookies & Tracking</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <p>We use cookies for:</p>
          <ul>
            <li>Analytics</li>
            <li>Performance optimization</li>
            <li>User preferences</li>
          </ul>
          <p>Types of cookies:</p>
          <ul>
            <li>Essential cookies</li>
            <li>Analytics cookies</li>
            <li>Functional cookies</li>
          </ul>
        </div>
      </div>

      <!-- 11 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">11</div>
          <h2>Children’s Privacy</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <p>Our services are not intended for users under 13 years of age. We do not knowingly collect data from children.</p>
        </div>
      </div>

      <!-- 12 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">12</div>
          <h2>Third-Party Links</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <p>Our website may include links to external sites. We are not responsible for their privacy practices or content.</p>
        </div>
      </div>

      <!-- 13 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">13</div>
          <h2>Automated Decision-Making</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <p>We do not use fully automated decision-making that significantly affects users.</p>
        </div>
      </div>

      <!-- 14 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">14</div>
          <h2>Data Breach Policy</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <ul>
            <li>Users will be notified promptly</li>
            <li>Legal steps will be taken</li>
            <li>Systems will be secured immediately</li>
          </ul>
        </div>
      </div>

      <!-- 15 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">15</div>
          <h2>Policy Updates</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <p>We may update this Privacy Policy periodically. Changes will be posted on this page with updated date.</p>
        </div>
      </div>

      <!-- 16 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">16</div>
          <h2>Governing Law</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <p>This policy is governed by the laws of India.</p>
        </div>
      </div>

      <!-- 17 -->
      <div class="pp-section open">
        <div class="pp-section-title" onclick="toggleSection(this)">
          <div class="pp-num">17</div>
          <h2>Contact Information</h2>
          <i class="fa-solid fa-chevron-down pp-arrow"></i>
        </div>
        <div class="pp-section-body">
          <div class="contact-grid">
            <div class="contact-item">
              <div class="c-label">Email</div>
              <a href="mailto:support@ridtech.in">support@ridtech.in</a>
            </div>
            <div class="contact-item">
              <div class="c-label">Website</div>
              <a href="https://www.ridtech.in" target="_blank">www.ridtech.in</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
 <%- include("common/footer.ejs") %>
  <script>

    // Login / Register slide
    const loginBtn    = document.getElementById('logInButton');
    const registerBtn = document.getElementById('signUpBtn');
    const swapBtn     = document.getElementById('swap-btn');

    function setLogin() {
      swapBtn.style.left = '0%';
      loginBtn.style.color    = '#fff';
      registerBtn.style.color = '#333';
    }
    function setRegister() {
      swapBtn.style.left = '50%';
      registerBtn.style.color = '#fff';
      loginBtn.style.color    = '#333';
    }

    if (loginBtn && registerBtn && swapBtn) {
      loginBtn.addEventListener('click', setLogin);
      registerBtn.addEventListener('click', setRegister);
      setLogin();
    }

  </script>
</body>
</html>