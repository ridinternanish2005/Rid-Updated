
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
  <title>Contact Us | RID Bharat – Research Innovation Discovery</title>

  <!-- Google Fonts + fallback system fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="icon" type="image/png" href="/assets/signup.png">
<link rel="stylesheet" href="/css/common/header.css">
  <link rel="stylesheet" href="/css/common/footer.css">
  <style>
  /* =========================
   GLOBAL
========================= */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

:root{
    --primary:#083d5d;
    --secondary:#1e88e5;
    --accent:#4da8da;
    --bg:#f4f8fc;
    --white:#ffffff;
    --text:#334155;
    --border:#e2e8f0;
    
}

body{
    font-family:'Poppins',sans-serif;
    background:var(--bg);
    color:var(--text);
    line-height:1.6;
    overflow-x:hidden;
    padding-top:120px; /* fixed header ke liye */
}

/* =========================
   CONTACT PAGE
========================= */

.contact-main-wrapper{
    padding:40px 20px 80px;
    background:linear-gradient(
        180deg,
        #f8fbff 0%,
        #eef5fc 100%
    );
    min-height:70vh;
}

.contact-container{
    max-width:1200px;
    margin:auto;
    background:#fff;
    border-radius:24px;
    overflow:hidden;
    box-shadow:var(--shadow);
}

.contact-inner{
    padding:50px;
}

/* =========================
   HEADER
========================= */

.contact-header{
    text-align:center;
    margin-bottom:45px;
}

.contact-header h1{
    font-size:3rem;
    font-weight:700;
    color:var(--primary);
    margin-bottom:12px;
}

.contact-header p{
    max-width:700px;
    margin:auto;
    color:#64748b;
    line-height:1.8;
}

/* =========================
   GRID
========================= */

.contact-grid{
    display:grid;
    grid-template-columns:1.2fr 1fr;
    gap:35px;
}

/* =========================
   FORM CARD
========================= */

.form-card{
    background:#fff;
    border:1px solid var(--border);
    border-radius:20px;
    padding:30px;
}

.input-group{
    margin-bottom:18px;
}

.input-group label{
    display:block;
    margin-bottom:8px;
    font-weight:600;
    color:var(--primary);
}

.input-group input,
.input-group textarea{
    width:100%;
    padding:14px 16px;
    border:1px solid #dbe4ee;
    border-radius:12px;
    background:#fff;
    font-size:.95rem;
    transition:.3s;
}

.input-group textarea{
    resize:vertical;
    min-height:140px;
}

.input-group input:focus,
.input-group textarea:focus{
    outline:none;
    border-color:var(--secondary);
    box-shadow:0 0 0 4px rgba(30,136,229,.12);
}

.submit-btn{
    width:100%;
    background:linear-gradient(
        135deg,
        var(--primary),
        var(--secondary)
    );
    color:#fff;
    border:none;
    padding:15px;
    border-radius:12px;
    font-size:1rem;
    font-weight:600;
    cursor:pointer;
    transition:.3s;
}

.submit-btn:hover{
    transform:translateY(-2px);
}

/* =========================
   INFO CARD
========================= */

.info-card{
    background:#fff;
    border:1px solid var(--border);
    border-radius:20px;
    padding:30px;
}

.info-title{
    font-size:1.4rem;
    color:var(--primary);
    font-weight:700;
    margin-bottom:25px;
}

.contact-details{
    display:flex;
    flex-direction:column;
    gap:20px;
}

.info-item{
    display:flex;
    gap:15px;
}

.info-icon{
    width:50px;
    height:50px;
    min-width:50px;
    border-radius:50%;
    background:#eaf4ff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:1.2rem;
}

.info-text h4{
    color:var(--primary);
    margin-bottom:4px;
}

.info-text p,
.info-text a{
    color:#64748b;
    text-decoration:none;
}

/* =========================
   MAP
========================= */

.map-placeholder{
    margin-top:25px;
    border-radius:16px;
    overflow:hidden;
    border:1px solid #dbe4ee;
}

.map-container{
    height:240px;
}

.google-map-embed{
    width:100%;
    height:100%;
    border:none;
}

.map-note{
    padding:12px;
    text-align:center;
    background:#f8fbff;
    color:#64748b;
    font-size:.85rem;
}

/* =========================
   TOAST
========================= */

.toast-msg{
    visibility:hidden;
    min-width:260px;
    background:#26648b;
    color:#fff;
    text-align:center;
    border-radius:50px;
    padding:12px 20px;
    position:fixed;
    bottom:20px;
    left:50%;
    transform:translateX(-50%);
    opacity:0;
    transition:.3s;
    z-index:9999;
}

.toast-msg.show{
    visibility:visible;
    opacity:1;
}

/* =========================
   MOBILE
========================= */

@media(max-width:992px){

    .contact-grid{
        grid-template-columns:1fr;
    }

}

@media(max-width:768px){

    body{
        padding-top:90px;
    }

    .contact-main-wrapper{
        padding:20px 12px 40px;
    }

    .contact-inner{
        padding:25px;
    }

    .contact-header h1{
        font-size:2rem;
    }

    .contact-header p{
        font-size:.9rem;
    }

    .form-card,
    .info-card{
        padding:20px;
    }

    .map-container{
        height:180px;
    }
}
  </style>
</head>
<body>
<%- include("common/header.ejs") %>
  <!-- ========== CONTACT SECTION (fully functional) ========== -->
  <div class="contact-main-wrapper">
    <div class="contact-container">
      <div class="contact-inner">
        <div class="contact-header">
          <h1>Contact Us</h1>
          <p>We'd love to hear from you! Whether you have a question, feedback, or an innovative idea, feel free to reach out. Our team will respond shortly.</p>
        </div>
        <div class="contact-grid">
          <div class="form-card">
            <form id="contactForm" action="#" method="post">
              <div class="input-group">
                <label for="fullname">Full Name</label>
                <input type="text" id="fullname" name="fullname" required>
              </div>
              <div class="input-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required>
              </div>
              <div class="input-group">
                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" placeholder="How can we help?" required>
              </div>
              <div class="input-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" placeholder="Write your message here..." required></textarea>
              </div>
              <button type="submit" class="submit-btn">Send Message →</button>
            </form>
          </div>
          <div class="info-card">
            <div class="info-title">Get in touch</div>
            <div class="contact-details">
              <div class="info-item">
                <div class="info-icon">📍</div>
                <div class="info-text">
                  <h4>Visit Us</h4>
                  <p>51 Indrapuri, Sector C. Jubali Gate, Near Croma, Bhel, Bhopal, Huzur, Madhya Pradesh, India, (402022)</p>
                </div>
              </div>
              <div class="info-item">
                <div class="info-icon">✉️</div>
                <div class="info-text">
                  <h4>Email Us</h4>
                  <p><a href="mailto:ridorg.in@gmail.com">ridorg.in@gmail.com</a></p>
                </div>
              </div>
              <div class="info-item">
                <div class="info-icon">📞</div>
                <div class="info-text">
                  <h4>Call Us</h4>
                  <p>+91 9202707903<br> (Sat, 9AM-6PM)</p>
                </div>
              </div>
            </div>
            <div class="map-placeholder">
              <div class="map-container">
                <iframe class="google-map-embed" src="https://maps.google.com/maps?q=51%20Indrapuri,%20Sector%20C.%20Jubali%20Gate,%20Near%20ridtech,%20Bhel,%20Bhopal,%20Huzur,%20Madhya%20Pradesh,%20India&t=&z=12&ie=UTF8&iwloc=&output=embed" title="Google Map" loading="lazy"></iframe>
              </div>
              <div class="map-note">51 Indrapuri, Sector C. Jubali Gate, Near Croma, Bhel, Bhopal, Huzur, Madhya Pradesh, India, (402022)</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="toastMessage" class="toast-msg">✨ Message sent! We'll reply soon.</div>
<%- include("common/footer.ejs") %>
  <script>
    // ========== HEADER / FOOTER INTERACTIONS ==========
  

     
  

    // ========== CONTACT FORM HANDLING ==========
    const form = document.getElementById('contactForm');
    const toast = document.getElementById('toastMessage');

    function showToast(message, isError = false) {
      toast.textContent = message || (isError ? "⚠️ Please fill all fields correctly." : "✨ Message sent! We'll reply soon.");
      if (isError) { toast.style.backgroundColor = "#9e4b3a"; } 
      else { toast.style.backgroundColor = "#26648b"; }
      toast.classList.add('show');
      setTimeout(() => { toast.classList.remove('show'); }, 2800);
    }

    function isValidEmail(email) { return /^[^\s@]+@([^\s@]+\.)+[^\s@]+$/.test(email); }

    if (form) {
      form.addEventListener('submit', function(event) {
        event.preventDefault();
        const fullname = document.getElementById('fullname').value.trim();
        const email = document.getElementById('email').value.trim();
        const subject = document.getElementById('subject').value.trim();
        const message = document.getElementById('message').value.trim();
        
        if (!fullname) { showToast("❌ Please enter your full name.", true); return; }
        if (!email) { showToast("❌ Email address is required.", true); return; }
        if (!isValidEmail(email)) { showToast("📧 Please provide a valid email address.", true); return; }
        if (!subject) { showToast("📌 Subject field cannot be empty.", true); return; }
        if (!message) { showToast("💬 Please write your message before sending.", true); return; }
        
        showToast("✅ Message sent successfully! We'll get back to you within 24h.", false);
        form.reset();
      });
    }
  </script>
</body>
</html>