
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
  <title>RID Bharat – Disclaimer</title>

  <!-- Google Fonts + Font Awesome -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="icon" type="image/png" href="/assets/signup.png">
<link rel="stylesheet" href="/css/common/header.css">
  <link rel="stylesheet" href="/css/common/footer.css">
  <style>
    /* =========================
   GLOBAL
========================= */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

:root{
    --primary:#083d5d;
    --secondary:#1e88e5;
    --accent:#4da8da;
    --bg:#f4f8fc;
    --card:#ffffff;
    --text:#334155;
    --heading:#0f172a;
    --border:#e2e8f0;
    --shadow:0 15px 40px rgba(0,0,0,.08);
}
@media (max-width: 768px) {
            .menu {
                position: fixed;
                top: 77px;
                left: 0;
                width: 100%;
                height: calc(100vh - 90px);
                background: rgba(255, 255, 255, 0.98);
                backdrop-filter: blur(15px);
                flex-direction: column;
                align-items: flex-start;
                justify-content: flex-start;
                display: none;
                padding: 30px 20px 20px;
                overflow-y: auto;
                z-index: 999;
                transform: translateX(-100%);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            }
        }

body{
    font-family:'Inter','Poppins',sans-serif;
    background:var(--bg);
    color:var(--text);
    overflow-x:hidden;
    line-height:1.7;
}

/* =========================
   DISCLAIMER SECTION
========================= */

.disclaimer-section{
    background:linear-gradient(
        180deg,
        #f8fbff 0%,
        #eef5fc 100%
    );
    padding:50px 20px 80px;
    min-height:70vh;
}

.disclaimer-card{
    max-width:1150px;
    margin:auto;
    background:var(--card);
    border-radius:24px;
    overflow:hidden;
    box-shadow:var(--shadow);
    border:1px solid rgba(255,255,255,.5);
}

/* =========================
   HEADER
========================= */

.disclaimer-header{
    background:linear-gradient(
        135deg,
        #083d5d 0%,
        #1e88e5 100%
    );
    color:#fff;
    padding:45px;
    position:relative;
    overflow:hidden;
}

.disclaimer-header::before{
    content:"";
    position:absolute;
    width:300px;
    height:300px;
    border-radius:50%;
    background:rgba(255,255,255,.08);
    top:-120px;
    right:-80px;
}

.disclaimer-header h1{
    font-size:2.4rem;
    font-weight:700;
    display:flex;
    align-items:center;
    gap:12px;
    position:relative;
    z-index:2;
}

.disclaimer-header h1 i{
    color:#ffd166;
}

.disclaimer-header p{
    margin-top:12px;
    font-size:.95rem;
    opacity:.9;
    position:relative;
    z-index:2;
}

/* =========================
   CONTENT
========================= */

.disclaimer-content{
    padding:45px;
}

.disclaimer-content h2{
    color:var(--primary);
    margin:35px 0 15px;
    padding-bottom:10px;
    border-bottom:2px solid #e7eef7;
    font-size:1.25rem;
    font-weight:700;
}

.disclaimer-content h2:first-child{
    margin-top:0;
}

.disclaimer-content p{
    color:#475569;
    line-height:1.9;
    margin-bottom:14px;
    font-size:.98rem;
}

.disclaimer-content ul{
    margin:15px 0 20px 22px;
}

.disclaimer-content li{
    margin-bottom:10px;
    color:#475569;
    line-height:1.8;
}

.disclaimer-content a{
    color:var(--primary);
    font-weight:600;
    text-decoration:none;
    transition:.3s;
}

.disclaimer-content a:hover{
    color:var(--secondary);
}

/* =========================
   SPECIAL BOX
========================= */

.disclaimer-content p:first-child{
    background:#f8fbff;
    border-left:4px solid var(--secondary);
    padding:18px;
    border-radius:12px;
}

/* =========================
   FOOTER NOTE
========================= */

.disclaimer-footer{
    background:#f8fbff;
    border-top:1px solid var(--border);
    padding:22px;
    text-align:center;
    color:#64748b;
    font-size:.9rem;
    font-weight:600;
}

/* =========================
   SCROLLBAR
========================= */

::-webkit-scrollbar{
    width:10px;
}

::-webkit-scrollbar-track{
    background:#e2ecf5;
}

::-webkit-scrollbar-thumb{
    background:linear-gradient(
        180deg,
        #083d5d,
        #1e88e5
    );
    border-radius:20px;
}

::-webkit-scrollbar-thumb:hover{
    background:#1e88e5;
}

/* =========================
   MOBILE
========================= */

@media (max-width:768px){

    .disclaimer-section{
        padding:25px 12px 50px;
    }

    .disclaimer-header{
        padding:28px 22px;
    }

    .disclaimer-header h1{
        font-size:1.7rem;
        flex-wrap:wrap;
    }

    .disclaimer-header p{
        font-size:.85rem;
    }

    .disclaimer-content{
        padding:24px 20px;
    }

    .disclaimer-content h2{
        font-size:1.05rem;
    }

    .disclaimer-content p,
    .disclaimer-content li{
        font-size:.9rem;
    }
}

/* =========================
   LARGE SCREEN
========================= */

@media (min-width:1400px){

    .disclaimer-card{
        max-width:1250px;
    }
}
  </style>
</head>
<body>
<%- include("common/header.ejs") %>
