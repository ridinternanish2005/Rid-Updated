    async function showAllTeacher() {
      try {
        document.getElementById("dashboardContent").style.display = "none";

        document.getElementById("dynamicContent").innerHTML = `
            <div style="padding:30px; text-align:center;">
                <h2>Loading Teachers...</h2>
            </div>
        `;

        // ✅ FIXED URL
        const res = await fetch("/admin/teachers");

        if (!res.ok) {
          throw new Error("Failed to fetch teachers");
        }

        const teachers = await res.json();

        console.log("Teachers Data:", teachers);

        if (!teachers || teachers.length === 0) {
          document.getElementById("dynamicContent").innerHTML = `
                <div class="data-table-container">
                    <h2>No Teachers / Users Found</h2>
                </div>
            `;

          return;
        }

        const content = `
            <div class="data-table-container">

                <div style="
                    display:flex;
                    justify-content:space-between;
                    align-items:center;
                    margin-bottom:15px;
                    flex-wrap:wrap;
                    gap:10px;
                ">

                    <h3>All Teachers & Users</h3>

                    <input
                        type="text"
                        id="teacherSearch"
                        placeholder="Search by name or email..."
                        style="
                            padding:10px 14px;
                            border:1px solid #ccc;
                            border-radius:6px;
                            width:260px;
                        "
                    >
                </div>

                <div style="overflow-x:auto;">

                    <table class="data-table" style="width:100%;">

                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Created</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody id="teacherTableBody">

                            ${teachers
            .map(
              (t) => `

                                <tr>

                                    <td>${t.name || "N/A"}</td>

                                    <td>${t.email || "N/A"}</td>

                                    <td>${t.role || "User"}</td>

                                    <td>
                                        ${t.createdAt
                  ? new Date(
                    t.createdAt,
                  ).toLocaleDateString()
                  : "N/A"
                }
                                    </td>

                                    <td>

                                        <button
                                            onclick="openTeacherTests('${t._id}')"
                                            style="
                                                padding:7px 14px;
                                                background:#0a66c2;
                                                color:white;
                                                border:none;
                                                border-radius:5px;
                                                cursor:pointer;
                                            "
                                        >
                                            Select
                                        </button>

                                    </td>

                                </tr>

                            `,
            )
            .join("")}

                        </tbody>

                    </table>

                </div>

            </div>
        `;

        document.getElementById("dynamicContent").innerHTML = content;

        const searchInput = document.getElementById("teacherSearch");

        searchInput.addEventListener("keyup", function () {
          const value = this.value.toLowerCase();

          const rows = document.querySelectorAll("#teacherTableBody tr");

          rows.forEach((row) => {
            const name = row.children[0].innerText.toLowerCase();

            const email = row.children[1].innerText.toLowerCase();

            if (name.includes(value) || email.includes(value)) {
              row.style.display = "";
            } else {
              row.style.display = "none";
            }
          });
        });
      } catch (error) {
        console.log("Show Teacher Error:", error);

        document.getElementById("dynamicContent").innerHTML = `
            <div style="padding:30px; text-align:center; color:red;">
                <h2>Error Loading Teachers</h2>
                <p>${error.message}</p>
            </div>
        `;
      }
    }

    function openTeacherTests(id) {
      window.location.href = "/admin/teacher-tests-page/" + id;
    }
