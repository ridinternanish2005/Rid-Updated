<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title> All India Test </title>
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts: Roboto -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/Allindiatestserice/testserice.css">
    <link rel="icon" type="image/png" href="/assets/Allindiatest/nationaltesticon1.jpeg">

</head>

<body>
    <% function timeAgo(date) { const seconds=Math.floor((new Date() - new Date(date)) / 1000); const intervals={
        year:31536000, month:2592000, day:86400, hour:3600, minute:60 }; for (let key in intervals) { const
        value=Math.floor(seconds / intervals[key]); if (value>= 1) {
        return value + " " + key + (value > 1 ? "s" : "") + " ago";
        }
        }
        return "just now";
        }

        function formatViews(views) {
        if (views >= 1000000) return (views/1000000).toFixed(1).replace('.0','') + "M";
        if (views >= 1000) return (views/1000).toFixed(1).replace('.0','') + "K";
        return views;
        }
        %>
        <%- include("common/allindiatestheader.ejs") %>

            <!-- This hidden content will be moved inside .main-layout -->
            <div id="tempContent" style="display: none;">
                <div class="content">
                    <!-- CHIPS ROW -->
                    <div class="chips-row" id="chipsRow">
                        <div class="chip active" data-filter="all">All Exams</div>
                        <div class="chip" data-filter="ssc">SSC Exams</div>
                        <div class="chip" data-filter="banking">Banking Exams</div>
                        <div class="chip" data-filter="railway">Railway Exams</div>
                        <div class="chip" data-filter="upsc">UPSC / Civil Services</div>
                        <div class="chip" data-filter="neet">NEET Exam</div>
                        <div class="chip" data-filter="jee">JEE Exam</div>
                        <div class="chip" data-filter="state">State Government Exams</div>
                        <div class="chip" data-filter="police">Police / Defence Exams</div>
                        <div class="chip" data-filter="teaching">Teaching Exams (CTET / TET)</div>
                        <div class="chip" data-filter="computer">Computer / IT Tests</div>
                        <div class="chip" data-filter="mock">Mock Tests</div>
                        <div class="chip" data-filter="previous">Previous Year Papers</div>
                        <div class="chip" data-filter="class10">Class 10 Exams</div>
                        <div class="chip" data-filter="class12">Class 12 Exams</div>
                        <div class="chip" data-filter="entrance">Entrance Exams</div>
                        <div class="chip" data-filter="competitive">Competitive Exams</div>
                    </div>

                    <div id="searchResultInfo" style="display:none;"></div>

                    <!-- VIDEO GRID -->
                    <div class="video-grid" id="videoGrid">
                        <% if(tests && tests.length> 0){ %>
                            <% tests.forEach(test=> { %>
                                <div class="video-card" data-test-id="<%= test._id %>"
                                    data-test-name="<%= test.name.toLowerCase() %>"
                                    data-subject="<%= test.subject?.toLowerCase() || '' %>"
                                    data-teacher="<%= test.teacher?.name?.toLowerCase() || '' %>"
                                    onclick="handleCardClick(event, '<%= test._id %>', '<%= test.name %>')">
                                    <% const gradients=[ "linear-gradient(135deg,#667eea,#764ba2)"
                                        , "linear-gradient(135deg,#f093fb,#f5576c)"
                                        , "linear-gradient(135deg,#4facfe,#00f2fe)"
                                        , "linear-gradient(135deg,#43e97b,#38f9d7)"
                                        , "linear-gradient(135deg,#fa709a,#fee140)"
                                        , "linear-gradient(135deg,#30cfd0,#330867)"
                                        , "linear-gradient(135deg,#5ee7df,#b490ca)"
                                        , "linear-gradient(135deg,#ff9966,#ff5e62)" ]; let hash=0; for(let i=0; i <
                                        test.name.length; i++){ hash +=test.name.charCodeAt(i); } const
                                        bgColor=gradients[hash % gradients.length]; %>

                                        <div class="thumbnail">
                                            <% if (test.thumbnail && test.thumbnail.trim() !=="" ) { %>

                                                <img src="<%= test.thumbnail %>" alt="thumbnail" />

                                                <% } else { %>

                                                    <div class="thumbnail-placeholder"
                                                        style="background:<%= bgColor %>">
                                                        <span>
                                                            <%= test.name %>
                                                        </span>
                                                    </div>

                                                    <% } %>
                                        </div>
                                        <div class="video-details">
                                            <div class="channel-avatar">
                                                <%= test.createdBy?.name?.charAt(0).toUpperCase() || "U" %>
                                            </div>
                                            <div class="video-info">
                                                <div class="title-row">

                                                    <div class="video-title">
                                                        <%= test.name %>
                                                    </div>

                                                    <div class="video-actions">

                                                        <div class="like-wrapper">

                                                            <button
                                                                class="like-btn <%= (user && test.likedBy?.includes(user._id)) ? 'liked' : '' %>"
                                                                onclick="event.stopPropagation(); toggleLike(this, '<%= test._id %>')">

                                                                <i class="fas fa-heart"></i>

                                                            </button>

                                                            <span class="like-count">
                                                                <%= test.likes || 0 %>
                                                            </span>

                                                        </div>

                                                        <button class="like-btn"
                                                            onclick="event.stopPropagation(); shareTest('<%= test._id %>', '<%= test.name %>')">
                                                            <i class="fas fa-share-alt"></i>
                                                        </button>

                                                        <!-- 🔥 MENU -->
                                                        <div class="menu-wrapper">
                                                            <button class="like-btn menu-btn">
                                                                <i class="fas fa-ellipsis-v"></i>
                                                            </button>

                                                            <div class="menu-dropdown">
                                                                <% if (test.createdBy && test.createdBy._id) { %>

                                                                    <button type="button" class="follow-btn"
                                                                        id="followBtn-<%= test.createdBy._id %>"
                                                                        onclick="event.stopPropagation(); followUser('<%= test.createdBy._id %>')">
                                                                        Follow
                                                                    </button>

                                                                    <% } else { %>

                                                                        <span style="color:red;">No Teacher</span>

                                                                        <% } %>
                                                                            <div
                                                                                onclick="openComments('<%= test._id %>')">
                                                                                💬 Comment</div>
                                                            </div>
                                                        </div>

                                                    </div>

                                                </div>
                                                <div class="channel-name" <% if (test.createdBy && test.createdBy._id) {
                                                    %>

                                                    onclick="event.stopPropagation();
                                                    window.location.href='/api/profile/<%= test.createdBy._id %>'"
                                                        <% } %>
                                                            >

                                                            <%= test.createdBy?.name %>

                                                                <% if (test.createdBy && test.createdBy._id) { %>

                                                                    • <span
                                                                        id="followerCount-<%= test.createdBy._id %>">
                                                                        👥 <%= test.createdBy.followers?.length || 0 %>
                                                                    </span> followers

                                                                    <button class="follow-inline-btn"
                                                                        id="followBtnInline-<%= test.createdBy._id %>"
                                                                        onclick="event.stopPropagation(); followUser('<%= test.createdBy._id %>')">
                                                                        Follow
                                                                    </button>

                                                                    <% } else { %>

                                                                        • 👥 0 followers

                                                                        <% } %>

                                                </div>

                                                <div class="video-stats">
                                                    <%= formatViews(test.views) %> views • <%= timeAgo(test.createdAt)
                                                            %>
                                                </div>
                                            </div>
                                        </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <p style="padding:20px;">No tests available</p>
                                        <% } %>
                    </div>
                </div>
            </div>

            <!-- POPUP (must exist for openTestPopup) -->
            <div id="startTestPopup" style="display:none;">
                <div class="popup-container">
                    <div class="popup-header">
                        <h3><i class="fas fa-rocket"></i> Start Test</h3>
                        <button class="popup-close" onclick="closePopup()"><i class="fas fa-times"></i></button>
                    </div>
                    <div class="popup-body">
                        <div class="popup-icon"><i class="fas fa-clipboard-list"></i></div>
                        <p id="popupTestName" style="font-size:1.2rem; font-weight:600;"></p>
                        <p>Your test session will start immediately.</p>
                        <div class="test-warning"><i class="fas fa-info-circle"></i> Ensure stable internet & no
                            distractions.</div>
                    </div>
                    <div class="popup-footer">
                        <button class="btn-cancel-popup" onclick="closePopup()">Cancel</button>
                        <button class="btn-start-popup" onclick="startTest()">Start Now</button>
                    </div>
                </div>
            </div>

            <script>

                async function toggleLike(btn, testId) {

                    try {

                        const res = await fetch(
                            `/National-Test-Series/like/${testId}`,
                            {
                                method: "POST"
                            }
                        );

                        const data = await res.json();

                        // 🔐 LOGIN REQUIRED
                        if (res.status === 401 || data.loginRequired) {

                            alert("Please login first");

                            window.location.href =
                                "/login?redirect=" +
                                encodeURIComponent(window.location.pathname);

                            return;
                        }

                        btn.classList.toggle(
                            "liked",
                            data.liked
                        );

                        btn.parentElement.querySelector(".like-count").innerText =
                            data.likes;

                    }
                    catch (err) {

                        console.log(err);

                    }

                }
                let selectedTestId = null;

                function openTestPopup(testId, testName) {
                    selectedTestId = testId;
                    document.getElementById("popupTestName").innerText = testName;
                    document.getElementById("startTestPopup").style.display = "flex";
                }

                function closePopup() {
                    document.getElementById("startTestPopup").style.display = "none";
                }

                function startTest() {
                    if (selectedTestId) {
                        window.location.href = "/National-Test-Series/test/" + selectedTestId;
                    }
                }

                function shareTest(testId, testName) {
                    const url = window.location.origin + "/National-Test-Series/test/" + testId;
                    const text = `📘 ${testName}\n\n👉 Start your test:\n${url}`;
                    window.open(`https://wa.me/?text=${encodeURIComponent(text)}`);
                }

                // ========== MOVE CONTENT INTO MAIN LAYOUT ==========
                document.addEventListener("DOMContentLoaded", function () {
                    const dynamicContent = document.getElementById("dynamicContent");
                    const tempContent = document.getElementById("tempContent");
                    if (dynamicContent && tempContent) {
                        // Move the inner .content div into dynamicContent
                        const contentDiv = tempContent.querySelector(".content");
                        if (contentDiv) {
                            dynamicContent.appendChild(contentDiv);
                        }
                        // Remove the temporary container
                        tempContent.remove();
                    }
                });

                // ========== ADDED CLIENT-SIDE FILTERING (chips + search) ==========
                let currentChipFilter = "all";
                let currentSearchQuery = "";

                function filterVideos() {

                    const grid = document.querySelector(".video-grid");
                    const infoDiv = document.getElementById("searchResultInfo");

                    // 🔥 ORIGINAL ALL CARDS
                    const cards = Array.from(
                        grid.querySelectorAll(".video-card")
                    );

                    const q =
                        currentSearchQuery
                            .trim()
                            .toLowerCase()
                            .replace(/[.,!?;:"']/g, "");

                    function getMatchScore(text, query) {

                        text = text.toLowerCase();

                        let score = 0;

                        if (text.includes(query)) {
                            score += 100;
                        }

                        const words = text.split(" ");

                        words.forEach(word => {

                            if (word.startsWith(query)) {
                                score += 50;
                            }

                            if (word.includes(query)) {
                                score += 20;
                            }

                        });

                        return score;
                    }

                    // 🔥 SEARCH EMPTY = SHOW ALL
                    if (q === "") {

                        cards.forEach(card => {

                            card.style.display = "block";

                        });

                        if (infoDiv) {
                            infoDiv.style.display = "none";
                        }

                        return;
                    }

                    // 🔥 FILTER
                    cards.forEach(card => {

                        const title =
                            (card.getAttribute("data-test-name") || "")
                                .toLowerCase();

                        const teacher =
                            (card.getAttribute("data-teacher") || "")
                                .toLowerCase();

                        const subject =
                            (card.getAttribute("data-subject") || "")
                                .toLowerCase();

                        const fullText =
                            `${title} ${teacher} ${subject}`;

                        const score =
                            getMatchScore(fullText, q);

                        // 🔥 MATCH
                        if (score > 0) {

                            card.style.display = "block";

                        }

                        // ❌ NO MATCH
                        else {

                            card.style.display = "none";

                        }

                    });

                    if (infoDiv) {
                        infoDiv.style.display = "none";
                    }

                }
                // Attach chip click events (delegation because chips may be moved)
                // 🔥 ONLY ONE EVENT SYSTEM

                document.addEventListener("click", function (e) {

                    const btn = e.target.closest(".menu-btn");
                    const wrapper = e.target.closest(".menu-wrapper");

                    // 🔥 MENU BUTTON CLICK
                    if (btn && wrapper) {
                        e.stopPropagation();

                        // dusre sab band
                        document.querySelectorAll(".menu-wrapper").forEach(m => {
                            if (m !== wrapper) m.classList.remove("active");
                        });

                        // toggle current
                        wrapper.classList.toggle("active");
                        return;
                    }

                    // 🔥 MENU ANDAR CLICK → kuch mat karo
                    if (e.target.closest(".menu-dropdown")) {
                        return; // ❌ stopPropagation hata diya
                    }

                    // 🔥 OUTSIDE CLICK → close
                    document.querySelectorAll(".menu-wrapper").forEach(m => m.classList.remove("active"));
                });

                // Desktop search integration
                const desktopSearchInput = document.getElementById("desktopSearchInput");
                const desktopSearchBtn = document.getElementById("desktopSearchBtn");
                const overlaySearchInput = document.getElementById("overlaySearchInput");

                if (overlaySearchInput) {

                    overlaySearchInput.addEventListener("input", function () {

                        currentSearchQuery = this.value.trim();

                        filterVideos();

                    });

                    overlaySearchInput.addEventListener("keypress", function (e) {

                        if (e.key === "Enter") {

                            currentSearchQuery = this.value.trim();

                            filterVideos();

                        }

                    });

                }
                function updateSearch() {

                    currentSearchQuery =
                        desktopSearchInput.value.trim();

                    filterVideos();

                }
                if (desktopSearchBtn) desktopSearchBtn.addEventListener("click", updateSearch);
                if (desktopSearchInput) desktopSearchInput.addEventListener("keypress", (e) => {
                    if (e.key === "Enter") updateSearch();
                });

                // Initial filter after content is moved
                setTimeout(() => {

                    // 🔥 search input empty hai to sab dikhao
                    if (desktopSearchInput && desktopSearchInput.value.trim() === "") {

                        currentSearchQuery = "";

                    }

                    filterVideos();

                }, 150);

                // 🔥 LIVE RESET
                if (desktopSearchInput) {

                    desktopSearchInput.addEventListener("input", function () {

                        // agar search empty
                        if (this.value.trim() === "") {

                            currentSearchQuery = "";

                            // URL clean
                            window.history.replaceState(
                                {},
                                "",
                                window.location.pathname
                            );

                            // sab cards wapas
                            filterVideos();
                        }

                    });

                }

                // follow and comment js code 

                function handleCardClick(e, testId, testName) {
                    // 🔥 agar menu ya button click hai → popup mat kholo
                    if (e.target.closest(".menu-wrapper")) {
                        return;
                    }

                    openTestPopup(testId, testName);
                }

                // follow systems


                async function followUser(teacherId) {

                    console.log("CLICKED:", teacherId);

                    if (!teacherId) {
                        alert("Teacher ID missing ❌");
                        return;
                    }

                    try {
                        const res = await fetch(`/api/follow/${teacherId}`, {
                            method: "POST"
                        });

                        const data = await res.json();
                        console.log("RESPONSE:", data);

                        if (res.status === 401) {
                            alert("Login required 🔐");
                            window.location.href = "/login";
                            return;
                        }

                        if (data.success) {

                            // ✅ BUTTON CHANGE
                            const btn = document.getElementById(`followBtn-${teacherId}`);
                            const inlineBtn = document.getElementById(`followBtnInline-${teacherId}`);

                            if (inlineBtn) {
                                inlineBtn.innerText = data.following ? " Unfollow" : "👤 Follow";
                            }
                            if (btn) {
                                btn.innerText = data.following ? " Unfollow" : "👤 Follow";
                            }


                            // ✅ 🔥 FOLLOWER COUNT LIVE UPDATE
                            const countEl = document.getElementById(`followerCount-${teacherId}`);

                            if (countEl) {

                                let currentCount = parseInt(
                                    countEl.innerText.replace(/[^\d]/g, "")
                                ) || 0;

                                if (data.following) {
                                    currentCount++;
                                } else {
                                    currentCount = Math.max(currentCount - 1, 0);
                                }

                                countEl.innerText = "👥 " + currentCount;
                            }

                        }

                    } catch (err) {
                        console.log("FOLLOW ERROR:", err);
                    }
                }
                document.querySelectorAll(".follow-btn").forEach(btn => {
                    btn.addEventListener("click", (e) => {
                        e.stopPropagation();
                    });
                });







                // ✅ URL से search पकड़ो
                const urlParams = new URLSearchParams(window.location.search);
                const searchQuery = urlParams.get("search");

                if (searchQuery) {
                    currentSearchQuery = searchQuery;
                    filterVideos(); // 🔥 existing function use
                }
            </script>
</body>

</html>