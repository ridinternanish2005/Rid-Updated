<script>
    (function () {
        // Generic pill toggle initializer
        function initPillToggle(pillContainer) {
            if (!pillContainer) return;
            const options = pillContainer.querySelectorAll('.pill-option');
            const indicator = pillContainer.querySelector('.pill-active-indicator');

            function setActive(activeValue) {
                pillContainer.setAttribute('data-active', activeValue);
                options.forEach(function (opt) {
                    if (opt.getAttribute('data-value') === activeValue) {
                        opt.classList.add('active-option');
                    } else {
                        opt.classList.remove('active-option');
                    }
                });
                var activeIndex = 0;
                options.forEach(function (opt, idx) {
                    if (opt.getAttribute('data-value') === activeValue) activeIndex = idx;
                });
                if (indicator) {
                    indicator.style.transform = 'translateX(' + (activeIndex * 100) + '%)';
                }
            }

            // Set initial state
            var initialActive = pillContainer.getAttribute('data-active');
            setActive(initialActive);

            options.forEach(function (opt) {
                opt.addEventListener('click', function (e) {
                    e.preventDefault();
                    var newValue = this.getAttribute('data-value');
                    var currentActive = pillContainer.getAttribute('data-active');
                    if (newValue !== currentActive) {
                        setActive(newValue);
                        var targetUrl = this.getAttribute('href');
                        if (targetUrl && targetUrl !== '#') {
                            setTimeout(function () {
                                window.location.href = targetUrl;
                            }, 150);
                        }
                    } else {
                        // Already active, navigate directly
                        var targetUrl = this.getAttribute('href');
                        if (targetUrl && targetUrl !== '#') window.location.href = targetUrl;
                    }
                });
            });

            // Fix indicator on resize
            window.addEventListener('resize', function () {
                var cur = pillContainer.getAttribute('data-active');
                var idx = 0;
                options.forEach(function (opt, i) {
                    if (opt.getAttribute('data-value') === cur) idx = i;
                });
                if (indicator) {
                    indicator.style.transform = 'translateX(' + (idx * 100) + '%)';
                }
            });
        }

        // Init both pill toggles
        initPillToggle(document.getElementById('pillToggleTS'));
        initPillToggle(document.getElementById('pillToggleLR'));
        initPillToggle(document.getElementById('pillToggleTI'));

        // Mobile menu toggle
        var menuIcon = document.getElementById('menuIcon');
        var mobileMenu = document.getElementById('innerCont');

        if (menuIcon && mobileMenu) {
            menuIcon.addEventListener('click', function (e) {
                e.stopPropagation();
                this.classList.toggle('active');
                mobileMenu.classList.toggle('active');
                document.body.style.overflow = mobileMenu.classList.contains('active') ? 'hidden' : '';
            });

            mobileMenu.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', function () {
                    if (window.innerWidth <= 768) {
                        menuIcon.classList.remove('active');
                        mobileMenu.classList.remove('active');
                        document.body.style.overflow = '';
                    }
                });
            });
        }

        window.addEventListener('resize', function () {
            if (window.innerWidth > 768 && mobileMenu && mobileMenu.classList.contains('active')) {
                mobileMenu.classList.remove('active');
                if (menuIcon) menuIcon.classList.remove('active');
                document.body.style.overflow = '';
            }
        });
    })();
</script>