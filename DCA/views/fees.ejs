<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
    <title> Fee Management </title>
     <link rel="icon" type="image/png" href="/assets/signup.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/slidebar.css">
    <link rel="stylesheet" href="/css/fees.css">

</head>

<body>
    <%- include('partials/sidebar') %>
        <div class="dashboard-layout">
            <!-- Sidebar -->

            <div class="sidebar-overlay" id="sidebarOverlay"></div>

            <main class="main-content">
                <button class="menu-toggle" id="menuToggleBtn"><i class="fas fa-bars"></i></button>
                <div class="fee-container">
                    <div class="header-section">
                        <div class="title-badge"><i class=""></i>
                            <h2>Fee Management</h2>
                        </div>
                        <div class="btn-group-header">
                            <button class="add-fee-btn" id="openAddModalBtn"><i class="fas fa-plus-circle"></i> Add
                                Payment</button>
                            <button class="export-csv-btn" id="exportCSVBtn"><i class="fas fa-download"></i> Export
                                CSV</button>
                        </div>
                    </div>
                    <div class="stats-search-bar">
                        <div class="stats-mini">
                            <div class="stat-pill"><i class="fas fa-users"></i> Total Students: <span
                                    id="totalRecords">0</span></div>
                        </div>
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" id="searchInput" placeholder="Search by student or course...">
                            <i class="fas fa-times-circle clear-search" id="clearSearch"></i>
                        </div>
                    </div>
                    <div class="table-wrapper">
                        <table class="fee-table">
                            <thead>
                                <tr>
                                    <th>👤 Student</th>
                                    <th>📘 Course</th>
                                    <th>💰 Amount</th>
                                    <th>📅 Payment Date</th>
                                    <th>🏷️ Status</th>
                                    <th>⚙️ Actions</th>
                                </tr>
                            </thead>
                            <tbody id="feeTableBody"></tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>

        <!-- Modal -->
        <div id="feeModal" class="modal-overlay">
            <div class="modal-card">
                <div class="close-modal-icon" id="closeModalBtn"><i class="fas fa-times-circle"></i></div>
                <h3 id="modalTitle"><i class="fas fa-plus-circle"></i> Payment Details</h3>
                <form id="feeForm">
                    <input type="text" id="studentName" placeholder="Full Student Name *" required>
                    <input type="text" id="courseName" placeholder="Course / Program *" required>
                    <input type="number" id="amount" placeholder="Amount (₹) *" step="1" required>
                    <input type="date" id="paymentDate" required>
                    <select id="statusSelect">
                        <option value="Paid">✅ Paid - Completed</option>
                        <option value="Pending">⏳ Pending - Due</option>
                    </select>
                    <input type="hidden" id="editId" value="">
                    <button type="submit">💾 Save Payment</button>
                </form>
            </div>
        </div>
        <div id="toastMsg" class="toast-msg">✨ Action completed</div>

        <script>
            // ---------- DATA (persistent, deleted records stay deleted) ----------
            let fees = [];
            let searchQuery = "";

            const API_URL = "/computer/api/students";

            function showToast(msg, isError = false) {
                const toast = document.getElementById('toastMsg');
                toast.textContent = msg;
                toast.style.background = isError ? '#b91c1c' : '#0f2f42';
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 2600);
            }

            function formatINR(amt) { return '₹' + amt.toLocaleString('en-IN'); }



            async function fetchStudents() {

                try {

                    const response = await fetch(API_URL);

                    const data = await response.json();

                    fees = data;

                    renderTable();

                } catch (err) {

                    console.log(err);

                    showToast("Failed to load students", true);

                }

            }

            function updateTotalCount() {
                document.getElementById("totalRecords").innerText = fees.length;
            }

            function getFiltered() {
                if (!searchQuery.trim()) return fees;
                const q = searchQuery.trim().toLowerCase();
                return fees.filter(f =>
                    f.name.toLowerCase().includes(q) ||
                    f.course.toLowerCase().includes(q)
                );
            }

            function escapeHtml(str) { return str.replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m])); }
            function escapeRegex(str) { return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

            // ---------- RESPECT DL (download respect receipt) ----------
            function downloadRespectReceipt(fee) {
                const amountFormatted = formatINR(fee.amount);
                const statusEmoji = fee.status === "Paid" ? "✅ PAID" : "⏳ PENDING";
                const receiptText = `
============================================
          RID TECH INSTITUTE
      Official Fee Acknowledgment Receipt
============================================

We hereby express our sincere respect and gratitude to:

🎓 Student Name   : ${fee.name}
📚 Course         : ${fee.course}
💰 Amount         : ${amountFormatted}
📅 Payment Date   : ${new Date(fee.createdAt).toLocaleDateString()}
🏷️ Status         : ${fee.fee}

------------------------------------------------
"Your dedication to learning and timely contribution
is highly valued. Thank you for being part of RID Tech."

Issued by: RID Tech Management
Downloaded on: ${new Date().toLocaleString()}
============================================
        `;
                const blob = new Blob([receiptText], { type: "text/plain;charset=utf-8" });
                const link = document.createElement("a");
                const url = URL.createObjectURL(blob);
                link.href = url;
                const safeName = fee.name.replace(/[^a-z0-9]/gi, '_').toLowerCase();
                link.download = `Respect_Receipt_${safeName}.txt`;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(url);
                showToast(`📄 Respect receipt saved for ${fee.name}`);
            }

            function renderTable() {
                const filtered = getFiltered();
                const tbody = document.getElementById("feeTableBody");
                if (!filtered.length) {
                    tbody.innerHTML = `<tr><td colspan="6" class="empty-state"><i class="fas fa-search"></i><br/>No fee records found</td></tr>`;
                    updateTotalCount();
                    return;
                }
                let html = "";
                filtered.forEach(fee => {
                    const statusClass = fee.fee === "Paid" ? "status-paid" : "status-pending";
                    let displayStudent = escapeHtml(fee.name);
                    let displayCourse = escapeHtml(fee.course);
                    if (searchQuery.trim()) {
                        const regex = new RegExp(`(${escapeRegex(searchQuery.trim())})`, 'gi');
                        displayStudent = displayStudent.replace(regex, `<mark>$1</mark>`);
                        displayCourse = displayCourse.replace(regex, `<mark>$1</mark>`);
                    }
                    html += `
                <tr>
                    <td><strong>${displayStudent}</strong></td>
                    <td>${displayCourse}</td>
                    <td><strong>${formatINR(fee.amount)}</strong></td>
<td>${fee.createdAt ? new Date(fee.createdAt).toLocaleDateString('en-IN') : 'N/A'}</td>
<td><span class="status-badge ${statusClass}">${fee.fee}</span></td>
                    <td class="action-group">
                        <button class="edit-btn" data-id="${fee._id}"><i class="fas fa-edit"></i> Edit</button>
                        <button class="delete-btn" data-id="${fee._id}"><i class="fas fa-trash-alt"></i> Del</button>
                        <button class="respect-btn" data-id="${fee._id}"><i class="fas fa-download"></i> Respect DL</button>
                    </td>
                </tr>
            `;
                });
                tbody.innerHTML = html;

                // Attach event listeners
                document.querySelectorAll('.edit-btn').forEach(btn =>
                    btn.addEventListener('click', () => editFee(btn.dataset.id))
                );

                document.querySelectorAll('.delete-btn').forEach(btn =>
                    btn.addEventListener('click', () => deleteFee(btn.dataset.id))
                );

                document.querySelectorAll('.respect-btn').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const id = btn.dataset.id;
                        const fee = fees.find(f => f._id === id);

                        if (fee) {
                            downloadRespectReceipt(fee);
                        } else {
                            showToast("Record not found", true);
                        }
                    });
                });
                updateTotalCount();
            }

            async function deleteFee(id) {

                if (!confirm("Delete this student?")) return;

                try {

                    const response = await fetch(`/computer/api/students/${id}`, {
                        method: "DELETE"
                    });

                    const data = await response.json();

                    if (response.ok) {

                        fees = fees.filter(f => f._id !== id);

                        renderTable();

                        showToast("Student Deleted");

                    } else {

                        showToast(data.message || "Delete Failed", true);

                    }

                } catch (err) {

                    console.log(err);

                    showToast("Server Error", true);

                }

            }

            function openAddModal() {
                document.getElementById("editId").value = "";
                document.getElementById("modalTitle").innerHTML = '<i class="fas fa-plus-circle"></i> Add New Payment';
                document.getElementById("studentName").value = "";
                document.getElementById("courseName").value = "";
                document.getElementById("amount").value = "";
                document.getElementById("paymentDate").value = new Date().toISOString().slice(0, 10);
                document.getElementById("statusSelect").value = "Paid";
                document.getElementById("feeModal").style.display = "flex";
            }

            function editFee(id) {

                const fee = fees.find(f => f._id === id);

                if (!fee) return;

                document.getElementById("editId").value = fee._id;
                document.getElementById("studentName").value = fee.name;
                document.getElementById("courseName").value = fee.course;
                document.getElementById("amount").value = fee.amount;
                document.getElementById("statusSelect").value = fee.fee;
                document.getElementById("paymentDate").value =
                    fee.createdAt
                        ? new Date(fee.createdAt).toISOString().split("T")[0]
                        : "";

                document.getElementById("modalTitle").innerHTML =
                    '<i class="fas fa-pen"></i> Edit Student';

                document.getElementById("feeModal").style.display = "flex";
            }

            function closeModal() {
                document.getElementById("feeModal").style.display = "none";
                document.getElementById("editId").value = "";
            }
            async function handleFormSubmit(e) {
                e.preventDefault();

                const student = document.getElementById("studentName").value.trim();
                const course = document.getElementById("courseName").value.trim();
                const amount = document.getElementById("amount").value;
                const status = document.getElementById("statusSelect").value;
                const paymentDate = document.getElementById("paymentDate").value;
                const editId = document.getElementById("editId").value;

                try {

                    const isEdit = editId && editId.length > 0;

                    const response = await fetch(
                        isEdit
                            ? `/computer/api/students/${editId}`
                            : `/computer/api/students`,
                        {
                            method: isEdit ? "PUT" : "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({
                                name: student,
                                course,
                                amount: Number(amount),
                                fee: status,
                                paymentDate
                            })
                        }
                    );

                    const data = await response.json();

                    if (response.ok) {
                        showToast(isEdit ? "Updated Successfully" : "Payment Added Successfully");
                        closeModal();
                        await fetchStudents();
                    } else {
                        showToast(data.message || "Save Failed", true);
                    }

                } catch (err) {
                    console.error(err);
                    showToast("Server Error", true);
                }
            }
            function exportToCSV() {
                if (!fees.length) {
                    showToast("No data to export", true);
                    return;
                }
                const headers = ["Student Name", "Course", "Amount (₹)", "Payment Date", "Status"];
                const rows = fees.map(f => [f.student, f.course, f.amount, f.date, f.status]);
                const csvContent = [headers, ...rows].map(row => row.map(cell => `"${String(cell).replace(/"/g, '""')}"`).join(",")).join("\n");
                const blob = new Blob(["\uFEFF" + csvContent], { type: "text/csv;charset=utf-8;" });
                const link = document.createElement("a");
                const url = URL.createObjectURL(blob);
                link.href = url;
                link.download = "rid_fee_records.csv";
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(url);
                showToast("📎 CSV export complete");
            }

            function handleSearch() {
                searchQuery = document.getElementById("searchInput").value;
                renderTable();
            }
            function clearSearch() {
                document.getElementById("searchInput").value = "";
                searchQuery = "";
                renderTable();
                showToast("🔍 Search cleared");
            }

            function initSidebar() {
                const menuBtn = document.getElementById("menuToggleBtn");
                const sidebar = document.getElementById("sidebar");
                const overlay = document.getElementById("sidebarOverlay");
                if (menuBtn) {
                    menuBtn.addEventListener("click", () => {
                        sidebar.classList.toggle("open");
                        overlay.style.display = "block";
                        overlay.classList.add("active");
                    });
                }
                if (overlay) {
                    overlay.addEventListener("click", () => {
                        sidebar.classList.remove("open");
                        overlay.style.display = "none";
                        overlay.classList.remove("active");
                    });
                }
                document.querySelectorAll('.nav-item').forEach(item => {
                    item.addEventListener("click", () => {
                        document.querySelectorAll('.nav-item').forEach(nav => nav.classList.remove('active'));
                        item.classList.add('active');
                        const navType = item.getAttribute('data-nav');
                        if (navType === 'fees') showToast("💰 Fee Management Dashboard");
                        else if (navType === 'reports') {
                            const collected = fees.filter(f => f.status === 'Paid').reduce((s, f) => s + f.amount, 0);
                            const pending = fees.filter(f => f.status === 'Pending').reduce((s, f) => s + f.amount, 0);
                            showToast(`📊 Analytics: Collected ${formatINR(collected)} | Pending ${formatINR(pending)}`);
                        } else showToast("ℹ️ RID Tech Support - Contact admin");
                    });
                });
            }

            async function init() {

                await fetchStudents();

                initSidebar();

                document.getElementById("openAddModalBtn").addEventListener("click", openAddModal);

                document.getElementById("closeModalBtn").addEventListener("click", closeModal);

                document.getElementById("exportCSVBtn").addEventListener("click", exportToCSV);

                document.getElementById("feeForm").addEventListener("submit", handleFormSubmit);

                document.getElementById("searchInput").addEventListener("input", handleSearch);

                document.getElementById("clearSearch").addEventListener("click", clearSearch);

                window.onclick = (e) => {
                    if (e.target === document.getElementById("feeModal")) {
                        closeModal();
                    }
                };
            }

            init();
        </script>
</body>

</html>