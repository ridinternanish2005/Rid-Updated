<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>RID Institute | Certificate Application</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/certificates.css">

</head>

<body>

  <div class="dashboard-layout">
    <!-- Sidebar -->
    <%- include('partials/sidebar') %>

      <!-- Sidebar Overlay -->
      <div class="sidebar-overlay" id="sidebarOverlay"></div>

      <!-- Main Content - Full Screen -->
      <main class="main-content">
        <button class="menu-toggle" id="menuToggleBtn">
          <i class="fas fa-bars"></i>
        </button>
<form
 id="certificateForm"
 action="/computer/api/application/create"
 method="POST"
 enctype="multipart/form-data">

          <!-- Header -->


          <!-- Email Section -->
          <div class="section">
            <div class="section-title">
              <i class="fas fa-envelope"></i>
              <h3> Your Email</h3>
            </div>
            <div class="form-group">
              <label><i class="fas fa-envelope"></i> Email Address <span class="required">*</span></label>
              <input type="email" name="email" placeholder="Enter your email address" required>
              <small style="display: block; margin-top: 5px; color: #666;">
                <i class="fas fa-info-circle"></i> Certificate download link will be sent to this email
              </small>
            </div>
          </div>

          <!-- Student Details Section -->
          <div class="section">
            <div class="section-title">
              <i class="fas fa-user-graduate"></i>
              <h3>Student Details</h3>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label><i class="fas fa-user"></i> Student Name <span class="required">*</span></label>
                <input type="text" name="studentName" placeholder="Full name" required>
              </div>
              <div class="form-group">
                <label><i class="fas fa-user-friends"></i> Father's Name <span class="required">*</span></label>
                <input type="text" name="fatherName" placeholder="Father's name" required>
              </div>
            </div>

            <div class="form-group">
              <label><i class="fas fa-book"></i> Course Name <span class="required">*</span></label>
              <input type="text" name="courseName" placeholder="e.g., ADCA, DCA, Web Development" required>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label><i class="fas fa-calendar-alt"></i> Admission Date <span class="required">*</span></label>
                <input type="date" name="admissionDate" required>
              </div>
              <div class="form-group">
                <label><i class="fas fa-calendar-check"></i> Completion Date <span class="required">*</span></label>
                <input type="date" name="completionDate" required>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label><i class="fas fa-chart-line"></i> Marks (%) <span class="required">*</span>
                  <span class="auto-badge"><i class="fas fa-magic"></i> Auto Grade</span>
                </label>
                <input type="number" id="marks" name="marks" min="0" max="100" step="0.01"
                  placeholder="Enter marks (0-100)" required>
              </div>
              <div class="form-group">
                <label><i class="fas fa-star"></i> Grade <span class="required">*</span></label>
                <input type="text" id="grade" name="grade" readonly placeholder="Auto-calculated">
              </div>
            </div>

<div class="form-group">
<label><i class="fas fa-image"></i> Student Photo <span class="required">*</span></label>

<input
 id="studentPhoto"
 type="file"
 name="photo"
 accept="image/*"
 required>

  <div style="margin-top:15px;">
    <img id="photoPreview"
         src=""
         style="display:none;width:150px;height:180px;object-fit:cover;border-radius:10px;border:2px solid #ddd;">
  </div>

  <small style="display:block;margin-top:5px;color:#666;">
    <i class="fas fa-info-circle"></i>
    Upload JPG, PNG or JPEG image
  </small>
</div>

          <!-- Hidden Fields -->
          <input type="hidden" id="certificateNo" name="certificateNo">
<input type="hidden" id="registrationNo" name="registrationNo" value="083632">
          <input type="hidden" id="enrollNo" name="enrollNo">
          <input type="hidden" id="rollNo" name="rollNo">

          <!-- Note Box -->
          <div class="note-box">
            <p>
              <i class="fas fa-shield-alt"></i>
              <strong>Note:</strong> Certificate Number, Registration Number, Enroll No., and Roll No. will be
              auto-generated.
              After admin verification, the certificate download link will be sent to your email address.
            </p>
          </div>

          <!-- Submit Button -->
          <button type="submit" class="submit-btn">
            <i class="fas fa-paper-plane"></i>
            Submit Application
          </button>

        </form>
      </main>
  </div>

  <!-- Toast Message -->
  <div id="toastMsg" class="toast-message"></div>

  <script>

    const photoInput = document.getElementById("studentPhoto");
const photoPreview = document.getElementById("photoPreview");

photoInput.addEventListener("change", function () {
  const file = this.files[0];

  if (file) {
    const reader = new FileReader();

    reader.onload = function (e) {
      photoPreview.src = e.target.result;
      photoPreview.style.display = "block";
    };

    reader.readAsDataURL(file);
  }
});
    // Sidebar Toggle Functionality
    const menuToggle = document.getElementById('menuToggleBtn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');

    if (menuToggle) {
      menuToggle.addEventListener('click', () => {
        sidebar.classList.toggle('open');
        overlay.classList.toggle('active');
        overlay.style.display = overlay.classList.contains('active') ? 'block' : 'none';
      });

      overlay.addEventListener('click', () => {
        sidebar.classList.remove('open');
        overlay.classList.remove('active');
        overlay.style.display = 'none';
      });
    }

    // Close sidebar on window resize to desktop
    window.addEventListener('resize', () => {
      if (window.innerWidth > 900) {
        sidebar.classList.remove('open');
        overlay.classList.remove('active');
        overlay.style.display = 'none';
      }
    });

    // Auto-grade calculation
    const marksInput = document.getElementById("marks");
    const gradeInput = document.getElementById("grade");

    function calculateGrade(marks) {
      if (marks === '' || marks === null) return '';
      const m = parseFloat(marks);
      if (isNaN(m)) return '';
      if (m >= 90) return 'A+';
      if (m >= 80) return 'A';
      if (m >= 70) return 'B+';
      if (m >= 60) return 'B';
      if (m >= 50) return 'C+';
      if (m >= 40) return 'C';
      if (m >= 33) return 'D';
      return 'F';
    }

    marksInput.addEventListener("input", function () {
      gradeInput.value = calculateGrade(this.value);
    });

    // Toast message
    function showToast(message, isError = false) {
      const toast = document.getElementById('toastMsg');
      toast.textContent = message;
      toast.style.background = isError ? '#b91c1c' : '#1e293b';
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    // Form submission
    document.getElementById("certificateForm")
.addEventListener("submit", function () {

  document.getElementById("grade").value =
    calculateGrade(document.getElementById("marks").value);

});
    document.getElementById("certificateForm").addEventListener("submit", function (e) {
      // Generate unique numbers
      const now = new Date();
      const year = now.getFullYear();
      const random = Math.floor(Math.random() * 9999).toString().padStart(4, '0');

      document.getElementById("certificateNo").value = "RID/" + year + "/" + random;
document.getElementById("registrationNo").value = "083632";
      document.getElementById("enrollNo").value = "RID/" + year + "/" + Math.floor(Math.random() * 9999).toString().padStart(4, '0');
      document.getElementById("rollNo").value = Math.floor(Math.random() * 99999999).toString().padStart(8, '0');

      // Validate fields
      const email = document.querySelector('input[name="email"]').value.trim();
      const studentName = document.querySelector('input[name="studentName"]').value.trim();
      const fatherName = document.querySelector('input[name="fatherName"]').value.trim();
      const courseName = document.querySelector('input[name="courseName"]').value.trim();
      const admissionDate = document.querySelector('input[name="admissionDate"]').value;
      const completionDate = document.querySelector('input[name="completionDate"]').value;
      const marks = document.querySelector('input[name="marks"]').value;
const photo = document.getElementById("studentPhoto").files[0];

if (!email || !studentName || !fatherName || !courseName || !admissionDate || !completionDate || !marks || !photo) {
        e.preventDefault();
        showToast("❌ Please fill all required fields", true);
        return;
      }

      if (new Date(completionDate) <= new Date(admissionDate)) {
        e.preventDefault();
        showToast("❌ Completion date must be after admission date", true);
        return;
      }

      if (marks < 0 || marks > 100) {
        e.preventDefault();
        showToast("❌ Marks should be between 0-100", true);
        return;
      }

      // Show loading state
      const submitBtn = document.querySelector('.submit-btn');
      submitBtn.classList.add('loading');
      submitBtn.innerHTML = '<i class="fas fa-spinner"></i> Submitting...';

      showToast("✅ Application submitted! You will receive email confirmation soon.");
    });

    // Marks validation
    marksInput.addEventListener('change', function () {
      let val = parseFloat(this.value);
      if (val < 0) this.value = 0;
      if (val > 100) this.value = 100;
      gradeInput.value = calculateGrade(this.value);
    });

    // Update sidebar stats from localStorage if available
    function updateSidebarStats() {
      try {
        const stored = localStorage.getItem('rid_cert_data');
        if (stored) {
          const applications = JSON.parse(stored);
          const pendingCount = applications.filter(a => a.status === 'pending').length;
          const verifiedCount = applications.filter(a => a.status === 'verified').length;

          const pendingEl = document.getElementById('statPending');
          const verifiedEl = document.getElementById('statVerified');
          const totalEl = document.getElementById('statTotal');

          if (pendingEl) pendingEl.innerText = pendingCount;
          if (verifiedEl) verifiedEl.innerText = verifiedCount;
          if (totalEl) totalEl.innerText = applications.length;
        }
      } catch (e) {
        console.log('No stored data');
      }
    }

    updateSidebarStats();
  </script>
</body>

</html>