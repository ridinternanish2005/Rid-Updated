<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
    <title> ID Card </title>
     <link rel="icon" type="image/png" href="/assets/signup.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html-to-image/1.11.11/html-to-image.min.js"></script>
    <link rel="stylesheet" href="/css/idcard.css">
   
</head>
<body>
<%- include('partials/sidebar') %>
<!-- SIDEBAR - FULLY DEFINED -->


<div class="sidebar-overlay" id="sidebarOverlay"></div>
<button class="menu-toggle" id="menuToggleBtn"><i class="fas fa-bars"></i></button>

<div class="main-content">
    <div class="id-card-wrapper">
        <div class="tabs">
            <button class="tab-btn active" id="tabFormBtn">📝 STUDENT DETAILS</button>
            <button class="tab-btn" id="tabPreviewBtn">🪪 SMART ID CARD</button>
        </div>

        <!-- FORM PANEL -->
        <div class="pane active" id="formPane">
            <div class="form-grid">
                <div class="full-width">
                    <div class="photo-upload" id="photoArea">
                        <input type="file" id="photoFile" accept="image/*">
                        <i class="fas fa-camera" style="font-size: 32px; color: #06b6d4;"></i>
                        <span style="display: block; margin-top: 6px;">Click to upload photo</span>
                        <img id="photoPreviewImg" class="photo-preview">
                    </div>
                </div>
                <div class="input-group"><label><i class="fas fa-user"></i> First Name</label><input type="text" id="firstName" value="ANANYA"></div>
                <div class="input-group"><label><i class="fas fa-user-tag"></i> Last Name</label><input type="text" id="lastName" value="SHARMA"></div>
                <div class="full-width input-group">
                    <label><i class="fas fa-laptop-code"></i> Course / Program</label>
                    <input type="text" id="courseInput" value="Full Stack Development" placeholder="Enter course name">
                </div>
                <div class="full-width">
                    <label><i class="fas fa-id-badge"></i> Student ID</label>
                    <div class="id-badge">
                        <span id="studentIdDisplay">AVON-2026-8K9L2M</span>
                        <button class="regen-btn" id="regenerateIdBtn"><i class="fas fa-sync-alt"></i> New ID</button>
                    </div>
                    <input type="hidden" id="studentIdHidden">
                </div>
                <div class="input-group"><label><i class="fas fa-envelope"></i> Email</label><input type="email" id="email" value="ananya.sharma@avon.edu"></div>
                <div class="input-group"><label><i class="fas fa-phone-alt"></i> Mobile</label><input type="text" id="mobile" value="9876543210"></div>
                <div class="input-group"><label><i class="fas fa-calendar-alt"></i> Enrollment Date</label><input type="date" id="enrollDate" value="2026-05-01"></div>
                <div class="input-group"><label><i class="fas fa-calendar-check"></i> Valid Till</label><input type="date" id="validTill" value="2027-05-01"></div>
                <div class="input-group"><label><i class="fas fa-university"></i> Institute Name</label><input type="text" id="institute" value="AVON COMPUTER ACADEMY"></div>
                <div class="input-group"><label><i class="fas fa-tag"></i> Tagline</label><input type="text" id="tagline" value="Empowering Digital Future"></div>
                <div class="input-group"><label><i class="fas fa-globe"></i> Website</label><input type="text" id="website" value="www.avonacademy.in"></div>
                <div class="input-group"><label><i class="fas fa-phone-volume"></i> Inst. Phone</label><input type="text" id="instPhone" value="+91 755 496 7800"></div>
                <div class="full-width input-group">
                    <label><i class="fas fa-map-marker-alt"></i> Address (Institute Address)</label>
                    <textarea id="addressInput" rows="3" placeholder="Enter full institute address">Avon Tower, 2nd Floor, Bhopal - 462011</textarea>
                </div>
            </div>
            <button class="generate-btn" id="generateCardBtn"><i class="fas fa-magic"></i> GENERATE ID CARD</button>
        </div>

        <!-- PREVIEW PANEL -->
        <div class="pane" id="previewPane">
            <button class="back-edit" id="backToFormBtn"><i class="fas fa-arrow-left"></i> Back to Edit</button>
            <div class="cards-container">
                <div class="card-item">
                    <div class="card-label">FRONT</div>
                    <div class="id-card front-card" id="frontCard">
                        <div class="front-bg"></div>
                        <div class="logo-circle"><i class="fas fa-graduation-cap" style="color:#06b6d4; font-size:24px;"></i></div>
                        <div class="inst-name" id="instNameLive">AVON COMPUTER <span>ACADEMY</span></div>
                        <div class="inst-tagline" id="taglineLive">Empowering Digital Future</div>
                        <div class="photo-circle" id="photoCircleLive"><i class="fas fa-user-graduate" style="font-size:40px; color:#94a3b8;"></i></div>
                        <div class="student-name" id="fullNameLive">ANANYA SHARMA</div>
                        <div style="text-align:center;"><span class="course-badge" id="courseLive">FULL STACK DEVELOPMENT</span></div>
                        <div class="info-grid">
                            <div class="info-row"><div class="info-label">ID</div><div class="info-value" id="idLive">AVON-2026-8K9L2M</div></div>
                            <div class="info-row"><div class="info-label">EMAIL</div><div class="info-value" id="emailLive">ananya.sharma@avon.edu</div></div>
                            <div class="info-row"><div class="info-label">MOBILE</div><div class="info-value" id="mobileLive">9876543210</div></div>
                            <div class="info-row"><div class="info-label">ENROLL</div><div class="info-value" id="enrollLive">01-05-2026</div></div>
                            <div class="info-row"><div class="info-label">VALID</div><div class="info-value" id="validLive">01-05-2027</div></div>
                        </div>
                        <div class="footer-wave"></div>
                        <div class="website-text" id="websiteLive">www.ridtech.in</div>
                    </div>
                </div>
                <div class="card-item">
                    <div class="card-label">BACK</div>
                    <div class="id-card back-card" id="backCard">
                        <div class="back-bg"></div>
                        <div class="back-title">◆ ACADEMY RULES ◆</div>
                        <div class="rules-list">
                            <div class="rule"><div class="check-icon">✓</div><div class="rule-text">ID card must be visible in campus & library</div></div>
                            <div class="rule"><div class="check-icon">✓</div><div class="rule-text">Non-transferable · Report loss immediately</div></div>
                        </div>
                        <div class="contact-info">
                            <div class="contact-line"><i class="fas fa-building"></i><span id="addrLive">Avon Tower, Bhopal</span></div>
                            <div class="contact-line"><i class="fas fa-phone"></i><span id="phoneLive">+91 755 496 7800</span></div>
                            <div class="contact-line"><i class="fas fa-globe"></i><span id="webBackLive">www.ridtech.in</span></div>
                        </div>
                        <div class="qr-box" id="qrContainer"></div>
                        <div class="signature"><div class="sig-name">Authorized Signatory</div><div class="sig-line"></div><div class="sig-label">DIRECTOR</div></div>
                    </div>
                </div>
            </div>
            <div class="download-buttons">
                <button class="btn-download btn-primary" id="downloadFrontBtn"><i class="fas fa-download"></i> Front PNG</button>
                <button class="btn-download btn-primary" id="downloadBackBtn"><i class="fas fa-download"></i> Back PNG</button>
                <button class="btn-download btn-outline" id="downloadBothBtn"><i class="fas fa-layer-group"></i> Both Sides</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        // SIDEBAR TOGGLE
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const menuToggle = document.getElementById('menuToggleBtn');
        function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('active'); }
        function openSidebar() { sidebar.classList.add('open'); overlay.classList.add('active'); }
        if (menuToggle) {
            menuToggle.addEventListener('click', (e) => { e.stopPropagation(); sidebar.classList.contains('open') ? closeSidebar() : openSidebar(); });
        }
        if (overlay) overlay.addEventListener('click', closeSidebar);
        window.addEventListener('resize', () => { if(window.innerWidth > 768) { sidebar.classList.remove('open'); overlay.classList.remove('active'); } });
        
        // Navigation elements
        const navForm = document.getElementById('navFormSide');
        const navPreview = document.getElementById('navPreviewSide');
        const navHelp = document.getElementById('navHelpSide');
        const navSettings = document.getElementById('navSettingsSide');
        const formPane = document.getElementById('formPane');
        const previewPane = document.getElementById('previewPane');
        const tabForm = document.getElementById('tabFormBtn');
        const tabPreview = document.getElementById('tabPreviewBtn');
        const backBtn = document.getElementById('backToFormBtn');
        
        function showPane(pane) {
            if (formPane) formPane.classList.toggle('active', pane === 'form');
            if (previewPane) previewPane.classList.toggle('active', pane === 'preview');
            if (tabForm) tabForm.classList.toggle('active', pane === 'form');
            if (tabPreview) tabPreview.classList.toggle('active', pane === 'preview');
            if (navForm) navForm.classList.toggle('active', pane === 'form');
            if (navPreview) navPreview.classList.toggle('active', pane === 'preview');
            if (pane === 'preview') closeSidebar();
        }
        
        if (navForm) navForm.addEventListener('click', () => showPane('form'));
        if (navPreview) navPreview.addEventListener('click', () => showPane('preview'));
        if (tabForm) tabForm.addEventListener('click', () => showPane('form'));
        if (tabPreview) tabPreview.addEventListener('click', () => showPane('preview'));
        if (backBtn) backBtn.addEventListener('click', () => showPane('form'));
        if (navHelp) navHelp.addEventListener('click', () => alert("📌 Fill all details, upload photo, click GENERATE. Then download front/back as high-quality PNG."));
        if (navSettings) navSettings.addEventListener('click', () => alert("⚙️ Settings coming soon — customize ID card colors and layout."));

        // Photo upload
        let uploadedPhoto = null;
        const photoFile = document.getElementById('photoFile');
        const photoPreviewImg = document.getElementById('photoPreviewImg');
        if (photoFile) {
            photoFile.addEventListener('change', (e) => {
                if(e.target.files && e.target.files[0]) {
                    const reader = new FileReader();
                    reader.onload = (ev) => {
                        uploadedPhoto = ev.target.result;
                        if (photoPreviewImg) {
                            photoPreviewImg.src = uploadedPhoto;
                            photoPreviewImg.style.display = 'block';
                        }
                    };
                    reader.readAsDataURL(e.target.files[0]);
                }
            });
        }

        // Format date
        function formatDate(dateStr) {
            if(!dateStr) return '';
            const d = new Date(dateStr);
            if(isNaN(d)) return '';
            return `${String(d.getDate()).padStart(2,'0')}-${String(d.getMonth()+1).padStart(2,'0')}-${d.getFullYear()}`;
        }

        // ID generation
        function generateRandomId() {
            const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ0123456789';
            let code = '';
            for(let i=0;i<6;i++) code += chars[Math.floor(Math.random() * chars.length)];
            return `AVON-2026-${code}`;
        }
        const studentIdSpan = document.getElementById('studentIdDisplay');
        const studentIdHidden = document.getElementById('studentIdHidden');
        function regenId() {
            const newId = generateRandomId();
            if (studentIdSpan) studentIdSpan.innerText = newId;
            if (studentIdHidden) studentIdHidden.value = newId;
        }
        const regenBtn = document.getElementById('regenerateIdBtn');
        if (regenBtn) regenBtn.addEventListener('click', regenId);
        regenId();

        // Update cards
        function updateCards() {
            const firstName = document.getElementById('firstName')?.value.toUpperCase() || 'STUDENT';
            const lastName = document.getElementById('lastName')?.value.toUpperCase() || '';
            const fullName = `${firstName} ${lastName}`.trim();
            const courseVal = document.getElementById('courseInput')?.value || 'COURSE';
            const studentIdVal = studentIdHidden ? studentIdHidden.value : (studentIdSpan ? studentIdSpan.innerText : 'ID-0000');
            const emailVal = document.getElementById('email')?.value || '';
            const mobileVal = document.getElementById('mobile')?.value || '';
            const enroll = formatDate(document.getElementById('enrollDate')?.value);
            const valid = formatDate(document.getElementById('validTill')?.value);
            const instituteVal = document.getElementById('institute')?.value || 'AVON ACADEMY';
            const taglineVal = document.getElementById('tagline')?.value || '';
            const websiteVal = document.getElementById('website')?.value || '';
            const instPhoneVal = document.getElementById('instPhone')?.value || '';
            const addressVal = document.getElementById('addressInput')?.value || '';

            // Front
            const parts = instituteVal.split(' ');
            const firstPart = parts.slice(0, -1).join(' ') || instituteVal;
            const lastPart = parts[parts.length-1] || '';
            const instNameLive = document.getElementById('instNameLive');
            if (instNameLive) instNameLive.innerHTML = `${firstPart} <span>${lastPart}</span>`;
            const taglineLive = document.getElementById('taglineLive');
            if (taglineLive) taglineLive.innerText = taglineVal;
            const fullNameLive = document.getElementById('fullNameLive');
            if (fullNameLive) fullNameLive.innerText = fullName;
            const courseLive = document.getElementById('courseLive');
            if (courseLive) courseLive.innerText = courseVal.toUpperCase();
            const idLive = document.getElementById('idLive');
            if (idLive) idLive.innerText = studentIdVal;
            const emailLive = document.getElementById('emailLive');
            if (emailLive) emailLive.innerText = emailVal;
            const mobileLive = document.getElementById('mobileLive');
            if (mobileLive) mobileLive.innerText = mobileVal;
            const enrollLive = document.getElementById('enrollLive');
            if (enrollLive) enrollLive.innerText = enroll;
            const validLive = document.getElementById('validLive');
            if (validLive) validLive.innerText = valid;
            const websiteLive = document.getElementById('websiteLive');
            if (websiteLive) websiteLive.innerText = websiteVal;

            // Photo
            const photoCircle = document.getElementById('photoCircleLive');
            if (photoCircle) {
                if(uploadedPhoto) photoCircle.innerHTML = `<img src="${uploadedPhoto}" style="width:100%; height:100%; object-fit:cover; border-radius:50%;">`;
                else photoCircle.innerHTML = '<i class="fas fa-user-graduate" style="font-size:40px; color:#94a3b8;"></i>';
            }

            // Back
            const addrLive = document.getElementById('addrLive');
            if (addrLive) addrLive.innerText = addressVal.split('\n')[0] || addressVal;
            const phoneLive = document.getElementById('phoneLive');
            if (phoneLive) phoneLive.innerText = instPhoneVal;
            const webBackLive = document.getElementById('webBackLive');
            if (webBackLive) webBackLive.innerText = websiteVal;

            // QR
            const qrDiv = document.getElementById('qrContainer');
            if (qrDiv) {
                qrDiv.innerHTML = '';
                new QRCode(qrDiv, {
                    text: `ID:${studentIdVal} | ${fullName} | ${courseVal}`,
                    width: 62,
                    height: 62,
                    colorDark: "#0A192F",
                    colorLight: "#ffffff"
                });
            }
        }

        // Generate button
        const generateBtn = document.getElementById('generateCardBtn');
        if (generateBtn) {
            generateBtn.addEventListener('click', () => {
                updateCards();
                showPane('preview');
            });
        }

        // Download functions
        async function downloadCard(elementId, filename) {
            const el = document.getElementById(elementId);
            if (!el) return;
            try {
                const data = await htmlToImage.toPng(el, { pixelRatio: 2.5, backgroundColor: '#ffffff', cacheBust: true });
                const link = document.createElement('a');
                link.download = filename;
                link.href = data;
                link.click();
            } catch(e) { alert("Download failed: " + e.message); }
        }
        const frontBtn = document.getElementById('downloadFrontBtn');
        const backBtnEl = document.getElementById('downloadBackBtn');
        const bothBtn = document.getElementById('downloadBothBtn');
        if (frontBtn) frontBtn.addEventListener('click', () => downloadCard('frontCard', 'id-front.png'));
        if (backBtnEl) backBtnEl.addEventListener('click', () => downloadCard('backCard', 'id-back.png'));
        if (bothBtn) bothBtn.addEventListener('click', async () => {
            await downloadCard('frontCard', 'id-front.png');
            setTimeout(() => downloadCard('backCard', 'id-back.png'), 400);
        });
    })();
</script>
</body>
</html>