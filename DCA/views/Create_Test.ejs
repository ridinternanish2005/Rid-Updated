    // IMPROVED SWITCH TAB FUNCTION - Smooth and reliable
    function switchTab(tab) {
        // Update display of tab containers
        document.getElementById('createTab').style.display = tab === 'create' ? 'block' : 'none';
        document.getElementById('bankTab').style.display = tab === 'bank' ? 'block' : 'none';
        document.getElementById('testsTab').style.display = tab === 'tests' ? 'block' : 'none';
        
        // Update active classes on top tabs and sidebar nav items
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.nav-item').forEach(nav => nav.classList.remove('active'));
        
        const activeTabBtn = document.querySelector(`.tab-btn[data-tab="${tab}"]`);
        const activeNavItem = document.querySelector(`.nav-item[data-tab="${tab}"]`);
        if (activeTabBtn) activeTabBtn.classList.add('active');
        if (activeNavItem) activeNavItem.classList.add('active');
        
        // Refresh data if needed
        if (tab === 'bank') renderBankList();
        if (tab === 'tests') renderAllTestCards();
        
        // Small haptic feedback
        showToast(`Switched to ${tab === 'create' ? 'Create' : tab === 'bank' ? 'Bank' : 'Tests'} view`);
    }
    
    // Event Listeners for tabs
    document.querySelectorAll('.tab-btn, .nav-item[data-tab]').forEach(el => {
        el.addEventListener('click', (e) => {
            e.preventDefault();
            const tab = el.getAttribute('data-tab');
            if (tab) switchTab(tab);
        });
    });
    
  
