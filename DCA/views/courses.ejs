<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
  <title>Course Manager</title>
  <!-- Google Fonts + Font Awesome 6 -->
    <link rel="icon" type="image/png" href="/assets/signup.png">
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/css/courses.css">

</head>
<body>
  <%- include('partials/sidebar') %>
<div class="dashboard">
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- MAIN CONTENT (Course Manager) -->
  <div class="main-content" id="mainContent">
    <button class="menu-toggle" id="menuToggleBtn"><i class="fas fa-bars"></i> </button>

    <div class="manager-container">
      <div class="manager-header">
        <div class="title-section">
          <h1><i class="" style="margin-right: 10px; color:#2563eb;"></i> All Courses</h1>
       
        </div>
        <button class="btn-primary" onclick="openModal()"><i class="fas fa-plus-circle"></i> Add Course</button>
      </div>

      <div class="stats-search-panel">
        <div class="stats-group">
          <div class="stat-badge"><i class=""></i> <span id="totalCoursesCount">0</span> Courses</div>
          <div class="stat-badge"><i class="fas fa-user-graduate"></i> <span id="totalEnrollmentsCount">0</span> Total Enrollments</div>
        </div>
        <div class="search-wrapper">
          <i class="fas fa-search"></i>
          <input type="text" id="searchInput" placeholder="Search by name or category..." autocomplete="off">
        </div>
      </div>

      <div id="dynamicPanel"></div>
    </div>
  </div>
</div>

<!-- MODAL -->
<div id="courseModal" class="modal">
  <div class="modal-content">
    <h3 id="modalTitle">Add New Course</h3>
    <form id="courseForm">
      <div class="form-group">
        <label><i class="fas fa-book"></i> Course Name *</label>
        <input type="text" id="courseName" placeholder="e.g., Full-Stack Web Development" required>
      </div>
      <div class="form-group">
        <label><i class="fas fa-tag"></i> Category *</label>
        <input type="text" id="courseCategory" placeholder="e.g., Development, Data & AI, Design" required>
      </div>
      <div class="form-group">
        <label><i class="fas fa-users"></i> Enrollments</label>
        <input type="number" id="courseEnrollments" placeholder="Number of enrollments" min="0" value="0">
      </div>
      <input type="hidden" id="editCourseId" value="">
      <div class="modal-actions">
        <button type="button" class="cancel-modal" id="cancelModalBtn">Cancel</button>
        <button type="submit" class="save-modal">Save Course</button>
      </div>
    </form>
  </div>
</div>
<div id="toastMsg" class="toast">✅ Action completed</div>

<script>
  // ============================================
  // COURSE MANAGER WITH MONGODB BACKEND INTEGRATION
  // All data persists in MongoDB via REST API
  // ============================================
  
  let courses = [];
  let editMode = false;
  let editId = null;
  let currentSearchTerm = '';
  let isLoading = false;

  // API endpoint for MongoDB operations
const API_BASE_URL = '/computer/api/courses';

  // Toast notification helper
  function showToast(message, isError = false) {
    const toast = document.getElementById('toastMsg');
    toast.textContent = (isError ? '⚠️ ' : '✅ ') + message;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
  }

  // Fetch all courses from MongoDB
  async function fetchCourses() {
    if (isLoading) return;
    isLoading = true;
    
    try {
      // Show loading state in table
      const container = document.getElementById('dynamicPanel');
      if (container) {
        container.innerHTML = `<div class="table-wrapper"><div class="loading-spinner"><i class="fas fa-spinner fa-pulse"></i> Loading courses from MongoDB...</div></div>`;
      }
      
      const response = await fetch(`${API_BASE_URL}`, {
        method: 'GET',
        headers: { 'Content-Type': 'application/json' }
      });
      
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }
      
      const data = await response.json();
      // Ensure we have an array (MongoDB returns array of courses)
      courses = Array.isArray(data) ? data : [];
      renderCourseManager();
      
      if (courses.length === 0) {
        showToast("No courses found. Add your first course!", false);
      }
    } catch (error) {
      console.error('Error fetching courses:', error);
      showToast(`Failed to load courses: ${error.message}`, true);
      courses = [];
      renderCourseManager();
    } finally {
      isLoading = false;
    }
  }

  // Add new course to MongoDB
  async function addCourse(courseData) {
    try {
      const response = await fetch(`${API_BASE_URL}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(courseData)
      });
      
      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData.message || `HTTP ${response.status}`);
      }
      
      const newCourse = await response.json();
      showToast(`Course "${newCourse.courseName}" added to MongoDB!`);
      await fetchCourses(); // Refresh the list
      return true;
    } catch (error) {
      console.error('Error adding course:', error);
      showToast(`Failed to add course: ${error.message}`, true);
      return false;
    }
  }

  // Update existing course in MongoDB
  async function updateCourse(courseId, courseData) {
    try {
      const response = await fetch(`${API_BASE_URL}/${courseId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(courseData)
      });
      
      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData.message || `HTTP ${response.status}`);
      }
      
      const updatedCourse = await response.json();
      showToast(`Course "${updatedCourse.courseName}" updated in MongoDB!`);
      await fetchCourses(); // Refresh the list
      return true;
    } catch (error) {
      console.error('Error updating course:', error);
      showToast(`Failed to update course: ${error.message}`, true);
      return false;
    }
  }

  // Delete course from MongoDB
  async function deleteCourse(courseId) {
    try {
      const response = await fetch(`${API_BASE_URL}/${courseId}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
      });
      
      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData.message || `HTTP ${response.status}`);
      }
      
      const result = await response.json();
      showToast(result.message || 'Course deleted from MongoDB!');
      await fetchCourses(); // Refresh the list
      return true;
    } catch (error) {
      console.error('Error deleting course:', error);
      showToast(`Failed to delete course: ${error.message}`, true);
      return false;
    }
  }

  // Handle form submit (Create or Update)
  async function handleFormSubmit(event) {
    event.preventDefault();
    
    const courseName = document.getElementById('courseName').value.trim();
    const courseCategory = document.getElementById('courseCategory').value.trim();
    const courseEnrollments = parseInt(document.getElementById('courseEnrollments').value) || 0;

    if (!courseName || !courseCategory) {
      showToast("Course name and category are required", true);
      return;
    }

    const courseData = {
      courseName: courseName,
      courseCategory: courseCategory,
      courseEnrollments: courseEnrollments
    };

    let success = false;
    
    if (editMode && editId) {
      success = await updateCourse(editId, courseData);
    } else {
      success = await addCourse(courseData);
    }
    
    if (success) {
      closeModal();
      document.getElementById('courseForm').reset();
    }
  }

  // Delete course with confirmation
  window.deleteCourseById = async function(courseId) {
    if (!confirm("⚠️ Delete this course permanently from MongoDB? This action cannot be undone.")) return;
    await deleteCourse(courseId);
  }

  // Open modal for add or edit
  window.openModal = function(course = null) {
    const modal = document.getElementById('courseModal');
    const modalTitle = document.getElementById('modalTitle');
    const courseNameInput = document.getElementById('courseName');
    const courseCategoryInput = document.getElementById('courseCategory');
    const courseEnrollmentsInput = document.getElementById('courseEnrollments');
    const editCourseIdField = document.getElementById('editCourseId');

    if (course && course._id) {
      editMode = true;
      editId = course._id;
      modalTitle.innerText = "✏️ Edit Course";
      courseNameInput.value = course.courseName;
      courseCategoryInput.value = course.courseCategory;
      courseEnrollmentsInput.value = course.courseEnrollments || 0;
      editCourseIdField.value = course._id;
    } else {
      editMode = false;
      editId = null;
      modalTitle.innerText = "➕ Add New Course";
      document.getElementById('courseForm').reset();
      courseEnrollmentsInput.value = "0";
      editCourseIdField.value = "";
    }
    modal.style.display = "flex";
  }

  function closeModal() {
    document.getElementById('courseModal').style.display = "none";
    document.getElementById('courseForm').reset();
    editMode = false;
    editId = null;
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // Render course table with MongoDB data
  function renderCourseManager() {
    const container = document.getElementById('dynamicPanel');
    if (!container) return;

    // Apply search filter
    let filteredCourses = courses;
    if (currentSearchTerm.trim() !== '') {
      filteredCourses = courses.filter(course =>
        course.courseName.toLowerCase().includes(currentSearchTerm.toLowerCase()) ||
        course.courseCategory.toLowerCase().includes(currentSearchTerm.toLowerCase())
      );
    }

    const totalCourses = courses.length;
    const totalEnrollments = courses.reduce((sum, course) => sum + (course.courseEnrollments || 0), 0);
    
    document.getElementById('totalCoursesCount').innerText = totalCourses;
    document.getElementById('totalEnrollmentsCount').innerText = totalEnrollments.toLocaleString();

    // Empty state
    if (filteredCourses.length === 0) {
      const emptyMessage = courses.length === 0 
        ? '<i class="fas fa-database" style="margin-right: 8px;"></i> No courses in MongoDB. Click "Add Course" to get started! '
        : '<i class="fas fa-search" style="margin-right: 8px;"></i> No courses match your search. Try different keywords.';
      
      container.innerHTML = `
        <div class="table-wrapper">
          <table class="course-table">
            <thead><tr><th>Course Name</th><th>Category</th><th>Enrollments</th><th>Actions</th></tr></thead>
            <tbody><tr class="empty-row"><td colspan="4">${emptyMessage}</td></tr></tbody>
          </table>
        </div>
      `;
      return;
    }

    // Build table rows with MongoDB _id
    let rows = filteredCourses.map(course => {
      const safeCourse = {
        _id: course._id,
        courseName: course.courseName,
        courseCategory: course.courseCategory,
        courseEnrollments: course.courseEnrollments || 0
      };
      const jsonData = JSON.stringify(safeCourse).replace(/'/g, "&#39;");
      
      return `
        <tr>
          <td><strong>${escapeHtml(course.courseName)}</strong></strong></td>
          <td><span class="category-chip">${escapeHtml(course.courseCategory)}</span></td>
          <td><span class="enroll-value"><i class="fas fa-user-friends"></i> ${(course.courseEnrollments || 0).toLocaleString()} enrolled</span></td>
          <td>
            <div class="action-btns">
              <button class="edit-btn" onclick='openModal(${jsonData})'><i class="fas fa-edit"></i> Edit</button>
              <button class="delete-btn" onclick="deleteCourseById('${course._id}')"><i class="fas fa-trash"></i> Delete</button>
            </div>
          </td>
        </tr>
      `;
    }).join("");

    container.innerHTML = `
      <div class="table-wrapper">
        <table class="course-table">
          <thead>
            <tr>
              <th>Course Name</th>
              <th>Category</th>
              <th>Enrollments</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;
  }

  // ========== SIDEBAR TOGGLE LOGIC ==========
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');
  const menuToggleBtn = document.getElementById('menuToggleBtn');

  function openSidebar() {
    if (sidebar) sidebar.classList.add('open');
    if (overlay) overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    if (sidebar) sidebar.classList.remove('open');
    if (overlay) overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  function toggleSidebar() {
    if (sidebar && sidebar.classList.contains('open')) {
      closeSidebar();
    } else {
      openSidebar();
    }
  }

  if (menuToggleBtn) {
    menuToggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleSidebar();
    });
  }
  if (overlay) {
    overlay.addEventListener('click', closeSidebar);
  }

  function handleResize() {
    if (window.innerWidth > 768) {
      if (sidebar) sidebar.classList.remove('open');
      if (overlay) overlay.classList.remove('active');
      document.body.style.overflow = '';
    } else {
      if (sidebar && sidebar.classList.contains('open')) {
        overlay.classList.add('active');
      } else {
        overlay.classList.remove('active');
      }
    }
  }

  window.addEventListener('resize', handleResize);
  document.addEventListener('keydown', (e) => { if (e.key === "Escape") closeSidebar(); });
  
  // Navigation active highlight
  document.querySelectorAll('.nav-item').forEach(link => {
    link.addEventListener('click', (e) => {
      if (window.innerWidth <= 768) closeSidebar();
      document.querySelectorAll('.nav-item').forEach(nav => nav.classList.remove('active'));
      link.classList.add('active');
    });
  });

  // Search input handler
  const searchInput = document.getElementById('searchInput');
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      currentSearchTerm = e.target.value;
      renderCourseManager();
    });
  }

  // Initialize event listeners
  document.getElementById('courseForm').addEventListener('submit', handleFormSubmit);
  document.getElementById('cancelModalBtn').addEventListener('click', closeModal);
  window.addEventListener('click', (e) => {
    if (e.target.id === 'courseModal') closeModal();
  });
  
  handleResize();
  
  // Initial load from MongoDB
  fetchCourses();
  
  // Auto-refresh every 30 seconds (optional, keeps data in sync)
  setInterval(() => {
    if (!document.hidden) {
      fetchCourses();
    }
  }, 30000);
</script>
</body>
</html>