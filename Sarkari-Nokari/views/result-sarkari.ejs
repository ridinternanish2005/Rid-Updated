<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Latest Results - Sarkari Naukari</title>

  <link rel="stylesheet" href="/nokari/css/common/navbar.css">
  <link rel="stylesheet" href="/nokari/css/common/footer.css">
  <link rel="stylesheet" href="/nokari/css/pages/results.css">

  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700&family=Noto+Sans:wght@400;500;600&display=swap" rel="stylesheet">
</head>

<body class="results-page">

  <%- include('common/navbar') %>
  <%- include('common/subnavbar') %>

  <%
    function fmtDate(val) {
      if (!val) return null;

      const d = new Date(val);

      if (isNaN(d)) return String(val);

      return d.toLocaleDateString('en-IN', {
        day: '2-digit',
        month: 'short',
        year: 'numeric'
      });
    }

    function getStateName(code) {

      const states = {

        central: "Central Govt / All India",

        ap: "Andhra Pradesh",
        ar: "Arunachal Pradesh",
        as: "Assam",
        br: "Bihar",
        cg: "Chhattisgarh",
        ga: "Goa",
        gj: "Gujarat",
        hr: "Haryana",
        hp: "Himachal Pradesh",
        jh: "Jharkhand",
        ka: "Karnataka",
        kl: "Kerala",
        mp: "Madhya Pradesh",
        mh: "Maharashtra",
        mn: "Manipur",
        ml: "Meghalaya",
        mz: "Mizoram",
        nl: "Nagaland",
        od: "Odisha",
        pb: "Punjab",
        rj: "Rajasthan",
        sk: "Sikkim",
        tn: "Tamil Nadu",
        tg: "Telangana",
        tr: "Tripura",
        up: "Uttar Pradesh",
        uk: "Uttarakhand",
        wb: "West Bengal",
        dl: "Delhi (NCT)",
        jk: "Jammu & Kashmir",
        la: "Ladakh",
        ch: "Chandigarh",
        dd: "Dadra & Nagar Haveli",
        py: "Puducherry"
      };

      return states[code] || code;
    }
  %>

  <div class="page-wrapper">

    <div class="container">

      <!-- Header -->
      <div class="page-header">
        <h1><span>📋</span> Latest Exam Results</h1>
      </div>

      <!-- Intro -->
        <div class="intro-card">
          <div class="intro-text">
            Welcome to <a href="#">Sarkari Naukari</a> — Stay informed about latest exam results across India.

            <div class="disclaimer-box">
              ⚠️ <strong class="d-label">Disclaimer:</strong>
              Result status and merit list information shown here are for informational purposes only.
              Candidates must verify all details on the
              <strong class="d-link">official website</strong>
              before taking any action. We are not liable for any discrepancy, loss or inconvenience.
            </div>
          </div>
          <a href="https://whatsapp.com/channel/0029VbCxUkXCMY0PLcmcOt0O"
            class="update-btn"
            target="_blank"
            rel="noopener noreferrer">
            📢 Join WhatsApp
          </a>
        </div>

        <!-- Quick result Index -->
        <div class="result-index-box">
          <div class="result-index-header">
            <span>All Latest Results</span>
            <span class="badge-count" id="resultCountBadge"><%= results.length %> Available</span>
          </div>
          <% if (results.length === 0) { %>
            <div class="empty-state">
              <div class="empty-icon">📭</div>
              <p>No results available right now. Please check back soon.</p>
            </div>
          <% } %>
          <div class="result-index-list">
            <% results.forEach(function(result, i) { %>
              <a class="result-index-item" href="/nokari/result/<%= result._id %>/detail">
                <span class="result-index-num"><%= i + 1 %>.</span>
                <span class="result-index-title"><%= result.title %></span>
                    <% if (result.totalPosts) { %>
                <span class="result-index-posts"><%= result.totalPosts.toLocaleString('en-IN') %> Posts</span>
              <% } %>

              </a>
            <% }); %>
          </div>
        </div>

      <!-- Cards -->
      <div class="card-grid">

        <% results.forEach(function(result) {

          const items = [];

          if (result.examDate)
            items.push({
              label: 'Exam Date',
              value: result.examDate,
              cls: 'highlight'
            });

          if (result.resultDate)
            items.push({
              label: 'Result Date',
              value: fmtDate(result.resultDate),
              cls: 'highlight'
            });

          if (result.resultType)
            items.push({
              label: 'Result Type',
              value: result.resultType
            });

          if (result.totalPosts)
            items.push({
              label: 'Total Posts',
              value: result.totalPosts.toLocaleString('en-IN') + '+',
              cls: 'highlight'
            });

          if (result.selectionProcess && result.selectionProcess.length)
            items.push({
              label: 'Selection Process',
              value: result.selectionProcess.join(' → ')
            });



          const half       = Math.ceil(items.length / 2);
          const leftItems  = items.slice(0, half);
          const rightItems = items.slice(half);
          const isOdd      = items.length % 2 !== 0;

        %>

        <div
            class="modern-card"
            id="<%= result._id %>"
            data-category="<%= result.category || '' %>"
            data-organization="<%= result.organization || '' %>"
          >

          <!-- Header -->
          <div class="card-header">

            <div class="card-title">
              <%= result.title %>
            </div>

            <% if (result.organization) { %>
              <div class="card-org">
                <%= result.organization %>
              </div>
            <% } %>

            <div class="card-badges">
                <% if (result.category) { %>
                  <div class="category-badge">
                    <%= result.category %>
                  </div>
                <% } %>

                <% if (result.state) { %>
                  <div class="category-badge">
                    📌 <%= getStateName(result.state) %>
                  </div>
                <% } %>
              </div>



          </div>

          <%
            const iconMap = {

              'Exam Date': '📝',
              'Result Date': '📅',
              'Result Type': '🏷️',
              'Total Posts': '📈',
              'Selection Process': '⚙️',
              'Official Site': '🌐'

            };
          %>

          <!-- Info Body -->
          <div class="info-body">

            <!-- LEFT -->
            <div class="info-panel info-panel--left">

              <% leftItems.forEach(function(item) { %>

                <div class="info-item">

                  <span class="info-icon">
                    <%= iconMap[item.label] || '🔹' %>
                  </span>

                  <div class="info-text">

                    <span class="info-label">
                      <%= item.label %> :
                    </span>

                    <% if (item.cls === 'link') { %>

                      <span class="info-value">
                        <a href="<%= item.value %>" target="_blank">
                          <%= item.value %>
                        </a>
                      </span>

                    <% } else { %>

                      <span class="info-value <%= item.cls || '' %>">
                        <%= item.value %>
                      </span>

                    <% } %>

                  </div>

                </div>

              <% }); %>

            </div>

            <!-- RIGHT -->
            <div class="info-panel info-panel--right">

              <% rightItems.forEach(function(item) { %>

                <div class="info-item">

                  <span class="info-icon">
                    <%= iconMap[item.label] || '🔹' %>
                  </span>

                  <div class="info-text">

                    <span class="info-label">
                      <%= item.label %> :
                    </span>

                    <% if (item.cls === 'link') { %>

                      <span class="info-value">
                        <a href="<%= item.value %>" target="_blank">
                          <%= item.value %>
                        </a>
                      </span>

                    <% } else { %>

                      <span class="info-value <%= item.cls || '' %>">
                        <%= item.value %>
                      </span>

                    <% } %>

                  </div>

                </div>

              <% }); %>

              <% if (isOdd) { %>

                <div class="info-item info-item--empty">

                  <span class="info-icon"></span>

                  <div class="info-text">
                    <span class="info-label"></span>
                    <span class="info-value"></span>
                  </div>

                </div>

              <% } %>

            </div>

          </div>

          <!-- Footer -->
          <!-- Footer -->
          <div class="card-footer">

            <% if (result.officialSite) { %>
              <a class="footer-btn btn-official" href="<%= result.officialSite %>" target="_blank">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="2" y1="12" x2="22" y2="12"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
                Official Site
              </a>
            <% } %>

            <% if (result.resultLink) { %>
              <a class="footer-btn btn-secondary" href="<%= result.resultLink %>" target="_blank">
                📄 View Result
              </a>
            <% } else { %>
              <span class="btn-disabled">
                🔒 Result Not Available Yet
              </span>
            <% } %>

            <% if (result.meritListLink) { %>
              <a class="footer-btn btn-merit" href="<%= result.meritListLink %>" target="_blank">
                🏆 Merit List
              </a>
            <% } %>

            <a class="footer-btn btn-guide" href="/nokari/exam/result/<%= result._id %>">
              📘 Detail Guide
            </a>

          </div>

        </div>

        <% }); %>

      </div>

    </div>

  </div>

  <%- include('common/footer') %>

  <script src="/nokari/js/results.js"></script>

</body>
</html>