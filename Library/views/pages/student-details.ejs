<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student-details</title>
    <link rel="stylesheet" href="/library/css/student-details.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZmHnM+YIY7qD3SrtxUknkXl2p5XhY+Yd1e9+UeBfEYdgRZgiwxhTBTkF7CXvN" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
    <div class="details-modal-overlay">
    <div class="details-modal">
        <div class="details-header">
            <h2>📋 Details</h2>
            <a href="/library/dashboard" class="details-close">&times;</a>
        </div>

        <div class="details-content">
            <!-- Candidate -->
            <div class="detail-row">
                <div class="detail-icon">👤</div>
                <div class="detail-info">
                    <span class="detail-label">Candidate</span>
                    <strong class="detail-value"><%= student.fullName %></strong>
                </div>
            </div>

            <!-- Mobile -->
            <div class="detail-row">
                <div class="detail-icon">📱</div>
                <div class="detail-info">
                    <span class="detail-label">Mobile</span>
                    <strong class="detail-value"><%= student.mobileNumber %></strong>
                </div>
            </div>

            <!-- Site # (Seat Number) -->
            <div class="detail-row">
                <div class="detail-icon">🪑</div>
                <div class="detail-info">
                    <span class="detail-label">Site #</span>
                    <strong class="detail-value"><%= student.seatNumber %></strong>
                </div>
            </div>

            <!-- Site Type -->
            <div class="detail-row">
                <div class="detail-icon">🏷️</div>
                <div class="detail-info">
                    <span class="detail-label">Site Type</span>
                    <span class="detail-badge <%= student.seatType === 'Reserved' ? 'badge-reserved' : 'badge-normal' %>">
                        <i class="fa-solid fa-heart"></i> <%= student.seatType %>
                    </span>
                </div>
            </div>

            <!-- Date -->
            <div class="detail-row">
                <div class="detail-icon">📅</div>
                <div class="detail-info">
                    <span class="detail-label">Date</span>
                    <strong class="detail-value"><%= new Date(student.date).toLocaleDateString('en-IN') %></strong>
                </div>
            </div>

            <!-- Shift -->
            <div class="detail-row">
                <div class="detail-icon">⏰</div>
                <div class="detail-info">
                    <span class="detail-label">Shift</span>
                    <strong class="detail-value"><%= student.shift %></strong>
                </div>
            </div>

            <!-- Fee -->
            <div class="detail-row">
                <div class="detail-icon">💰</div>
                <div class="detail-info">
                    <span class="detail-label">Fee</span>
                    <strong class="detail-value">₹<%= student.fees %></strong>
                </div>
            </div>

            <!-- Payment Status -->
            <div class="detail-row">
                <div class="detail-icon">💳</div>
                <div class="detail-info">
                    <span class="detail-label">Payment</span>
                    <span class="detail-badge <%= student.paymentStatus === 'Paid' ? 'badge-paid' : 'badge-unpaid' %>">
                        <% if (student.paymentStatus === 'Paid') { %>
                            ✓ PAID
                        <% } else { %>
                            ✗ UNPAID
                        <% } %>
                    </span>
                </div>
            </div>

            <!-- In time -->
            <div class="detail-row">
                <div class="detail-icon">🔓</div>
                <div class="detail-info">
                    <span class="detail-label">In time</span>
                    <strong class="detail-value">09:00 AM</strong>
                </div>
            </div>

            <!-- Out time -->
            <div class="detail-row">
                <div class="detail-icon">🔒</div>
                <div class="detail-info">
                    <span class="detail-label">Out time</span>
                    <strong class="detail-value">05:00 PM</strong>
                </div>
            </div>
        </div>

        <div class="details-actions">
            <form action="/library/student/<%= student._id %>/payment" method="POST" class="update-payment-form">
                <button type="submit" class="btn-update-payment">
                    <i class="fa-solid fa-refresh"></i> Update payment
                </button>
            </form>

            <form action="/library/student/<%= student._id %>/delete" method="POST" class="delete-form" onsubmit="return confirm('Are you sure you want to delete this student?');">
                <button type="submit" class="btn-delete-card">
                    <i class="fa-solid fa-trash"></i> Delete this card
                </button>
            </form>
        </div>
    </div>
</div>
</body>
</html>




