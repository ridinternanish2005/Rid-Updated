<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>Elysian Books | Digital E-Book Library</title>
  <!-- Tailwind CSS + Google Fonts + Font Awesome -->
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="/library/css/E-book.css">
  <style>
    /* When this page loads with Tailwind present, ensure sidebar items keep their original sizing */
    .sidebar .menu a,
    .sidebar .menu a.active,
    .sidebar .menu a:hover {
      padding-top: 12px !important;
      padding-bottom: 12px !important;
      padding-left: 20px !important;
      padding-right: 20px !important;
      align-items: center !important;
      min-height: 44px !important;
      line-height: 1.1 !important;
    }
    .sidebar .menu i { font-size: 18px !important; }
    .sidebar .menu span { font-size: 18px !important; }
  </style>
</head>
<body>

  <!-- Main Container: Centered Card Style -->
  <div class="max-w-5xl w-full mx-auto fade-in p-5 md:p-8">
    <div class="glass-hero p-6 md:p-10 lg:p-12">
      <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
        
        <!-- Left Side: Content -->
        <div class="flex-1 text-center lg:text-left">
          <!-- Floating mini book icons above heading -->
          <div class="flex justify-center lg:justify-start gap-3 mb-4">
            <i class="fas fa-book-open text-indigo-400 text-xl floating-icon"></i>
            <i class="fas fa-book-reader text-purple-400 text-xl floating-icon-delayed"></i>
            <i class="fas fa-graduation-cap text-blue-400 text-xl floating-icon" style="animation-duration: 4.5s;"></i>
          </div>
          
          <!-- Main Heading -->
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold bg-gradient-to-r from-indigo-700 via-purple-700 to-indigo-800 bg-clip-text text-transparent leading-tight">
            Explore Our Digital <br>E-Book Library
          </h1>
          
          <!-- Description Text -->
          <p class="text-gray-600 mt-5 text-base md:text-lg leading-relaxed max-w-md mx-auto lg:mx-0">
            Access thousands of premium e-books, bestsellers, and academic resources — all in one place. Read anywhere, anytime.
          </p>
          
          <div class="mt-8">
            <a href="https://www.ridtech.in/ebook/?search=&filter=all&sort=newest" target="_blank" rel="noopener noreferrer" class="btn-cta inline-flex items-center gap-3 px-8 py-3.5 rounded-full text-white font-semibold text-base md:text-lg shadow-xl transition-all">
              <i class="fas fa-book-open text-lg"></i>
              Open E-Books
              <i class="fas fa-arrow-right text-sm transition-transform group-hover:translate-x-1"></i>
            </a>
            <p class="text-xs text-gray-400 mt-4">✨ Redirects to our secure e-book portal</p>
          </div>
        </div>
        
        <div class="flex-1 flex justify-center relative">
          <div class="absolute w-48 h-48 bg-indigo-200/40 rounded-full blur-2xl -z-0"></div>
          <div class="absolute w-64 h-64 bg-purple-200/30 rounded-full blur-3xl -z-0 top-10 right-10"></div>
          
          <div class="relative floating-icon">
            <div class="relative bg-white/80 backdrop-blur-sm p-5 rounded-3xl shadow-2xl border border-white/60">
              <img src="https://placehold.co/400x400/eef2ff/6366f1?text=✨&font=roboto" 
                   alt="Digital E-Book Illustration" 
                   class="w-56 md:w-64 lg:w-72 h-auto rounded-2xl shadow-xl">
              <div class="absolute -top-6 -right-6 bg-white/90 rounded-full p-3 shadow-lg">
                <i class="fas fa-cloud-upload-alt text-indigo-500 text-xl"></i>
              </div>
              <div class="absolute -bottom-5 -left-5 bg-indigo-100 rounded-full p-2 shadow-md">
                <i class="fas fa-file-pdf text-indigo-600 text-sm"></i>
              </div>
            </div>
            <i class="fas fa-book absolute -top-8 -left-8 text-indigo-300 text-2xl floating-icon-delayed"></i>
            <i class="fas fa-bookmark absolute -bottom-6 right-4 text-purple-300 text-xl floating-icon"></i>
          </div>
        </div>
      </div>
      
      <div class="text-center mt-10 pt-4 border-t border-indigo-100/50">
        <p class="text-xs text-gray-400 flex items-center justify-center gap-2">
          <i class="fas fa-shield-alt text-indigo-300"></i> 
          Instant access • No signup required • Free preview
          <i class="fas fa-smile-wink text-indigo-300"></i>
        </p>
      </div>
    </div>
  </div>

  <div class="fixed bottom-5 left-5 text-indigo-200 opacity-30 pointer-events-none text-4xl hidden md:block">
    <i class="fas fa-book-open"></i>
  </div>
  <div class="fixed top-1/3 right-8 text-purple-200 opacity-25 pointer-events-none text-5xl hidden lg:block floating-icon-delayed">
    <i class="fas fa-graduation-cap"></i>
  </div>

  <script>
    console.log("✨ E-Book redirect page loaded — redirect button ready.");
  </script>
</body>
</html>