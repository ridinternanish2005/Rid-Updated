<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage-tests</title>
    <link rel="stylesheet" href="/library/css/bootstrap.min.css">
    <link rel="stylesheet" href="/library/css/fontawesome.min.css">
</head>
<body>
    <%- include('../partials/navbar') %>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-3">📊 Manage Tests</h1>
            <p class="text-muted">View, edit, and analyze your tests</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/library/create-tests" class="btn btn-primary btn-lg">
                <i class="fas fa-plus"></i> Create New Test
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Search by title..." id="searchInput" onkeyup="filterTests()">
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="categoryFilter" onchange="filterTests()">
                        <option value="">All Categories</option>
                        <option value="Programming">Programming</option>
                        <option value="General Knowledge">General Knowledge</option>
                        <option value="Aptitude">Aptitude</option>
                        <option value="Science">Science</option>
                        <option value="Math">Math</option>
                        <option value="Language">Language</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="statusFilter" onchange="filterTests()">
                        <option value="">All Status</option>
                        <option value="published">Published</option>
                        <option value="draft">Draft</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Tests Table -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="testsTable">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Questions</th>
                        <th>Difficulty</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Attempts</th>
                        <th>Avg Score</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="testsBody">
                    <tr>
                        <td colspan="9" class="text-center py-4 text-muted">Loading...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Test Details Modal -->
<div class="modal fade" id="testDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Test Details & Analytics</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="testDetailsContent">Loading...</div>
            </div>
        </div>
    </div>
</div>

<!-- Share Link Modal -->
<div class="modal fade" id="shareLinkModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Share Test Link</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Public Link:</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="shareLinkInput" readonly>
                        <button class="btn btn-primary" onclick="copyShareLink()">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                </div>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    Share this link with your students to take the test.
                </div>
                <div class="mb-3">
                    <label class="form-label">Share via:</label>
                    <div class="btn-group w-100" role="group">
                        <button type="button" class="btn btn-outline-primary" onclick="shareVia('whatsapp')">
                            <i class="fab fa-whatsapp"></i> WhatsApp
                        </button>
                        <button type="button" class="btn btn-outline-primary" onclick="shareVia('email')">
                            <i class="fas fa-envelope"></i> Email
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
 <script href="manage-tests.js"></script>
</body>
</html>




