     <button
  class="category-btn"
  onclick="alert('🚧 DSA Section Coming Soon!')"
>
  <i class="fas fa-sitemap"></i> DSA
</button>
        <button class="category-btn"
  onclick="alert('🚧 Interview Questions   Coming Soon!')"><i class="fas fa-user-tie"></i> Interview Questions</button>
       <button class="category-btn" onclick="window.location.href='/'">
    <i class="fas fa-code"></i> Language Practice
</button>
      </div>
      <div class="subtopics-wrapper">
        <button class="subtopic-btn active-subtopic" data-topic="all"><i class="fas fa-layer-group"></i> All Topics</button>
        <button class="subtopic-btn" data-topic="basic-iop"><i class="fas fa-keyboard"></i> Basic</button>
        <button class="subtopic-btn" data-topic="conditions"><i class="fas fa-code-branch"></i> Conditions</button>
        <button class="subtopic-btn" data-topic="loops"><i class="fas fa-repeat"></i> Loops</button>
        <button class="subtopic-btn" data-topic="patterns"><i class="fas fa-shapes"></i> Patterns</button>
        <button class="subtopic-btn" data-topic="number-problems"><i class="fas fa-hashtag"></i> Numbers</button>
        <button class="subtopic-btn" data-topic="digit-problems"><i class="fas fa-calculator"></i> Digits</button>
        <button class="subtopic-btn" data-topic="factor-divisibility"><i class="fas fa-divide"></i> Factors</button>
        <button class="subtopic-btn" data-topic="math-logic"><i class="fas fa-square-root-alt"></i> Math Logic</button>
        <button class="subtopic-btn" data-topic="special-numbers"><i class="fas fa-star"></i> Special Numbers</button>
        <button class="subtopic-btn" data-topic="conversion"><i class="fas fa-right-left"></i> Conversion</button>
        <button class="subtopic-btn" data-topic="range-problems"><i class="fas fa-arrows-left-right"></i> Range Problems</button>
        <button class="subtopic-btn" data-topic="string-problems"><i class="fas fa-font"></i> String Problems</button>
      </div>
    </div>

    <div class="questions-container" id="questionsContainer"></div>
  </div>

  <!-- LEADERBOARD VIEW -->
  <div id="leaderboardView" style="display: none;">
    <div class="leaderboard-card"><h3><i class="fas fa-ranking-star"></i> Global Leaderboard</h3>
      <table class="leaderboard-table"><thead><tr><th>Rank</th><th>User</th><th>Solved</th><th>XP</th><th>Streak</th></tr></thead>
      <tbody>
        <tr><td class="rank-badge">1</td><td><i class="fas fa-user-circle"></i> John Doe</td><td>142</td><td>2840</td><td>12</td></tr>
        <tr><td class="rank-badge">2</td><td><i class="fas fa-user-circle"></i> Sarah Williams</td><td>128</td><td>2560</td><td>9</td></tr>
        <tr><td class="rank-badge">3</td><td><i class="fas fa-user-circle"></i> Michael Kumar</td><td>115</td><td>2300</td><td>7</td></tr>
        <tr><td class="rank-badge">4</td><td><i class="fas fa-user-circle"></i> Priya Sharma</td><td>98</td><td>1960</td><td>5</td></tr>
        <tr><td class="rank-badge">5</td><td><i class="fas fa-user-circle"></i> Alex Rivera</td><td>87</td><td>1740</td><td>4</td></tr>
      </tbody></table>
    </div>
  </div>

  <!-- CONTESTS VIEW -->
  <div id="contestsView" style="display: none;">
    <div class="leaderboard-card"><h3><i class="fas fa-trophy"></i> Upcoming Contests</h3><p style="margin-top:1rem;">Weekly coding challenges & leaderboard contests coming soon. Stay tuned!</p><div class="empty-placeholder" style="padding:2rem; text-align:center;"><i class="fas fa-calendar-alt"></i> Phase 2: contests & achievements</div></div>
  </div>
</div>

