<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>Code Arena By RID Tech</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/practice.css">
</head>
<body>

<div class="navbar">
  <div class="nav-container">
    <div class="nav-left">
      <div class="logo-main"><i class="fas fa-laptop-code"></i> Code Arena</div>
      <div class="powered-by">by RID Tech </div>
    </div>
    <div class="nav-links">
      <button class="nav-link active" data-nav="problems">Problems</button>
      <button class="nav-link" data-nav="leaderboard">Leaderboard</button>
      <button class="nav-link" data-nav="contests">Contests</button>
      <button class="nav-link" data-nav="dashboard">Coding Journey ⭐</button>
    </div>
    <div class="nav-right">
      <div class="search-wrapper">
        <i class="fas fa-search"></i>
        <input type="text" id="globalSearchInput" placeholder="Search...">
      </div>
      <!-- <div class="profile-icon" id="profileIcon"><i class="fas fa-user"></i></div> -->
      <button class="dark-toggle" id="darkModeToggle"><i class="fas fa-moon"></i> Dark</button>
    </div>
  </div>
</div>

<div id="profileModal" class="profile-modal">
  <div class="modal-header">
    <div class="modal-avatar"><i class="fas fa-user"></i></div>
    <div class="modal-info">
      <h4 id="modalUsername">CodeCoder</h4>
      <p>Member since 2025</p>
    </div>
  </div>
  <div class="modal-stats">
    <div><span>✅ Solved:</span><span id="modalSolved">0</span></div>
    <div><span>🔥 Streak:</span><span id="modalStreak">0</span></div>
    <div><span>🏆 XP:</span><span id="modalXP">0</span></div>
    <div><span>⭐ Level:</span><span id="modalLevel">1</span></div>
  </div>
  <div class="modal-footer">
    <button id="closeProfileModal">Close</button>
  </div>
</div>

<div class="main-container">
  <!-- DASHBOARD VIEW -->
  <div id="dashboardView" style="display: none;">
    <div class="hero-section">
      <div class="hero-content"><h1>Sharpen Your Coding Skills</h1><p>Solve challenges, earn XP, and climb the leaderboard</p></div>
      <div class="hero-stats"><div class="hero-stat"><div class="number" id="heroStreak">0</div><div class="label">Day Streak</div></div><div class="hero-stat"><div class="number" id="heroSolved">0</div><div class="label">Problems Solved</div></div><div class="hero-stat"><div class="number" id="heroRank">1</div><div class="label">Global Rank</div></div></div>
    </div>
    <div class="dashboard-grid">
      <div class="stat-card"><div class="stat-header"><span><i class="fas fa-fire"></i> Current Streak</span><span>+10 XP daily</span></div><div class="stat-value" id="streakValue">0</div><div class="progress-bar"><div class="progress-fill" id="streakProgress"></div></div><p style="font-size:0.7rem;" id="streakMsg">Solve a problem today to continue</p></div>
      <div class="stat-card"><div class="stat-header"><span><i class="fas fa-check-circle"></i> Solved Problems</span><span>Total</span></div><div class="stat-value" id="totalSolved">0</div><div class="progress-bar"><div class="progress-fill" id="solvedFill"></div></div><p>Completion: <span id="completionPercent">0</span>%</p></div>
      <div class="stat-card"><div class="stat-header"><span><i class="fas fa-chart-simple"></i> Difficulty</span><span>Progress</span></div><div><span>🟢 Easy</span> <span style="float:right;" id="easyCount">0/12</span></div><div class="progress-bar"><div class="progress-fill" id="easyFill" style="background:#10b981;"></div></div><div><span>🟠 Medium</span> <span style="float:right;" id="mediumCount">0/8</span></div><div class="progress-bar"><div class="progress-fill" id="mediumFill" style="background:#f97316;"></div></div><div><span>🔴 Hard</span> <span style="float:right;" id="hardCount">0/5</span></div><div class="progress-bar"><div class="progress-fill" id="hardFill" style="background:#ef4444;"></div></div></div>
      <div class="stat-card"><div class="stat-header"><span><i class="fas fa-trophy"></i> Rank & XP</span><span>Level Up</span></div><div class="stat-value" id="xpValue">0</div><div class="progress-bar"><div class="progress-fill" id="xpProgressFill"></div></div><div>Level <span id="levelNum">1</span> Coder &nbsp;|&nbsp; Rank #<span id="rankNum">1</span></div></div>
    </div>
    <div class="badge-container" id="badgeContainer" style="display: flex; flex-wrap: wrap; gap: 10px; margin: 1rem 0; justify-content: center;"></div>
  </div>

  <!-- PROBLEMS VIEW -->
  <div id="problemsView">
    <div class="photo-container">
      <div class="photo-track">
        <img src="/assets/Interview.jpeg" class="gallery-photo">
    <a href="/tech-interview/code-arena">
<img src="/assets/problemsolving.png" class="gallery-photo"></a>
       <a href="/tech-interview"><img src="/assets/tech-interview.png" class="gallery-photo"></a>
        <img src="/assets/Javascript.jpeg" class="gallery-photo">
        <img src="/assets/Interview.jpeg" class="gallery-photo">
       <a href="/tech-interview/code-arena"> <img src="/assets/problemsolving.png" class="gallery-photo"></a>
       <a href="/tech-interview"> <img src="/assets/tech-interview.png" class="gallery-photo"></a>
        <img src="/assets/Javascript.jpeg" class="gallery-photo">
        <img src="/assets/Interview.jpeg" class="gallery-photo">
    <a href="/tech-interview/code-arena"> <img src="/assets/problemsolving.png" class="gallery-photo"></a>
       <a href="/tech-interview">  <img src="/assets/tech-interview.png" class="gallery-photo"></a>
        <img src="/assets/Javascript.jpeg" class="gallery-photo">
