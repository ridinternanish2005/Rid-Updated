 <!-- ✅ STEP 2: Smart Language Loader - localStorage check karke priority language pehle load karta hai -->
    <script>
      (function () {
        // ── localStorage se priority language decide karo ──
        const STORAGE_LANG = "codeques_lang";
        const supportedLanguages = ["py", "java", "cpp", "c", "js", "cs"];
        let priorityLang = localStorage.getItem(STORAGE_LANG) || "py";
        if (!supportedLanguages.includes(priorityLang)) priorityLang = "py";

        // ── Har language ki JS files ka map ──
        const langScripts = {
          py: [
             "/js/data/python/python-question1.js",
             "/js/data/python/python-question2.js",
             "/js/data/python/python-question3.js",
             "/js/data/python/python-question4.js",
             "/js/data/python/python-question5.js",
             "/js/data/python/python-question6.js",
             "/js/data/python/python-question7.js",
             "/js/data/python/python-question8.js",
          ],
          java: [
            "/js/data/java/java-question1.js",
            "/js/data/java/java-question2.js",
            "/js/data/java/java-question3.js",
            "/js/data/java/java-question4.js",
            "/js/data/java/java-question5.js",
           "/js/data/java/java-question6.js",
           "/js/data/java/java-question7.js"
          ],
          cpp: [
            "/js/data/C++/cpp-question1.js",
            "/js/data/C++/cpp-question2.js",
            "/js/data/C++/cpp-question3.js",
            "/js/data/C++/cpp-question4.js",
            "/js/data/C++/cpp-question5.js",
            "/js/data/C++/cpp-question6.js",
          ],
          c: [
             "/js/data/cp/c-question1.js",
             "/js/data/cp/c-question2.js",
             "/js/data/cp/c-question3.js",
             "/js/data/cp/c-question4.js",
            "/js/data/cp/c-question5.js",
            "/js/data/cp/c-question6.js",
             "/js/data/cp/c-question7.js", 
            ],
          js: [
            "/js/data/javascript/js-question1.js",
            "/js/data/javascript/js-question2.js",
            "/js/data/javascript/js-question3.js",
            "/js/data/javascript/js-question4.js",
            "/js/data/javascript/js-question5.js",
            "/js/data/javascript/js-question6.js",
          ],
          cs: [
     "/js/data/csharp/csharpe-question1.js",
     "/js/data/csharp/csharpe-question2.js",
     "/js/data/csharp/csharpe-question3.js",
     "/js/data/csharp/csharpe-question4.js",
     "/js/data/csharp/csharpe-question5.js",
     "/js/data/csharp/csharpe-question6.js",
          ],
        };

        // ── Ek script load karne ka function (Promise return karta hai) ──
        function loadScript(src) {
          return new Promise((resolve) => {
            // Already loaded? Skip karo
            if (document.querySelector('script[src="' + src + '"]')) {
              resolve();
              return;
            }
            const s = document.createElement("script");
            s.src = src;
            s.onload = resolve;
            s.onerror = resolve; // Error pe bhi resolve - ek file miss hone se sab ruke nahi
            document.head.appendChild(s);
          });
        }

        // ── Saari scripts parallel load karo ──
        function loadAllScripts(scripts) {
          return Promise.all(scripts.map(loadScript));
        }

        // ── Main loading logic ──
        // window._langLoadPromise ko IIFE await karega
        window._priorityLang = priorityLang; // IIFE ko bataao konsi language priority hai

        window._langLoadPromise = (async function () {
          // STEP A: Priority language ki files PEHLE load karo (await - zaroor wait karo)
          const priorityScripts = langScripts[priorityLang] || langScripts["py"];
          await loadAllScripts(priorityScripts);

          // STEP B: Baaki saari languages BACKGROUND mein load karo (await nahi - fire and forget)
          const otherLangs = Object.keys(langScripts).filter(
            (l) => l !== priorityLang
          );
          for (const lang of otherLangs) {
            loadAllScripts(langScripts[lang]); // NO await - background mein chalte raho
          }

          // STEP C: AI hint aur Go bhi background mein
          loadScript("/js/data/aiHint.js");
        })();
      })();
    </script>
